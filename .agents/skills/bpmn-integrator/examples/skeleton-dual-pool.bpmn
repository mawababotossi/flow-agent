<?xml version="1.0" encoding="UTF-8"?>
<!--
  SQUELETTE DUAL-POOL GNSPD — À COMPLÉTER PAR L'AGENT
  =====================================================
  Ce fichier est le point de départ de TOUTE nouvelle digitalisation.
  NE PAS générer un BPMN de zéro : partir de ce squelette.

  Instructions :
  1. Remplacer SERVICE par le nom fonctionnel du service (ex: DIPLOMECFA)
  2. Renseigner les ULIDs de formulaires (ULID_FORM_PRINCIPAL, ULID_FORM_CORRECTION...)
  3. Compléter les sections TODO dans Process_Xflow (vérification, instruction, décision)
  4. Si service PAYANT : décommenter les blocs [PAIEMENT] dans les deux pools
  5. Si service avec DOCUMENT : décommenter le bloc [CHAÎNE DOCUMENTAIRE]
  6. Mettre à jour les coordonnées DI en fonction du nombre de tâches ajoutées
  7. Supprimer les commentaires de guidage avant livraison

  Référence wiring XML : PATTERNS.md
  Référence templates   : SKILL.md §4
-->
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  exporter="Camunda Modeler" exporterVersion="5.42.0"
  modeler:executionPlatform="Camunda Platform"
  modeler:executionPlatformVersion="7.17.0">

  <!-- ═══════════════════════════════════════════════════════════
       MESSAGES KAFKA — Toujours déclarés avant la collaboration
       Remplacer SERVICE par le nom fonctionnel en majuscules
       ═══════════════════════════════════════════════════════════ -->
  <bpmn:message id="MSG_SERVICE_START"  name="MSG_SERVICE_START" />
  <bpmn:message id="MSG_SERVICE_RETURN" name="MSG_SERVICE_RETURN" />
  <bpmn:message id="MSG_SERVICE_RESUB"  name="MSG_SERVICE_RESUB" />
  <!-- [PAIEMENT] Décommenter si service payant :
  <bpmn:message id="MSG_SERVICE_PAY_ORDER"    name="MSG_SERVICE_PAY_ORDER" />
  <bpmn:message id="MSG_SERVICE_PAY_CALLBACK" name="MSG_SERVICE_PAY_CALLBACK" />
  <bpmn:message id="MSG_SERVICE_PAY_CONFIRM"  name="MSG_SERVICE_PAY_CONFIRM" />
  -->

  <!-- ═══════════════════════════════════════════════════════════
       COLLABORATION — 2 pools obligatoires
       ═══════════════════════════════════════════════════════════ -->
  <bpmn:collaboration id="Collaboration_SERVICE">
    <bpmn:participant id="Participant_Portal" name="XPORTAL" processRef="Process_Portal" />
    <bpmn:participant id="Participant_Xflow"  name="XFLOW"
      processRef="Process_Xflow"
      camunda:versionTag="1.0"
      camunda:historyTimeToLive="180" />

    <!-- MessageFlows (P8 : chaque Send a exactement 1 messageFlow) -->
    <bpmn:messageFlow id="MF_Start"    sourceRef="Send_P_Start"   targetRef="Event_X_Start" />
    <bpmn:messageFlow id="MF_Return"   sourceRef="Send_X_Return"  targetRef="Recv_P_Return" />
    <bpmn:messageFlow id="MF_Resub"    sourceRef="Send_P_Resub"   targetRef="Recv_X_Resub" />
    <!-- [PAIEMENT] Décommenter si service payant :
    <bpmn:messageFlow id="MF_PayOrder"   sourceRef="Send_X_PayOrder"   targetRef="Recv_P_PayOrder" />
    <bpmn:messageFlow id="MF_PayConfirm" sourceRef="Send_X_PayConfirm" targetRef="Recv_P_PayConfirm" />
    -->
  </bpmn:collaboration>

  <!-- ═══════════════════════════════════════════════════════════
       POOL XPORTAL — Machine à états (quasi-identique pour tous les services)
       NE PAS modifier la structure, seulement les ULIDs et noms
       ═══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Portal" isExecutable="true" camunda:versionTag="1">

    <!-- Soumission initiale par le citoyen -->
    <bpmn:startEvent id="Event_P_Start" name="Soumettre la demande"
      camunda:modelerTemplate="tg.gouv.gnspd.startEvent"
      camunda:type="external"
      camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Soumission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Le citoyen remplit et soumet le formulaire de demande.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter><!-- TODO: montant si payant -->
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <!-- TODO: Renseigner la config formulaire (voir SRS §2.4) -->
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>SF_P_Start_Send</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Envoi immédiat vers XFlow -->
    <bpmn:sendTask id="Send_P_Start" name="Soumettre dossier XFlow"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external"
      camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter><!-- StartEvent UNIQUEMENT ici -->
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_SERVICE_START</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Event_P_Start.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Start_Send</bpmn:incoming>
      <bpmn:outgoing>SF_P_SendStart_RecvReturn</bpmn:outgoing>
      <!-- [PAIEMENT] Si service payant, remplacer SF_P_SendStart_RecvReturn par SF_P_Send_RecvPayOrder -->
    </bpmn:sendTask>

    <!-- [PAIEMENT] Décommenter si service payant :
    <bpmn:receiveTask id="Recv_P_PayOrder" name="Recevoir ordre de paiement"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      camunda:type="external"
      messageRef="MSG_SERVICE_PAY_ORDER"
      camunda:topic="flow-receive-task">
      <bpmn:extensionElements>...</bpmn:extensionElements>
      <bpmn:incoming>SF_P_Send_RecvPayOrder</bpmn:incoming>
      <bpmn:outgoing>SF_P_PayOrder_TaskPay</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:userTask id="Task_P_Payment" name="Procéder au paiement"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:formKey="ULID_FORM_PAIEMENT"
      camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        ...
        <camunda:inputParameter name="gnspdHandlerType">tarification</camunda:inputParameter>
        ...
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_PayOrder_TaskPay</bpmn:incoming>
      <bpmn:outgoing>SF_P_TaskPay_RecvConfirm</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:receiveTask id="Recv_P_PayConfirm" name="Recevoir confirmation paiement"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      camunda:type="external"
      messageRef="MSG_SERVICE_PAY_CONFIRM"
      camunda:topic="flow-receive-task">
      <bpmn:extensionElements>...</bpmn:extensionElements>
      <bpmn:incoming>SF_P_TaskPay_RecvConfirm</bpmn:incoming>
      <bpmn:outgoing>SF_P_PayConfirm_RecvReturn</bpmn:outgoing>
    </bpmn:receiveTask>
    -->

    <!-- P2 : ReceiveTask multi-entrante — point de convergence unique -->
    <bpmn:receiveTask id="Recv_P_Return" name="Attendre réponse XFlow"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      camunda:type="external"
      messageRef="MSG_SERVICE_RETURN"
      camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_SendStart_RecvReturn</bpmn:incoming>       <!-- chemin initial (sans paiement) -->
      <!-- [PAIEMENT] <bpmn:incoming>SF_P_PayConfirm_RecvReturn</bpmn:incoming> -->
      <bpmn:incoming>SF_P_SendResub_RecvReturn</bpmn:incoming>      <!-- après resoumission correction -->
      <bpmn:outgoing>SF_P_RecvReturn_GwAction</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- Gateway action unique : lit l'action envoyée par XFlow -->
    <bpmn:exclusiveGateway id="Gw_P_Action" name="Action XFlow ?">
      <bpmn:incoming>SF_P_RecvReturn_GwAction</bpmn:incoming>
      <bpmn:outgoing>SF_P_Action_Correction</bpmn:outgoing>
      <bpmn:outgoing>SF_P_Action_Accepte</bpmn:outgoing>
      <bpmn:outgoing>SF_P_Action_Rejete</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Branche correction -->
    <bpmn:userTask id="Task_P_Correction" name="Corriger le dossier"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:formKey="ULID_FORM_CORRECTION"
      camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Le citoyen corrige son dossier suite à la demande de l'agent.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey">TODO_SLUG_FORMULAIRE_CORRECTION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_P_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments">{}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Corriger mon dossier</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Action_Correction</bpmn:incoming>
      <bpmn:outgoing>SF_P_Correction_Send</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="Send_P_Resub" name="Soumettre correction XFlow"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external"
      camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter><!-- ReceiveTask pour les resoumissions -->
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_SERVICE_RESUB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Task_P_Correction.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Correction_Send</bpmn:incoming>
      <bpmn:outgoing>SF_P_SendResub_RecvReturn</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- P7 : EndEvents explicites pour chaque branche -->
    <bpmn:endEvent id="End_P_Accepte" name="Demande acceptée">
      <bpmn:incoming>SF_P_Action_Accepte</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="End_P_Rejete" name="Demande rejetée">
      <bpmn:incoming>SF_P_Action_Rejete</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SequenceFlows XPortal -->
    <bpmn:sequenceFlow id="SF_P_Start_Send"         sourceRef="Event_P_Start"     targetRef="Send_P_Start" />
    <bpmn:sequenceFlow id="SF_P_SendStart_RecvReturn"     sourceRef="Send_P_Start"      targetRef="Recv_P_Return" />
    <bpmn:sequenceFlow id="SF_P_RecvReturn_GwAction" sourceRef="Recv_P_Return"     targetRef="Gw_P_Action" />
    <bpmn:sequenceFlow id="SF_P_Action_Correction"   sourceRef="Gw_P_Action"       targetRef="Task_P_Correction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Recv_P_Return.result.data.action == "correction"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Action_Accepte"      sourceRef="Gw_P_Action"       targetRef="End_P_Accepte">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Recv_P_Return.result.data.action == "accepte"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Action_Rejete"       sourceRef="Gw_P_Action"       targetRef="End_P_Rejete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Recv_P_Return.result.data.action == "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Correction_Send"    sourceRef="Task_P_Correction"  targetRef="Send_P_Resub" />
    <bpmn:sequenceFlow id="SF_P_SendResub_RecvReturn"    sourceRef="Send_P_Resub"       targetRef="Recv_P_Return" />

  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════
       POOL XFLOW — Orchestre le back-office
       TODO : compléter les sections marquées
       ═══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Xflow" isExecutable="true" camunda:versionTag="1">

    <!-- Entrée : réception de la soumission XPortal -->
    <bpmn:startEvent id="Event_X_Start" name="Réception dossier"
      camunda:modelerTemplate="tg.gouv.gnspd.startEvent"
      camunda:type="external"
      camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Réception du dossier soumis par le citoyen.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <!-- TODO: Renseigner la config KMS (ODOO, GED, APIs) depuis SRS §4 -->
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:messageEventDefinition messageRef="MSG_SERVICE_START" />
      <bpmn:outgoing>SF_X_Start_FirstTask</bpmn:outgoing>
    </bpmn:startEvent>

    <!--
    TODO : Insérer ici les tâches métier XFlow selon le SRS :
      - P5 : vérification système (Odoo search_read, API REST) en premier
      - Instruction agent (userTask back-office)
      - Gateway décision (3 sorties : approve / correction / reject)
      - Branche approve : [CHAÎNE DOCUMENTAIRE] ou directement notify+send
      - Branche correction : notify + send_correction + recv_resub (P6)
      - Nœud de rejet DRY P4 (plusieurs incomings)
      - [PAIEMENT] si service payant : send_payorder + intermediateCatch + gw_payok + send_payconfirm

    Copier les snippets correspondants depuis PATTERNS.md.
    -->

    <!-- Point de re-entrée après resoumission (P6) -->
    <bpmn:receiveTask id="Recv_X_Resub" name="Attendre resoumission"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      camunda:type="external"
      messageRef="MSG_SERVICE_RESUB"
      camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>TODO_SF_Correction_RecvResub</bpmn:incoming>
      <bpmn:outgoing>TODO_SF_RecvResub_BackToVerification</bpmn:outgoing><!-- P6 : retour vérification -->
    </bpmn:receiveTask>

    <!-- P7 : EndEvent succès principal — gnspdTaskStatus DOIT être "Completed" -->
    <bpmn:endEvent id="End_X_Success" name="Dossier traité avec succès"
      camunda:modelerTemplate="tg.gouv.gnspd.endEvent"
      camunda:type="external"
      camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier traité</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>TODO_SF_Send_EndSuccess</bpmn:incoming>
    </bpmn:endEvent>

    <!-- P7 : EndEvent rejet — gnspdTaskStatus DOIT être "Completed" -->
    <bpmn:endEvent id="End_X_Reject" name="Dossier rejeté"
      camunda:modelerTemplate="tg.gouv.gnspd.endEvent"
      camunda:type="external"
      camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier rejeté</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>TODO_SF_SendReject_EndReject</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SequenceFlow de départ (à compléter) -->
    <bpmn:sequenceFlow id="SF_X_Start_FirstTask" sourceRef="Event_X_Start" targetRef="TODO_FIRST_TASK" />

  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════
       BPMNDI — Section graphique obligatoire
       Grille : XPortal y=80→580, XFlow y=650→1250
       StartEvent 36x36 | Tâche 100x80 | Gateway 50x50
       Incrément horizontal : 160px entre éléments
       ═══════════════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_SERVICE">

      <!-- Pools -->
      <bpmndi:BPMNShape id="Participant_Portal_di" bpmnElement="Participant_Portal" isHorizontal="true">
        <dc:Bounds x="140" y="80" width="2970" height="500" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Xflow_di" bpmnElement="Participant_Xflow" isHorizontal="true">
