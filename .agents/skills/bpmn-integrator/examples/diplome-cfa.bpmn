<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_CFA_Diplome" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.17.0">
  
  <bpmn:message id="MSG_START_XFLOW" name="CFA_START_XFLOW" />
  <bpmn:message id="MSG_CORRECTION_REQ" name="CFA_CORRECTION_REQ" />
  <bpmn:message id="MSG_RESUBMIT" name="CFA_RESUBMIT" />
  <bpmn:message id="MSG_FINAL_STATUS" name="CFA_FINAL_STATUS" />
  <bpmn:message id="MSG_REJET_STATUS" name="CFA_REJET_STATUS" />

  <bpmn:collaboration id="Collaboration_CFA">
    <bpmn:participant id="Participant_Portal" name="XPORTAL" processRef="Process_CFA_Portal" />
    <bpmn:participant id="Participant_XFlow" name="XFLOW" processRef="Process_CFA_Flow" />
    <bpmn:messageFlow id="Flow_M1" sourceRef="Activity_P_Submit" targetRef="Event_F_Start" />
    <bpmn:messageFlow id="Flow_M2" sourceRef="Activity_F_SendCorrection" targetRef="Activity_P_RecvCorrection" />
    <bpmn:messageFlow id="Flow_M3" sourceRef="Activity_P_SendResubmit" targetRef="Activity_F_RecvResubmit" />
    <bpmn:messageFlow id="Flow_M4" sourceRef="Activity_F_SendFinal" targetRef="Activity_P_RecvFinal" />
    <bpmn:messageFlow id="Flow_M5" sourceRef="Activity_F_SendRejet" targetRef="Activity_P_RecvFinal" />
  </bpmn:collaboration>

  <bpmn:process id="Process_CFA_Portal" name="Portail - Diplôme CFA" isExecutable="true" camunda:versionTag="1.0">
    <bpmn:startEvent id="Event_P_Start" name="Demande soumise" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Le candidat soumet sa demande de diplôme CFA depuis XPortal</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_P1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_P1" sourceRef="Event_P_Start" targetRef="Activity_P_Submit" />
    
    <bpmn:sendTask id="Activity_P_Submit" name="Notifier Back-Office" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMessageRef">CFA_START_XFLOW</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P1</bpmn:incoming>
      <bpmn:outgoing>Flow_P2</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_P2" sourceRef="Activity_P_Submit" targetRef="Gateway_P_Loop" />

    <bpmn:exclusiveGateway id="Gateway_P_Loop" name="Attente Etat">
      <bpmn:incoming>Flow_P2</bpmn:incoming>
      <bpmn:incoming>Flow_P_LoopIn</bpmn:incoming>
      <bpmn:outgoing>Flow_P3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_P3" sourceRef="Gateway_P_Loop" targetRef="Gateway_P_Wait" />

    <bpmn:eventBasedGateway id="Gateway_P_Wait" name="Attendre Message">
      <bpmn:incoming>Flow_P3</bpmn:incoming>
      <bpmn:outgoing>Flow_P_ToCorr</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_ToFinal</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="Activity_P_RecvCorrection" name="Demande Correction">
      <bpmn:incoming>Flow_P_ToCorr</bpmn:incoming>
      <bpmn:outgoing>Flow_P4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgCorrReq" messageRef="MSG_CORRECTION_REQ" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_P_ToCorr" sourceRef="Gateway_P_Wait" targetRef="Activity_P_RecvCorrection" />

    <bpmn:userTask id="Activity_P_Correction" name="Corriger le Dossier" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:incoming>Flow_P4</bpmn:incoming>
      <bpmn:outgoing>Flow_P5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_P4" sourceRef="Activity_P_RecvCorrection" targetRef="Activity_P_Correction" />

    <bpmn:sendTask id="Activity_P_SendResubmit" name="Soumettre Correction" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMessageRef">CFA_RESUBMIT</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P5</bpmn:incoming>
      <bpmn:outgoing>Flow_P_LoopIn</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_P5" sourceRef="Activity_P_Correction" targetRef="Activity_P_SendResubmit" />
    <bpmn:sequenceFlow id="Flow_P_LoopIn" sourceRef="Activity_P_SendResubmit" targetRef="Gateway_P_Loop" />

    <bpmn:intermediateCatchEvent id="Activity_P_RecvFinal" name="Notification Finale">
      <bpmn:incoming>Flow_P_ToFinal</bpmn:incoming>
      <bpmn:outgoing>Flow_P6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgFinal" messageRef="MSG_FINAL_STATUS" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_P_ToFinal" sourceRef="Gateway_P_Wait" targetRef="Activity_P_RecvFinal" />

    <bpmn:endEvent id="Event_P_End" name="Fin" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_P6" sourceRef="Activity_P_RecvFinal" targetRef="Event_P_End" />
  </bpmn:process>

  <bpmn:process id="Process_CFA_Flow" name="Back-Office - Diplôme CFA" isExecutable="true" camunda:versionTag="1.0" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="Event_F_Start" name="Réception Kafka" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdExecution">XFLOW</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_F1" sourceRef="Event_F_Start" targetRef="Activity_F_NotifyIn" />

    <bpmn:serviceTask id="Activity_F_NotifyIn" name="Accusé de réception" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:incoming>Flow_F1</bpmn:incoming>
      <bpmn:outgoing>Flow_F2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_F2" sourceRef="Activity_F_NotifyIn" targetRef="Activity_F_VerifyOdoo" />

    <bpmn:serviceTask id="Activity_F_VerifyOdoo" name="Vérification base" camunda:modelerTemplate="tg.gouv.gnspd.odoo" camunda:type="external" camunda:topic="flow-odoo">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdModel">exam.inscription</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMethod">search_read</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDomain">
            <camunda:script scriptFormat="javascript">
              JSON.stringify({"table_number": this.data.numeroTable});
            </camunda:script>
          </camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F2</bpmn:incoming>
      <bpmn:incoming>Flow_F_Resubmitted</bpmn:incoming>
      <bpmn:outgoing>Flow_F3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_F3" sourceRef="Activity_F_VerifyOdoo" targetRef="Activity_F_Instruction" />

    <bpmn:userTask id="Activity_F_Instruction" name="Instruction du Dossier" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:incoming>Flow_F3</bpmn:incoming>
      <bpmn:outgoing>Flow_F4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_F4" sourceRef="Activity_F_Instruction" targetRef="Gateway_F_Decision" />

    <bpmn:exclusiveGateway id="Gateway_F_Decision" name="Décision ?">
      <bpmn:incoming>Flow_F4</bpmn:incoming>
      <bpmn:outgoing>Flow_F_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_F_Correction</bpmn:outgoing>
      <bpmn:outgoing>Flow_F_Rejet</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_F_OK" name="Conforme" sourceRef="Gateway_F_Decision" targetRef="Activity_F_NotifyEnd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_F_Instruction.result.decision == 'APPROUVE'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_F_Correction" name="Correction" sourceRef="Gateway_F_Decision" targetRef="Activity_F_SendCorrection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_F_Instruction.result.decision == 'CORRECTION'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F_Rejet" name="Rejeté" sourceRef="Gateway_F_Decision" targetRef="Activity_F_NotifRejet">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_F_Instruction.result.decision == 'REJETE'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_F_RejetNotif" sourceRef="Activity_F_NotifRejet" targetRef="Activity_F_SendRejet" />
    <bpmn:sequenceFlow id="Flow_F_RejetSend" sourceRef="Activity_F_SendRejet" targetRef="Event_F_EndRejet" />

    <bpmn:sendTask id="Activity_F_SendCorrection" name="Notifier Correction" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
       <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMessageRef">CFA_CORRECTION_REQ</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F_Correction</bpmn:incoming>
      <bpmn:outgoing>Flow_F5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_F5" sourceRef="Activity_F_SendCorrection" targetRef="Activity_F_RecvResubmit" />

    <bpmn:receiveTask id="Activity_F_RecvResubmit" name="Attendre Resoumission" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_RESUBMIT" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:incoming>Flow_F5</bpmn:incoming>
      <bpmn:outgoing>Flow_F_Resubmitted</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:sequenceFlow id="Flow_F_Resubmitted" sourceRef="Activity_F_RecvResubmit" targetRef="Activity_F_VerifyOdoo" />

    <bpmn:serviceTask id="Activity_F_NotifyEnd" name="Notifier Succès" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:incoming>Flow_F_OK</bpmn:incoming>
      <bpmn:outgoing>Flow_F6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_F6" sourceRef="Activity_F_NotifyEnd" targetRef="Activity_F_SendFinal" />

    <bpmn:sendTask id="Activity_F_SendFinal" name="Clôturer Portail" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMessageRef">CFA_FINAL_STATUS</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F6</bpmn:incoming>
      <bpmn:outgoing>Flow_F_End</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_F_End" name="Fin succès" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_F_End" sourceRef="Activity_F_SendFinal" targetRef="Event_F_End" />
    <!-- === CHEMIN REJET === -->
    <bpmn:serviceTask id="Activity_F_NotifRejet" name="Notifier Rejet définitif" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">01KHBXDFGV1NTPHAR80ZSWEZXH</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": this.data.Activity_F_Instruction.result.motif ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">01KHBXF5B8B8WH9QFDZP607F5M</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">01KHBXFNJPJT5WZ3K0W9BBDF3N</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F_Rejet</bpmn:incoming>
      <bpmn:outgoing>Flow_F_RejetNotif</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_F_SendRejet" name="Clôturer Portail (Rejet)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_REJET_STATUS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "rejete", "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F_RejetNotif</bpmn:incoming>
      <bpmn:outgoing>Flow_F_RejetSend</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_F_EndRejet" name="Fin rejet" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_F_RejetSend</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_CFA">
      <!-- POOL PORTAL -->
      <bpmndi:BPMNShape id="Participant_Portal_di" bpmnElement="Participant_Portal" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1600" height="280" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_P_Start_di" bpmnElement="Event_P_Start">
        <dc:Bounds x="222" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="235" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_Submit_di" bpmnElement="Activity_P_Submit">
        <dc:Bounds x="310" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_P_Loop_di" bpmnElement="Gateway_P_Loop" isMarkerVisible="true">
        <dc:Bounds x="465" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="453" y="242" width="74" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_P_Wait_di" bpmnElement="Gateway_P_Wait">
        <dc:Bounds x="575" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="557" y="242" width="86" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_RecvCorrection_di" bpmnElement="Activity_P_RecvCorrection">
        <dc:Bounds x="687" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="664" y="325" width="82" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_Correction_di" bpmnElement="Activity_P_Correction">
        <dc:Bounds x="780" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_SendResubmit_di" bpmnElement="Activity_P_SendResubmit">
        <dc:Bounds x="940" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_RecvFinal_di" bpmnElement="Activity_P_RecvFinal">
        <dc:Bounds x="687" y="192" width="36" height="36" />
