            {
              "label": "Faire une demande",
              "showValidations": false,
              "disableOnInvalid": true,
              "key": "faireUneDemande",
              "properties": {
                "key": "startButton"
              },
              "type": "button",
              "input": true,
              "defaultValue": null,
              "persistent": false,
              "dataGridLabel": true,
              "validateOn": "change",
              "size": "md",
              "leftIcon": "",
              "rightIcon": "",
