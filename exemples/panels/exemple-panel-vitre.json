                {
                  "attr": "",
                  "value": ""
                }
              ],
              "content": "<div style=\"display:flex;gap:20px;flex-wrap:wrap;margin-top:20px;\"><div style=\"flex:1;min-width:220px;background:#fff;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">⏱️</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Délai d'exécution</h3><p style=\"font-size:15px;color:#333;margin:0;\">30 jours calendaires</p></div><div style=\"flex:1;min-width:220px;background:#f9fafb;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">💰</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Coût de la procédure</h3><p style=\"font-size:15px;color:#333;margin:0;\">10 000 FCFA + 2 000 FCFA (frais de timbre)</p></div><div style=\"flex:1;min-width:220px;background:#f9fafb;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">📅</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Durée de validité</h3><p style=\"font-size:15px;color:#333;margin:0;\">L'autorisation de vitre teintée est valable pour une durée de 2 ans à compter de la date de délivrance.</p></div></div>",
