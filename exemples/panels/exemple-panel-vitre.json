    {
      "label": "Styles CSS",
      "tag": "style",
      "content": "/* Carte principale - Sticky */\n.sfc-card {\n  position: sticky;\n  top: 20px;\n  background: #fff;\n  border: 1px solid #e5e7eb;\n  border-radius: 12px;\n  padding: 24px;\n  font-family: 'Segoe UI', Roboto, sans-serif;\n  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);\n}\n.sfc-card h3 {\n  font-size: 18px;\n  font-weight: 700;\n  color: #111827;\n  margin: 0 0 4px;\n}\n.sfc-card .sfc-subtitle {\n  font-size: 13.5px;\n  color: #4b5563;\n  margin: 0 0 18px;\n  line-height: 1.5;\n}\n.sfc-row {\n  display: flex;\n  align-items: flex-start;\n  gap: 10px;\n  margin-bottom: 12px;\n  font-size: 13.5px;\n  color: #374151;\n  line-height: 1.5;\n}\n.sfc-row .sfc-ico {\n  flex-shrink: 0;\n  width: 20px;\n  text-align: center;\n  font-size: 15px;\n  margin-top: 1px;\n  color: #4b5563;\n}\n.sfc-row a {\n  color: #3b82f6;\n  text-decoration: none;\n}\n.sfc-row a:hover {\n  text-decoration: underline;\n}\n.sfc-row strong {\n  color: #111827;\n  font-weight: 600;\n}\n.sfc-stitle {\n  font-size: 16px;\n  font-weight: 700;\n  color: #111827;\n  margin: 20px 0 12px;\n  padding-top: 16px;\n  border-top: 1px solid #e5e7eb;\n}\n.sfc-boxes {\n  display: flex;\n  gap: 10px;\n  margin-bottom: 14px;\n  width: 100%;\n}\n.sfc-box {\n  flex: 1;\n  background: #f9fafb;\n  border: 1px solid #e5e7eb;\n  border-radius: 8px;\n  padding: 12px;\n}\n.sfc-box .sfc-lbl {\n  font-size: 11.5px;\n  color: #6b7280;\n  font-weight: 500;\n  margin: 0 0 6px;\n  line-height: 1.3;\n}\n.sfc-box .sfc-val {\n  font-size: 14px;\n  font-weight: 700;\n  color: #111827;\n  margin: 0;\n}\n.sfc-box .sfc-sub {\n  font-size: 11px;\n  color: #9ca3af;\n  font-weight: 400;\n}\n.sfc-link {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  color: #16a34a;\n  font-size: 13px;\n  font-weight: 600;\n  text-decoration: none;\n  cursor: pointer;\n  margin-top: 5px;\n}\n.sfc-link:hover {\n  text-decoration: underline;\n}\n.sfc-link-ico {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 18px;\n  height: 18px;\n  background: #16a34a;\n  color: #fff;\n  border-radius: 50%;\n  font-size: 11px;\n  font-weight: 700;\n}",
