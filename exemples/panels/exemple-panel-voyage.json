      "content": ".info-card\n{display:flex;\nflex-direction:column;\nalign-items:center;justify-content:flex-start;\nbackground:#FFFFFF;\nborder:1px solid #E5E7EB;border-radius:16px;padding:40px 30px 30px 30px;width:100%;  \nwidth: 400px;\n  max-height: 460px;\n  cursor:pointer;transition:all 0.25s ease;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.04);margin:0 auto;box-sizing:border-box;position:relative;padding-bottom:90px}.info-card:hover{border-color:#006A4F;box-shadow:0 4px 16px rgba(0,106,79,0.12);transform:translateY(-2px)}\n  .info-card-title{font-size:22px;font-weight:600;color:#1E2939;margin:0 0 30px 0;font-family:'Poppins',sans-serif;text-align:center}\n  .info-card-img{margin-bottom:30px;display:flex;align-items:center;justify-content:center;min-height:150px}.info-card-img img{max-width:180px;height:auto}\n  .info-card-description{font-size:14px;color:#6B7280;line-height:1.7;font-family:'Poppins',sans-serif;max-width:350px;text-align:center;margin:0 0 20px 0;flex-grow:1}.btn-card-action .btn{background-color:#006A4F!important;border-radius:8px!important;border:none!important;color:#fff!important;display:block;margin:20px auto 0 auto;position:relative;z-index:2;max-width:220px;padding:14px 32px!important;font-size:15px!important;font-weight:600!important;font-family:'Poppins',sans-serif!important;cursor:pointer;transition:background 0.2s ease}.btn-card-action .btn:hover{background-color:#005540!important}\n  @media(max-width:992px){.info-card{max-width:100%;padding:30px 25px 80px 25px;min-height:380px}.info-card-img img{max-width:150px}.info-card-title{font-size:20px;margin-bottom:25px}.info-card-img{margin-bottom:25px;min-height:130px}.info-card-description{font-size:13px}.btn-card-action .btn{margin:15px auto 0 auto;padding:12px 28px!important;font-size:14px!important}}\n  @media(max-width:576px){\n  .info-card{padding:25px 20px 75px 20px;\n  min-height:360px;\n  margin-top: 20px}\n  .info-card-img img{max-width:130px}\n  .btn-card-action \n  .btn{\n  max-width:200px;padding:12px 24px!important;margin:15px auto 0 auto;}}",
