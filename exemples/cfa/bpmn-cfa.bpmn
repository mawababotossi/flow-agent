<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DiolomeCFA" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.17.0">
  <bpmn:message id="MSG_DIPLOMECFA_START" name="MSG_DIPLOMECFA_START" />
  <bpmn:message id="MSG_DIPLOMECFA_PAY_REQ" name="MSG_DIPLOMECFA_PAY_REQ" />
  <bpmn:message id="MSG_DIPLOMECFA_PAY_CALLBACK" name="MSG_DIPLOMECFA_PAY_CALLBACK" />
  <bpmn:message id="MSG_DIPLOMECFA_PAY_CONFIRM" name="MSG_DIPLOMECFA_PAY_CONFIRM" />
  <bpmn:message id="MSG_DIPLOMECFA_DECISION" name="MSG_DIPLOMECFA_DECISION" />
  <bpmn:message id="MSG_DIPLOMECFA_RESUB" name="MSG_DIPLOMECFA_RESUB" />
  <bpmn:collaboration id="Collaboration_DiolomeCFA">
    <bpmn:participant id="Participant_Portal" name="XPORTAL" processRef="Process_Portal_DiolomeCFA" />
    <bpmn:participant id="Participant_Xflow" name="XFLOW" processRef="Process_Xflow_DiolomeCFA" />
    <bpmn:messageFlow id="MF01" sourceRef="Activity_P_SendStart" targetRef="Event_X_Start" />
    <bpmn:messageFlow id="MF02" sourceRef="Activity_X_SendPayReq" targetRef="Activity_P_RecvPayReq" />
    <bpmn:messageFlow id="MF03" sourceRef="Activity_X_SendPayConfirm" targetRef="Activity_P_RecvPayConfirm" />
    <bpmn:messageFlow id="MF04" sourceRef="Activity_X_SendDecisionAccepte" targetRef="Activity_P_RecvDecision" />
    <bpmn:messageFlow id="MF05" sourceRef="Activity_X_SendDecisionCorr" targetRef="Activity_P_RecvDecision" />
    <bpmn:messageFlow id="MF06" sourceRef="Activity_X_SendDecisionRejet" targetRef="Activity_P_RecvDecision" />
    <bpmn:messageFlow id="MF07" sourceRef="Activity_P_SendResub" targetRef="Activity_X_RecvResub" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Portal_DiolomeCFA" isExecutable="true" camunda:versionTag="1">
    <bpmn:startEvent id="Event_P_Start" name="Soumission demande diplôme CFA" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:formKey="01KM34YGJPH4M7GWNP4D8M76XV" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>SF_P_Start_SendStart</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sendTask id="Activity_P_SendStart" name="Envoi au back-office" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_START</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Event_P_Start.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Start_SendStart</bpmn:incoming>
      <bpmn:outgoing>SF_P_SendStart_GwDup</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_P_Dup" name="Duplicata ?">
      <bpmn:incoming>SF_P_SendStart_GwDup</bpmn:incoming>
      <bpmn:outgoing>SF_P_GwDup_RecvPayReq</bpmn:outgoing>
      <bpmn:outgoing>SF_P_GwDup_RecvDecision</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:receiveTask id="Activity_P_RecvPayReq" name="Réception demande paiement" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_DIPLOMECFA_PAY_REQ" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_GwDup_RecvPayReq</bpmn:incoming>
      <bpmn:outgoing>SF_P_RecvPayReq_Pay</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:userTask id="Activity_P_Pay" name="Effectuer le paiement (Z-Pay)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:formKey="01KMDS83GSATPVEJ4TVR6TTP8F" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdFormSetting"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostTotal"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostUnitaire"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">tarification</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_RecvPayReq_Pay</bpmn:incoming>
      <bpmn:outgoing>SF_P_Pay_RecvPayConfirm</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:receiveTask id="Activity_P_RecvPayConfirm" name="Confirmation paiement reçue" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_DIPLOMECFA_PAY_CONFIRM" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Pay_RecvPayConfirm</bpmn:incoming>
      <bpmn:outgoing>SF_P_RecvPayConfirm_RecvDecision</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:receiveTask id="Activity_P_RecvDecision" name="Attente décision DECC" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_DIPLOMECFA_DECISION" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_GwDup_RecvDecision</bpmn:incoming>
      <bpmn:incoming>SF_P_RecvPayConfirm_RecvDecision</bpmn:incoming>
      <bpmn:incoming>SF_P_SendResub_RecvDecision</bpmn:incoming>
      <bpmn:outgoing>SF_P_RecvDecision_GwDecision</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="Gateway_P_Decision" name="Action requise ?">
      <bpmn:incoming>SF_P_RecvDecision_GwDecision</bpmn:incoming>
      <bpmn:outgoing>SF_P_GwDecision_Corrections</bpmn:outgoing>
      <bpmn:outgoing>SF_P_GwDecision_EndDiplome</bpmn:outgoing>
      <bpmn:outgoing>SF_P_GwDecision_EndRejet</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_P_Corrections" name="Faire les corrections" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:formKey="01KMFH6RY20V6NRWGB3AP46JWJ" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdFormSetting"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostTotal"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostUnitaire"></camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_GwDecision_Corrections</bpmn:incoming>
      <bpmn:outgoing>SF_P_Corrections_SendResub</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BoundaryTimer_P_Corrections" name="Délai 15 jours" cancelActivity="false" attachedToRef="Activity_P_Corrections">
      <bpmn:outgoing>SF_P_BoundaryTimer_EndRejet</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_P_Corrections">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sendTask id="Activity_P_SendResub" name="Envoyer la resoumission" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_RESUB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Activity_P_Corrections.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Corrections_SendResub</bpmn:incoming>
      <bpmn:outgoing>SF_P_SendResub_RecvDecision</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_P_EndDiplome" name="Diplôme disponible">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_GwDecision_EndDiplome</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_P_EndRejet" name="Demande rejetée">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_GwDecision_EndRejet</bpmn:incoming>
      <bpmn:incoming>SF_P_BoundaryTimer_EndRejet</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_P_Start_SendStart" sourceRef="Event_P_Start" targetRef="Activity_P_SendStart" />
    <bpmn:sequenceFlow id="SF_P_SendStart_GwDup" sourceRef="Activity_P_SendStart" targetRef="Gateway_P_Dup" />
    <bpmn:sequenceFlow id="SF_P_GwDup_RecvPayReq" name="Duplicata" sourceRef="Gateway_P_Dup" targetRef="Activity_P_RecvPayReq">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Event_P_Start.parameters.submissionData.data.typeDemande == 'Duplicata'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_GwDup_RecvDecision" name="Original" sourceRef="Gateway_P_Dup" targetRef="Activity_P_RecvDecision">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Event_P_Start.parameters.submissionData.data.typeDemande == 'Original'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_RecvPayReq_Pay" sourceRef="Activity_P_RecvPayReq" targetRef="Activity_P_Pay" />
    <bpmn:sequenceFlow id="SF_P_Pay_RecvPayConfirm" sourceRef="Activity_P_Pay" targetRef="Activity_P_RecvPayConfirm" />
    <bpmn:sequenceFlow id="SF_P_RecvPayConfirm_RecvDecision" sourceRef="Activity_P_RecvPayConfirm" targetRef="Activity_P_RecvDecision" />
    <bpmn:sequenceFlow id="SF_P_RecvDecision_GwDecision" sourceRef="Activity_P_RecvDecision" targetRef="Gateway_P_Decision" />
    <bpmn:sequenceFlow id="SF_P_GwDecision_Corrections" name="Correction" sourceRef="Gateway_P_Decision" targetRef="Activity_P_Corrections">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_P_RecvDecision.parameters.submissionData.data.action == 'correction'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_GwDecision_EndDiplome" name="Accepté" sourceRef="Gateway_P_Decision" targetRef="Event_P_EndDiplome">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_P_RecvDecision.parameters.submissionData.data.action == 'accepte'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_GwDecision_EndRejet" name="Rejeté" sourceRef="Gateway_P_Decision" targetRef="Event_P_EndRejet">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_P_RecvDecision.parameters.submissionData.data.action == 'rejete'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Corrections_SendResub" sourceRef="Activity_P_Corrections" targetRef="Activity_P_SendResub" />
    <bpmn:sequenceFlow id="SF_P_SendResub_RecvDecision" sourceRef="Activity_P_SendResub" targetRef="Activity_P_RecvDecision" />
    <bpmn:sequenceFlow id="SF_P_BoundaryTimer_EndRejet" sourceRef="BoundaryTimer_P_Corrections" targetRef="Event_P_EndRejet" />
  </bpmn:process>
  <bpmn:process id="Process_Xflow_DiolomeCFA" isExecutable="true" camunda:versionTag="1.0" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="Event_X_Start" name="Réception demande diplôme CFA" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="development">{"ODOO": {"BASEURL": "https://decc-odoo.sandbox.gouv.tg","PORT": "83","DB": "@{cfa}","SECRET_USERNAME": "{dbkms:CFA_ODOO_USERNAME}","SECRET_PASSWORD": "{dbkms:CFA_ODOO_PASSWORD}"}, "ECERT": {"SECRET_USERNAME": "{dbkms:ECERT_USER}", "SECRET_PASSWORD": "{dbkms:ECERT_PASS}"}, "PORTAL": {"BASE_URL": "https://portail.sandbox.gouv.tg"}}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{"ODOO": {"BASEURL": "https://decc-odoo.sandbox.gouv.tg","PORT": "83","DB": "@{cfa}","SECRET_USERNAME": "{dbkms:CFA_ODOO_USERNAME}","SECRET_PASSWORD": "{dbkms:CFA_ODOO_PASSWORD}"}, "ECERT": {"SECRET_USERNAME": "{dbkms:ECERT_USER}", "SECRET_PASSWORD": "{dbkms:ECERT_PASS}"}, "PORTAL": {"BASE_URL": "https://portail.sandbox.gouv.tg"}}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{"ODOO": {"BASEURL": "https://decc-odoo.preprod.gouv.tg","PORT": "83","DB": "@{cfa}","SECRET_USERNAME": "{dbkms:CFA_ODOO_USERNAME}","SECRET_PASSWORD": "{dbkms:CFA_ODOO_PASSWORD}"}, "ECERT": {"SECRET_USERNAME": "{dbkms:ECERT_USER}", "SECRET_PASSWORD": "{dbkms:ECERT_PASS}"}, "PORTAL": {"BASE_URL": "https://portail.preprod.gouv.tg"}}</camunda:inputParameter>
          <camunda:inputParameter name="production">{"ODOO": {"BASEURL": "https://decc-odoo.gouv.tg","PORT": "83","DB": "@{cfa}","SECRET_USERNAME": "{dbkms:CFA_ODOO_USERNAME}","SECRET_PASSWORD": "{dbkms:CFA_ODOO_PASSWORD}"}, "ECERT": {"SECRET_USERNAME": "{dbkms:ECERT_USER}", "SECRET_PASSWORD": "{dbkms:ECERT_PASS}"}, "PORTAL": {"BASE_URL": "https://portail.gouv.tg"}}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>SF_X_Start_StepNotifSubmitted</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_X_StepNotifSubmitted" name="Mettre à jour étape" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Submited</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Demande soumise</camunda:inputParameter>
          <camunda:inputParameter name="gnspdLabel">Soumission</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Start_StepNotifSubmitted</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepNotifSubmitted_NotifAR</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_NotifAR" name="Notifier accusé de réception (N01)" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.Event_X_Start.parameters.submissionData.data.eMail</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.Event_X_Start.parameters.submissionData.data.numeroTelephone</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepNotifSubmitted_NotifAR</bpmn:incoming>
      <bpmn:outgoing>SF_X_NotifAR_GwDup</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_X_Dup" name="Duplicata ?">
      <bpmn:incoming>SF_X_NotifAR_GwDup</bpmn:incoming>
      <bpmn:outgoing>SF_X_GwDup_SendPayReq</bpmn:outgoing>
      <bpmn:outgoing>SF_X_GwDup_OdooSearch</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Activity_X_SendPayReq" name="Demander le paiement" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_PAY_REQ</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GwDup_SendPayReq</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendPayReq_PayCallback</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Activity_X_SendPayConfirm" name="Confirmer le paiement" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_PAY_CONFIRM</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GwPayOK_SendPayConfirm</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendPayConfirm_OdooSearch</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Activity_X_OdooSearch" name="Vérification candidat Odoo" camunda:modelerTemplate="tg.gouv.gnspd.odoo" camunda:type="external" camunda:topic="flow-odoo">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMethod">search_read</camunda:inputParameter>
          <camunda:inputParameter name="gnspdModel">exam.inscription</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDb">$this.data.Event_X_Start.parameters.configuration.ODOO.DB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdUrl">$this.data.Event_X_Start.parameters.configuration.ODOO.BASEURL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPort">$this.data.Event_X_Start.parameters.configuration.ODOO.PORT</camunda:inputParameter>
          <camunda:inputParameter name="gnspdUsername">$this.data.Event_X_Start.parameters.configuration.ODOO.SECRET_USERNAME</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassword">$this.data.Event_X_Start.parameters.configuration.ODOO.SECRET_PASSWORD</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendPayConfirm_OdooSearch</bpmn:incoming>
      <bpmn:incoming>SF_X_GwDup_OdooSearch</bpmn:incoming>
      <bpmn:incoming>SF_X_RecvResub_OdooSearch</bpmn:incoming>
      <bpmn:outgoing>SF_X_OdooSearch_GwOdooOK</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_X_OdooOK" name="Inscrit et reçu ?">
      <bpmn:incoming>SF_X_OdooSearch_GwOdooOK</bpmn:incoming>
      <bpmn:outgoing>SF_X_GwOdooOK_Agent</bpmn:outgoing>
      <bpmn:outgoing>SF_X_GwOdooOK_NotifReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_X_Agent" name="Instruction du dossier" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:formKey="01KMFHAG65QMY66B428QQF3AFC" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdFormSetting"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostTotal"></camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostUnitaire"></camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GwOdooOK_Agent</bpmn:incoming>
      <bpmn:outgoing>SF_X_Agent_GwDecision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="BoundaryTimer_X_Agent" name="SLA 72h" cancelActivity="false" attachedToRef="Activity_X_Agent">
      <bpmn:outgoing>SF_X_BoundaryTimer_Agent_NotifEscalade</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_X_Agent">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT72H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Activity_X_NotifEscalade" name="Escalade SLA (N07/N08)" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_BoundaryTimer_Agent_NotifEscalade</bpmn:incoming>
      <bpmn:outgoing>SF_X_NotifEscalade_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_X_EndEscalade" name="Fin escalade SLA">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_NotifEscalade_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_X_Decision" name="Décision agent ?">
      <bpmn:incoming>SF_X_Agent_GwDecision</bpmn:incoming>
      <bpmn:outgoing>SF_X_GwDecision_StepNotifProcessing</bpmn:outgoing>
      <bpmn:outgoing>SF_X_GwDecision_NotifCorr</bpmn:outgoing>
      <bpmn:outgoing>SF_X_GwDecision_NotifReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_X_StepNotifProcessing" name="Mettre à jour étape (Processing)" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">PendingBackOffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">En cours de traitement</camunda:inputParameter>
          <camunda:inputParameter name="gnspdLabel">Traitement</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GwDecision_StepNotifProcessing</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepNotifProcessing_GenerateDoc</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_GenerateDoc" name="Générer le diplôme" camunda:type="external" camunda:topic="flow-generate-template">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTemplate">TEMPLATE_DIPLOME_CFA</camunda:inputParameter>
          <camunda:inputParameter name="gnspdGeneratedName">diplome-cfa-${this.data.xref}.pdf</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTempData">${
  "nom": this.data.Event_X_Start.parameters.submissionData.data.nom,
  "prenom": this.data.Event_X_Start.parameters.submissionData.data.prenom,
  "reference": this.data.xref
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPrintOptions">{'format':'A4'}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdGroups" />
          <camunda:inputParameter name="gnspdRoles" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepNotifProcessing_GenerateDoc</bpmn:incoming>
      <bpmn:outgoing>SF_X_GenerateDoc_GenQrcode</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_GenQrcode" name="Générer le QR code" camunda:modelerTemplate="tg.gouv.gnspd.generateUrlQrcode" camunda:type="external" camunda:topic="flow-generate-url-qrcode">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdUrl">$(this.data.Event_X_Start.parameters.configuration.PORTAL.BASE_URL + '/verify/' + this.data.xref)</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GenerateDoc_GenQrcode</bpmn:incoming>
      <bpmn:outgoing>SF_X_GenQrcode_ApplyQrcode</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_ApplyQrcode" name="Appliquer le QR code sur le PDF" camunda:modelerTemplate="tg.gouv.gnspd.pdfImage" camunda:type="external" camunda:topic="flow-pdf-image">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdPdfFile">$this.data.Activity_X_GenerateDoc.result</camunda:inputParameter>
          <camunda:inputParameter name="gnspdClickedX">450</camunda:inputParameter>
          <camunda:inputParameter name="gnspdClickedY">680</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCurrentPage">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdFile">$this.data.Activity_X_GenerateDoc.result</camunda:inputParameter>
          <camunda:inputParameter name="gnspdImage">$this.data.Activity_X_GenQrcode.result</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GenQrcode_ApplyQrcode</bpmn:incoming>
      <bpmn:outgoing>SF_X_ApplyQrcode_CertSign</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_CertSign" name="Signer le diplôme (certSign)" camunda:modelerTemplate="tg.gouv.gnspd.certSign" camunda:type="external" camunda:topic="flow-cert-sign">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdId">$this.data.Event_X_Start.parameters.configuration.ECERT.SECRET_USERNAME</camunda:inputParameter>
          <camunda:inputParameter name="gnspdKey">$this.data.Event_X_Start.parameters.configuration.ECERT.SECRET_PASSWORD</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsFormat">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdData">${
  "nom": this.data.Event_X_Start.parameters.submissionData.data.nom,
  "prenom": this.data.Event_X_Start.parameters.submissionData.data.prenom,
  "reference": this.data.xref,
  "dateDelivrance": new Date().toISOString()
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdUseNewMethod">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDefaultValue" />
          <camunda:inputParameter name="gnspdIgnoreList" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_ApplyQrcode_CertSign</bpmn:incoming>
      <bpmn:outgoing>SF_X_CertSign_OdooCreate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_OdooCreate" name="Créer la demande dans Odoo (exam.demande)" camunda:modelerTemplate="tg.gouv.gnspd.odoo" camunda:type="external" camunda:topic="flow-odoo">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMethod">create</camunda:inputParameter>
          <camunda:inputParameter name="gnspdModel">exam.demande</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDb">$this.data.Event_X_Start.parameters.configuration.ODOO.DB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdUrl">$this.data.Event_X_Start.parameters.configuration.ODOO.BASEURL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPort">$this.data.Event_X_Start.parameters.configuration.ODOO.PORT</camunda:inputParameter>
          <camunda:inputParameter name="gnspdUsername">$this.data.Event_X_Start.parameters.configuration.ODOO.SECRET_USERNAME</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassword">$this.data.Event_X_Start.parameters.configuration.ODOO.SECRET_PASSWORD</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_CertSign_OdooCreate</bpmn:incoming>
      <bpmn:outgoing>SF_X_OdooCreate_StepNotifCompleted</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_StepNotifCompleted" name="Mettre à jour étape (Completed)" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Success</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Diplôme délivré</camunda:inputParameter>
          <camunda:inputParameter name="gnspdLabel">Terminé</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_OdooCreate_StepNotifCompleted</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepNotifCompleted_NotifDiplome</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_X_NotifDiplome" name="Notifier diplôme disponible (N05)" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepNotifCompleted_NotifDiplome</bpmn:incoming>
      <bpmn:outgoing>SF_X_NotifDiplome_SendDecisionAccepte</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_X_SendDecisionAccepte" name="Envoyer décision acceptée" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_DECISION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">{"action": "accepte"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_NotifDiplome_SendDecisionAccepte</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendDecisionAccepte_EndSuccess</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_X_EndSuccess" name="Fin — Diplôme délivré">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendDecisionAccepte_EndSuccess</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_X_NotifCorr" name="Notifier corrections demandées (N04)" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GwDecision_NotifCorr</bpmn:incoming>
      <bpmn:outgoing>SF_X_NotifCorr_SendDecisionCorr</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_X_SendDecisionCorr" name="Envoyer décision correction" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_DECISION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">{"action": "correction"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_NotifCorr_SendDecisionCorr</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendDecisionCorr_RecvResub</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Activity_X_RecvResub" name="Réception resoumission" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_DIPLOMECFA_RESUB" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendDecisionCorr_RecvResub</bpmn:incoming>
      <bpmn:outgoing>SF_X_RecvResub_OdooSearch</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="BoundaryTimer_X_RecvResub" name="Délai 15 jours" cancelActivity="false" attachedToRef="Activity_X_RecvResub">
      <bpmn:outgoing>SF_X_BoundaryTimer_RecvResub_NotifReject</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_X_RecvResub">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Activity_X_NotifReject" name="Notifier rejet (N06)" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_GwPayOK_NotifReject</bpmn:incoming>
      <bpmn:incoming>SF_X_GwOdooOK_NotifReject</bpmn:incoming>
      <bpmn:incoming>SF_X_GwDecision_NotifReject</bpmn:incoming>
      <bpmn:incoming>SF_X_BoundaryTimer_RecvResub_NotifReject</bpmn:incoming>
      <bpmn:outgoing>SF_X_NotifReject_SendDecisionRejet</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_X_SendDecisionRejet" name="Envoyer décision rejet" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_DIPLOMECFA_DECISION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">{"action": "rejete"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_NotifReject_SendDecisionRejet</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendDecisionRejet_EndRejet</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_X_EndRejet" name="Fin — Demande rejetée">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendDecisionRejet_EndRejet</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_X_Start_StepNotifSubmitted" sourceRef="Event_X_Start" targetRef="Activity_X_StepNotifSubmitted" />
    <bpmn:sequenceFlow id="SF_X_StepNotifSubmitted_NotifAR" sourceRef="Activity_X_StepNotifSubmitted" targetRef="Activity_X_NotifAR" />
    <bpmn:sequenceFlow id="SF_X_NotifAR_GwDup" sourceRef="Activity_X_NotifAR" targetRef="Gateway_X_Dup" />
    <bpmn:sequenceFlow id="SF_X_GwDup_SendPayReq" name="Duplicata" sourceRef="Gateway_X_Dup" targetRef="Activity_X_SendPayReq">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Event_X_Start.parameters.submissionData.data.typeDemande == 'Duplicata'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_GwDup_OdooSearch" name="Original" sourceRef="Gateway_X_Dup" targetRef="Activity_X_OdooSearch">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Event_X_Start.parameters.submissionData.data.typeDemande == 'Original'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_SendPayReq_PayCallback" sourceRef="Activity_X_SendPayReq" targetRef="Event_X_PayCallback" />
    <bpmn:sequenceFlow id="SF_X_PayCallback_GwPayOK" sourceRef="Event_X_PayCallback" targetRef="Gateway_X_PayOK" />
    <bpmn:sequenceFlow id="SF_X_GwPayOK_SendPayConfirm" name="Oui" sourceRef="Gateway_X_PayOK" targetRef="Activity_X_SendPayConfirm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Event_X_PayCallback.parameters.submissionData.data.paiement == 'oui'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_GwPayOK_NotifReject" name="Non" sourceRef="Gateway_X_PayOK" targetRef="Activity_X_NotifReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Event_X_PayCallback.parameters.submissionData.data.paiement == 'non'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_SendPayConfirm_OdooSearch" sourceRef="Activity_X_SendPayConfirm" targetRef="Activity_X_OdooSearch" />
    <bpmn:sequenceFlow id="SF_X_OdooSearch_GwOdooOK" sourceRef="Activity_X_OdooSearch" targetRef="Gateway_X_OdooOK" />
    <bpmn:sequenceFlow id="SF_X_GwOdooOK_Agent" name="Oui" sourceRef="Gateway_X_OdooOK" targetRef="Activity_X_Agent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_OdooSearch.parameters.submissionData.data.inscription == 'oui'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_GwOdooOK_NotifReject" name="Non" sourceRef="Gateway_X_OdooOK" targetRef="Activity_X_NotifReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_OdooSearch.parameters.submissionData.data.inscription == 'non'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_BoundaryTimer_Agent_NotifEscalade" sourceRef="BoundaryTimer_X_Agent" targetRef="Activity_X_NotifEscalade" />
