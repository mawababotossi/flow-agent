  "components": [
    {
      "label": "Styles CSS",
      "tag": "style",
      "content": "/* ── Sidebar fournisseur (sticky) ── */\n.sfc-card {\n  position: sticky;\n  top: 20px;\n  background: #fff;\n  border: 1px solid #e5e7eb;\n  border-radius: 12px;\n  padding: 24px;\n  font-family: 'Segoe UI', Roboto, sans-serif;\n  box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);\n}\n.sfc-card h3 { font-size:18px;font-weight:700;color:#111827;margin:0 0 4px; }\n.sfc-card .sfc-subtitle { font-size:13.5px;color:#4b5563;margin:0 0 18px;line-height:1.5; }\n.sfc-row { display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;font-size:13.5px;color:#374151;line-height:1.5; }\n.sfc-row .sfc-ico { flex-shrink:0;width:20px;text-align:center;font-size:15px;margin-top:1px;color:#4b5563; }\n.sfc-row a { color:#3b82f6;text-decoration:none; }\n.sfc-row a:hover { text-decoration:underline; }\n.sfc-row strong { color:#111827;font-weight:600; }\n.sfc-stitle { font-size:16px;font-weight:700;color:#111827;margin:20px 0 12px;padding-top:16px;border-top:1px solid #e5e7eb; }\n.sfc-boxes { display:flex;gap:10px;margin-bottom:14px;width:100%; }\n.sfc-box { flex:1;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:12px; }\n.sfc-box .sfc-lbl { font-size:11.5px;color:#6b7280;font-weight:500;margin:0 0 6px;line-height:1.3; }\n.sfc-box .sfc-val { font-size:14px;font-weight:700;color:#111827;margin:0; }\n.sfc-box .sfc-sub { font-size:11px;color:#9ca3af;font-weight:400; }\n.sfc-link { display:inline-flex;align-items:center;gap:6px;color:#16a34a;font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;margin-top:5px; }\n.sfc-link:hover { text-decoration:underline; }\n.sfc-link-ico { display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;background:#16a34a;color:#fff;border-radius:50%;font-size:11px;font-weight:700; }\n",
      "key": "stylesCssSidebar",
      "type": "htmlelement"
    },
    {
      "tag": "div",
      "key": "stickyInjector",
      "type": "htmlelement",
      "customClass": "d-none",
      "calculateValue": "if(typeof window.__sfcStickyDone === 'undefined'){window.__sfcStickyDone=false;}function sfcApply(){var el=document.getElementById('sidebar-fournisseur');if(!el)return false;var col=el.closest('[class*=\"col-\"]');if(col){col.style.position='sticky';col.style.top='20px';col.style.alignSelf='flex-start';}var row=el.closest('.row');if(row){row.style.alignItems='flex-start';row.style.display='flex';}return true;}if(!window.__sfcStickyDone){if(sfcApply()){window.__sfcStickyDone=true;}else{setTimeout(function(){sfcApply();window.__sfcStickyDone=true;},500);setTimeout(function(){sfcApply();},1500);}}"
    },
    {
      "label": "Columns",
      "columns": [
        {
          "components": [
            {
              "tag": "h2",
              "content": "[Intitulé officiel du service]",
              "key": "titre",
              "type": "htmlelement"
            },
            {
              "tag": "div",
              "content": "<div style=\"display:flex;gap:20px;flex-wrap:wrap;margin-top:20px;\"><div style=\"flex:1;min-width:220px;background:#fff;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">⏱️</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Délai d'exécution</h3><p style=\"font-size:15px;color:#333;margin:0;\">[Délai]</p></div>\n<div style=\"flex:1;min-width:220px;background:#f9fafb;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">💰</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Coût</h3><p style=\"font-size:15px;color:#333;margin:0;\">[Coût]</p></div>\n<div style=\"flex:1;min-width:220px;background:#f9fafb;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">📅</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Validité</h3><p style=\"font-size:15px;color:#333;margin:0;\">[Durée]</p></div></div>",
              "key": "infoPills",
              "type": "htmlelement"
            },
            {
              "tag": "div",
              "content": "<div style=\"font-size:22px;font-weight:700;margin:30px 0 10px;color:#000;\">Description</div><div style=\"font-size:16px;line-height:1.6;color:#333;margin-bottom:30px;\">[Texte description]</div>\n<div style=\"font-size:22px;font-weight:700;margin-bottom:10px;color:#000;\">Personnes légitimes</div><div style=\"font-size:16px;line-height:1.6;color:#333;margin-bottom:30px;\">[Profils]</div>",
              "key": "descriptionService",
              "type": "htmlelement"
            },
            {
              "tag": "div",
              "content": "<div style=\"background:#F8F8F8;border:1px solid #E5E5E5;border-radius:12px;padding:25px;margin-bottom:25px;\"><div style=\"font-size:20px;font-weight:700;margin-bottom:15px;color:#000;\">Conditions d'éligibilité</div><ul style=\"font-size:16px;color:#333;line-height:1.7;padding-left:20px;margin:0;\"><li>[Condition 1]</li></ul></div>",
              "key": "conditionsEligibilite",
              "type": "htmlelement"
            },
            {
              "tag": "div",
              "content": "<div style=\"background:#F8F8F8;border:1px solid #E5E5E5;border-radius:12px;padding:25px;margin-bottom:25px;\"><div style=\"font-size:20px;font-weight:700;margin-bottom:15px;color:#000;\">Pièces à fournir</div><ul style=\"font-size:16px;color:#333;line-height:1.7;padding-left:20px;margin:0;\"><li>[Pièce 1]</li></ul></div>",
              "key": "piecesAFournir",
              "type": "htmlelement"
            },
            {
              "tag": "div",
              "content": "<div style=\"font-size:22px;font-weight:700;margin-bottom:20px;color:#000;\">Étapes</div><div style=\"display:flex;align-items:flex-start;margin-bottom:15px;\"><div style=\"width:28px;height:28px;min-width:28px;background:#1BAE4A;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px;font-size:16px;\">1</div><div style=\"font-size:16px;line-height:1.6;color:#333;\">[Étape 1]</div></div>",
              "key": "etapesProcessus",
              "type": "htmlelement"
            }
          ],
          "width": 8
        },
        {
          "components": [
            {
              "tag": "div",
              "content": "<div class=\"sfc-card\" id=\"sidebar-fournisseur\"><h3>Fournisseur de service</h3><p class=\"sfc-subtitle\">[Nom Ministère / Direction]</p>\n<div class=\"sfc-row\"><span class=\"sfc-ico\">📞</span><span><strong>Téléphone :</strong> (+228) 00 00 00 00</span></div>\n<div class=\"sfc-row\"><span class=\"sfc-ico\">✉️</span><span><strong>Email :</strong> contact@gouv.tg</span></div>\n<div class=\"sfc-row\"><span class=\"sfc-ico\">📍</span><span><strong>Adresse :</strong> [Adresse complète], Lomé, Togo</span></div>\n<div class=\"sfc-row\"><span class=\"sfc-ico\">🌐</span><span><strong>Site web :</strong> <a href=\"#\" target=\"_blank\">www.service-public.gouv.tg</a></span></div>\n<div class=\"sfc-row\"><span class=\"sfc-ico\">🕐</span><span><strong>Ouverture :</strong> Lun – Ven, 07h30 – 17h30</span></div>\n<h3 class=\"sfc-stitle\">Statistiques</h3>\n<div class=\"sfc-boxes\">\n<div class=\"sfc-box\"><p class=\"sfc-lbl\">Délai moyen de traitement</p><p class=\"sfc-val\">-- <span style=\"font-size:12px;font-weight:normal;\">Jours</span></p><p class=\"sfc-sub\">Base: 6 derniers mois</p></div>\n<div class=\"sfc-box\"><p class=\"sfc-lbl\">Demandes traitées aujourd'hui</p><p class=\"sfc-val\">--</p></div></div>\n<a href=\"#\" class=\"sfc-link\"><span class=\"sfc-link-ico\">➜</span> Voir les statistiques détaillées</a>\n</div>",
              "key": "sidebarFournisseur",
              "type": "htmlelement"
            }
          ],
          "width": 4
        }
      ],
      "key": "columnsIntro",
