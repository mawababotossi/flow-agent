<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <message id="Msg_DossierSoumis" name="Msg_DossierSoumis" />
  <message id="Msg_DossierResoumis" name="Msg_DossierResoumis" />
  <message id="Msg_PaiementEffectue" name="Msg_PaiementEffectue" />
  <message id="Msg_DecisionInstruction" name="Msg_DecisionInstruction" />
  <message id="Msg_AutorisationDispo" name="Msg_AutorisationDispo" />
  <collaboration id="Collab_InfraPetroliere">
    <participant id="Participant_Citizen" name="CITIZEN" processRef="Process_Citizen" />
    <participant id="Participant_Middleware" name="MIDDLEWARE" processRef="Process_Middleware" />
    <messageFlow id="MF_DossierSoumis" name="Dossier soumis" sourceRef="Activity_0j881lu" targetRef="CATCH_DOSSIER_SOUMIS" />
    <messageFlow id="MF_DossierResoumis" name="Dossier resoumis" sourceRef="THROW_DossierResoumis" targetRef="Activity_08aj04b" />
    <messageFlow id="MF_PaiementEffectue" name="Paiement effectué" sourceRef="Activity_1qr33v4" targetRef="Activity_1ccv5ed" />
    <messageFlow id="MF_DecisionInstruction" name="Décision instruction" sourceRef="Activity_0ud8pn0" targetRef="Activity_0rwsj8q" />
    <messageFlow id="MF_DecisionRejet" name="Décision rejet" sourceRef="THROW_DECISION_REJET" targetRef="CATCH_DECISION_CITIZEN" />
    <messageFlow id="MF_AutorisationDispo" name="Autorisation disponible" sourceRef="THROW_AUTORISATION" targetRef="CATCH_AUTORISATION_CITIZEN" />
    <messageFlow id="Flow_0nv3qqb" sourceRef="THROW_DECISION_PAIEMENT" targetRef="Activity_0rwsj8q" />
    <messageFlow id="Flow_0wbgto2" sourceRef="THROW_DECISION_REJET" targetRef="Activity_0rwsj8q" />
  </collaboration>
  <process id="Process_Citizen" name="Demande autorisation infrastructure pétrolière — Portail" isExecutable="true" camunda:historyTimeToLive="180">
    <userTask id="UT_CORRECTION" name="Correction du dossier" camunda:formKey="infra_petroliere_depot">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="3" />
          <camunda:property name="stepName" value="Correction dossier" />
          <camunda:property name="gnspdFormKey" value="infra_petroliere_depot" />
          <camunda:property name="isResubmission" value="true" />
          <camunda:property name="executionType" value="PORTAIL" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Corriger mon dossier" />
          <camunda:property name="gnspdTaskStatus" value="PendingPortal" />
          <camunda:property name="gnspdTaskOrder" value="3" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_C_XOR_Correction</incoming>
      <outgoing>SF_C_Correction_Throw</outgoing>
    </userTask>
    <intermediateThrowEvent id="THROW_DossierResoumis" name="Envoi dossier resoumis">
      <incoming>SF_C_Correction_Throw</incoming>
      <outgoing>SF_C_CorrectionLoop</outgoing>
      <messageEventDefinition id="MED_ThrowDossierResoumis" messageRef="Msg_DossierResoumis" />
    </intermediateThrowEvent>
    <userTask id="UT_ATTENTE_RETRAIT" name="Attente de disponibilité de l&#39;autorisation" camunda:formKey="infra_petroliere_attente_retrait">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="5" />
          <camunda:property name="stepName" value="Attente retrait autorisation" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Autorisation en cours de préparation" />
          <camunda:property name="gnspdTaskStatus" value="PendingCompletion" />
          <camunda:property name="gnspdTaskOrder" value="5" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_C_Paiement_Attente</incoming>
      <outgoing>SF_C_Attente_CatchAutorisation</outgoing>
    </userTask>
    <intermediateCatchEvent id="CATCH_AUTORISATION_CITIZEN" name="Autorisation disponible">
      <incoming>MF_AutorisationDispo</incoming>
      <outgoing>SF_C_CatchAutorisation_End</outgoing>
      <messageEventDefinition id="MED_CatchAutorisation" messageRef="Msg_AutorisationDispo" />
    </intermediateCatchEvent>
    <endEvent id="END_SUCCES" name="Autorisation obtenue — Succès">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Autorisation délivrée" />
          <camunda:property name="gnspdTaskStatus" value="Completed" />
          <camunda:property name="gnspdTaskOrder" value="99" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_C_CatchAutorisation_End</incoming>
    </endEvent>
    <endEvent id="END_REJET" name="Demande rejetée définitivement">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Demande rejetée" />
          <camunda:property name="gnspdTaskStatus" value="Rejected" />
          <camunda:property name="gnspdTaskOrder" value="98" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_C_XOR_Rejet</incoming>
      <terminateEventDefinition id="TED_Rejet" />
    </endEvent>
    <sequenceFlow id="SF_C_Start_Depot" sourceRef="START_PORTAIL" targetRef="Activity_0j881lu" />
    <sequenceFlow id="SF_C_CorrectionLoop" sourceRef="THROW_DossierResoumis" targetRef="GW_C_JoinAttente" />
    <sequenceFlow id="SF_C_JoinAttente_Task" sourceRef="GW_C_JoinAttente" targetRef="UT_ATTENTE_INSTRUCTION" />
    <sequenceFlow id="SF_C_Attente_Catch" sourceRef="UT_ATTENTE_INSTRUCTION" targetRef="Activity_0rwsj8q" />
    <sequenceFlow id="SF_C_XOR_Correction" name="Correction requise" sourceRef="XOR_DECISION_CITIZEN" targetRef="UT_CORRECTION">
      <conditionExpression xsi:type="tFormalExpression">${decisionInstruction == 'CORRECTION'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="SF_C_XOR_Paiement" name="Paiement requis" sourceRef="XOR_DECISION_CITIZEN" targetRef="UT_PAIEMENT">
      <conditionExpression xsi:type="tFormalExpression">${decisionInstruction == 'APPROVED'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="SF_C_XOR_Rejet" name="Rejet définitif (défaut)" sourceRef="XOR_DECISION_CITIZEN" targetRef="END_REJET" />
    <sequenceFlow id="SF_C_Correction_Throw" sourceRef="UT_CORRECTION" targetRef="THROW_DossierResoumis" />
    <sequenceFlow id="SF_C_Paiement_Throw" sourceRef="UT_PAIEMENT" targetRef="Activity_1qr33v4" />
    <sequenceFlow id="SF_C_Paiement_Attente" sourceRef="Activity_1qr33v4" targetRef="UT_ATTENTE_RETRAIT" />
    <sequenceFlow id="SF_C_Attente_CatchAutorisation" sourceRef="UT_ATTENTE_RETRAIT" targetRef="CATCH_AUTORISATION_CITIZEN" />
    <sequenceFlow id="SF_C_CatchAutorisation_End" sourceRef="CATCH_AUTORISATION_CITIZEN" targetRef="END_SUCCES" />
    <sequenceFlow id="Flow_04u9w3u" sourceRef="Activity_0j881lu" targetRef="GW_C_JoinAttente" />
    <sendTask id="Activity_1qr33v4" name="Envoi confirmation paiement" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">Message_2qtcshb</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer_xflow</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">true</camunda:inputParameter>
        </camunda:inputOutput>
      </extensionElements>
      <incoming>SF_C_Paiement_Throw</incoming>
      <outgoing>SF_C_Paiement_Attente</outgoing>
    </sendTask>
    <startEvent id="START_PORTAIL" name="Soumission initiale — Portail" camunda:formKey="">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdStepName" value="Demande d&#39;autorisation infrastructure pétrolière" />
          <camunda:property name="gnspdExecution" value="PORTAIL" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Démarrer la demande" />
          <camunda:property name="gnspdTaskStatus" value="PendingPortal" />
          <camunda:property name="gnspdTaskOrder" value="1" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
          <camunda:property name="gnspdPaymentAmount" value="0" />
        </camunda:properties>
      </extensionElements>
      <outgoing>SF_C_Start_Depot</outgoing>
    </startEvent>
    <sendTask id="Activity_0j881lu" name="Envoi dossier soumis" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdMessageRef" />
          <camunda:inputParameter name="gnspdMessageDestination" />
          <camunda:inputParameter name="gnspdMessage" />
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter>
        </camunda:inputOutput>
      </extensionElements>
      <incoming>SF_C_Start_Depot</incoming>
      <outgoing>Flow_04u9w3u</outgoing>
    </sendTask>
    <userTask id="UT_ATTENTE_INSTRUCTION" name="Attente de la décision d&#39;instruction" camunda:formKey="infra_petroliere_attente">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="2" />
          <camunda:property name="stepName" value="Attente instruction" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Dossier en cours d&#39;instruction" />
          <camunda:property name="gnspdTaskStatus" value="PendingBackOffice" />
          <camunda:property name="gnspdTaskOrder" value="2" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_C_JoinAttente_Task</incoming>
      <outgoing>SF_C_Attente_Catch</outgoing>
    </userTask>
    <exclusiveGateway id="GW_C_JoinAttente" name="Attente instruction">
      <incoming>SF_C_CorrectionLoop</incoming>
      <incoming>Flow_04u9w3u</incoming>
      <outgoing>SF_C_JoinAttente_Task</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_1cbvgxf" sourceRef="Activity_0rwsj8q" targetRef="XOR_DECISION_CITIZEN" />
    <receiveTask id="Activity_0rwsj8q" name="Décision reçue">
      <incoming>SF_C_Attente_Catch</incoming>
      <outgoing>Flow_1cbvgxf</outgoing>
    </receiveTask>
    <exclusiveGateway id="XOR_DECISION_CITIZEN" name="Décision reçue ?" default="SF_C_XOR_Rejet">
      <incoming>Flow_1cbvgxf</incoming>
      <outgoing>SF_C_XOR_Correction</outgoing>
      <outgoing>SF_C_XOR_Paiement</outgoing>
      <outgoing>SF_C_XOR_Rejet</outgoing>
    </exclusiveGateway>
    <userTask id="UT_PAIEMENT" name="Paiement de la redevance en ligne" camunda:formKey="infra_petroliere_paiement">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="4" />
          <camunda:property name="stepName" value="Paiement en ligne" />
          <camunda:property name="gnspdFormKey" value="infra_petroliere_paiement" />
          <camunda:property name="isResubmission" value="false" />
          <camunda:property name="executionType" value="PORTAIL" />
          <camunda:property name="gnspdHandlerType" value="tarification" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Payer la redevance" />
          <camunda:property name="gnspdTaskStatus" value="PendingPayment" />
          <camunda:property name="gnspdTaskOrder" value="4" />
          <camunda:property name="gnspdTaskKind" value="citizen" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_C_XOR_Paiement</incoming>
      <outgoing>SF_C_Paiement_Throw</outgoing>
    </userTask>
  </process>
  <process id="Process_Middleware" name="Traitement — Direction des Hydrocarbures" isExecutable="true" camunda:historyTimeToLive="180">
    <exclusiveGateway id="GW_MW_JoinConformite" name="Nouveau dossier / Resoumission">
      <incoming>SF_MW_CatchSoumis_Recap</incoming>
      <incoming>Flow_0du34ur</incoming>
      <outgoing>SF_MW_Join_Recap</outgoing>
    </exclusiveGateway>
    <serviceTask id="ST_GENERATION_RECAP" name="Génération du récapitulatif dossier" camunda:type="external" camunda:topic="flow-generate-template">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdTaskIsVisible" value="false" />
          <camunda:property name="gnspdTaskLabel" value="Génération récap" />
          <camunda:property name="gnspdTaskStatus" value="Pending" />
          <camunda:property name="gnspdTaskOrder" value="1" />
          <camunda:property name="gnspdTaskKind" value="system" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_MW_Join_Recap</incoming>
      <outgoing>SF_MW_Recap_SubAR</outgoing>
    </serviceTask>
    <serviceTask id="ST_ALERTE_ADMIN" name="Alerte admin — Email Direction des Hydrocarbures" camunda:type="external" camunda:topic="flow-notify">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdNotifySendEmail" value="true" />
          <camunda:property name="gnspdNotifyEmail" value="${ADMIN_DH_EMAIL}" />
          <camunda:property name="gnspdNotifyTemplateEmail" value="TPL_IP_ALERTE_ADMIN" />
          <camunda:property name="gnspdNotifyContentEmail" value="{&#34;reference&#34;:&#34;@RECORD_ID&#34;,&#34;demandeur&#34;:&#34;@E0_NOM_COMPLET&#34;,&#34;ficheJointe&#34;:true}" />
          <camunda:property name="gnspdTaskIsVisible" value="false" />
          <camunda:property name="gnspdTaskLabel" value="Alerte admin DH" />
          <camunda:property name="gnspdTaskStatus" value="Pending" />
          <camunda:property name="gnspdTaskOrder" value="2" />
          <camunda:property name="gnspdTaskKind" value="system" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_MW_SubAR_AlerteAdmin</incoming>
      <outgoing>SF_MW_Alerte_Conformite</outgoing>
    </serviceTask>
    <userTask id="UT_CONFORMITE" name="Étude de conformité du dossier" camunda:formKey="infra_petroliere_conformite">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="3" />
          <camunda:property name="stepName" value="Étude de conformité" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Étudier le dossier" />
          <camunda:property name="gnspdTaskStatus" value="Review" />
          <camunda:property name="gnspdTaskOrder" value="3" />
          <camunda:property name="gnspdTaskKind" value="backoffice" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_MW_Alerte_Conformite</incoming>
      <outgoing>SF_MW_Conformite_XOR</outgoing>
    </userTask>
    <userTask id="UT_TELECHARGEMENT" name="Téléchargement du dossier complet" camunda:formKey="infra_petroliere_telechargement">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="4" />
          <camunda:property name="stepName" value="Téléchargement dossier" />
          <camunda:property name="gnspdHandlerType" value="download_files" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Télécharger le dossier" />
          <camunda:property name="gnspdTaskStatus" value="PendingBackOffice" />
          <camunda:property name="gnspdTaskOrder" value="4" />
          <camunda:property name="gnspdTaskKind" value="backoffice" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_MW_XOR_Conforme</incoming>
      <outgoing>SF_MW_Telechargement_Decision</outgoing>
    </userTask>
    <userTask id="UT_DECISION_INSTRUCTION" name="Décision d&#39;instruction — Validation finale" camunda:formKey="infra_petroliere_decision">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdOrder" value="5" />
          <camunda:property name="stepName" value="Décision d&#39;instruction" />
          <camunda:property name="gnspdTaskIsVisible" value="true" />
          <camunda:property name="gnspdTaskLabel" value="Rendre la décision" />
          <camunda:property name="gnspdTaskStatus" value="PendingBackOffice" />
          <camunda:property name="gnspdTaskOrder" value="5" />
          <camunda:property name="gnspdTaskKind" value="backoffice" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_MW_Telechargement_Decision</incoming>
      <outgoing>SF_MW_Decision_XOR2</outgoing>
    </userTask>
    <exclusiveGateway id="XOR_DECISION_FINALE" name="Décision finale ?" default="SF_MW_XOR2_Rejet">
      <incoming>SF_MW_Decision_XOR2</incoming>
      <outgoing>SF_MW_XOR2_Rejet</outgoing>
      <outgoing>SF_MW_XOR2_Paiement</outgoing>
    </exclusiveGateway>
    <subProcess id="SP_NOTIF_REJET" name="Notification multicanal — Rejet définitif">
      <extensionElements>
        <camunda:properties>
          <camunda:property name="gnspdTaskIsVisible" value="false" />
          <camunda:property name="gnspdTaskKind" value="system" />
        </camunda:properties>
      </extensionElements>
      <incoming>SF_MW_XOR2_Rejet</incoming>
      <outgoing>SF_MW_SubRejet_Throw</outgoing>
      <startEvent id="SP_REJET_Start" />
      <parallelGateway id="AND_SPLIT_REJET" name="Diffusion rejet">
        <incoming>SF_REJET_Start_Split</incoming>
        <outgoing>SF_REJET_Email</outgoing>
        <outgoing>SF_REJET_SMS</outgoing>
        <outgoing>SF_REJET_Portail</outgoing>
      </parallelGateway>
      <serviceTask id="ST_REJET_EMAIL" name="Email — Rejet définitif" camunda:type="external" camunda:topic="flow-notify">
        <extensionElements>
          <camunda:properties>
            <camunda:property name="gnspdNotifySendEmail" value="true" />
            <camunda:property name="gnspdNotifyEmail" value="@USER_EMAIL" />
            <camunda:property name="gnspdNotifyTemplateEmail" value="TPL_IP_REJET_EMAIL" />
            <camunda:property name="gnspdNotifyContentEmail" value="{&#34;nom&#34;:&#34;@E0_NOM_COMPLET&#34;,&#34;reference&#34;:&#34;@RECORD_ID&#34;,&#34;motif&#34;:&#34;${motifRejet}&#34;}" />
            <camunda:property name="gnspdTaskIsVisible" value="false" />
            <camunda:property name="gnspdTaskKind" value="system" />
          </camunda:properties>
        </extensionElements>
        <incoming>SF_REJET_Email</incoming>
        <outgoing>SF_REJET_Email_Join</outgoing>
      </serviceTask>
      <serviceTask id="ST_REJET_SMS" name="SMS — Rejet définitif" camunda:type="external" camunda:topic="flow-notify">
        <extensionElements>
          <camunda:properties>
            <camunda:property name="gnspdNotifySendSMS" value="true" />
            <camunda:property name="gnspdNotifyPhone" value="@USER_PHONE" />
            <camunda:property name="gnspdNotifyTemplateSMS" value="TPL_IP_REJET_SMS" />
            <camunda:property name="gnspdNotifyContentSMS" value="{&#34;nom&#34;:&#34;@E0_NOM_COMPLET&#34;,&#34;reference&#34;:&#34;@RECORD_ID&#34;}" />
            <camunda:property name="gnspdTaskIsVisible" value="false" />
            <camunda:property name="gnspdTaskKind" value="system" />
          </camunda:properties>
        </extensionElements>
        <incoming>SF_REJET_SMS</incoming>
        <outgoing>SF_REJET_SMS_Join</outgoing>
      </serviceTask>
      <serviceTask id="ST_REJET_PORTAIL" name="Portail — Notification rejet" camunda:type="external" camunda:topic="flow-notify">
        <extensionElements>
          <camunda:properties>
            <camunda:property name="gnspdNotifyInApp" value="true" />
            <camunda:property name="gnspdNotifyTemplateInApp" value="TPL_IP_REJET_PORTAIL" />
            <camunda:property name="gnspdNotifyContentInApp" value="{&#34;message&#34;:&#34;Votre dossier @RECORD_ID a été rejeté.&#34;,&#34;statut&#34;:&#34;Rejeté&#34;}" />
            <camunda:property name="gnspdTaskIsVisible" value="false" />
            <camunda:property name="gnspdTaskKind" value="system" />
          </camunda:properties>
        </extensionElements>
        <incoming>SF_REJET_Portail</incoming>
        <outgoing>SF_REJET_Portail_Join</outgoing>
      </serviceTask>
      <parallelGateway id="AND_JOIN_REJET" name="Synchronisation rejet">
        <incoming>SF_REJET_Email_Join</incoming>
        <incoming>SF_REJET_SMS_Join</incoming>
        <incoming>SF_REJET_Portail_Join</incoming>
        <outgoing>SF_REJET_Join_End</outgoing>
      </parallelGateway>
      <endEvent id="SP_REJET_End" />
      <sequenceFlow id="SF_REJET_Start_Split" sourceRef="SP_REJET_Start" targetRef="AND_SPLIT_REJET" />
      <sequenceFlow id="SF_REJET_Email" sourceRef="AND_SPLIT_REJET" targetRef="ST_REJET_EMAIL" />
      <sequenceFlow id="SF_REJET_SMS" sourceRef="AND_SPLIT_REJET" targetRef="ST_REJET_SMS" />
      <sequenceFlow id="SF_REJET_Portail" sourceRef="AND_SPLIT_REJET" targetRef="ST_REJET_PORTAIL" />
