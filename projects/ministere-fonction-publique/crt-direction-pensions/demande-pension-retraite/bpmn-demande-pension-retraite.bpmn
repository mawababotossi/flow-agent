<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.17.0">
  <bpmn:message id="MSG_PENSION_START" name="MSG_PENSION_START" />
  <bpmn:message id="MSG_PENSION_RETURN" name="MSG_PENSION_RETURN" />
  <bpmn:message id="MSG_PENSION_RESUB" name="MSG_PENSION_RESUB" />
  <bpmn:collaboration id="Collaboration_PENSION_RETRAITE">
    <bpmn:participant id="Participant_Portal" name="XPORTAL" processRef="Process_Portal" />
    <bpmn:participant id="Participant_Xflow" name="XFLOW" processRef="Process_Xflow" camunda:versionTag="1.0" camunda:historyTimeToLive="180" />
    <bpmn:messageFlow id="MF_Start" sourceRef="Send_P_Start" targetRef="Event_X_Start" />
    <bpmn:messageFlow id="MF_Return" sourceRef="Send_X_Return" targetRef="Recv_P_Return" />
    <bpmn:messageFlow id="MF_Resub" sourceRef="Send_P_Resub" targetRef="Recv_X_Resub" />
    <bpmn:messageFlow id="MF_ReturnReject" sourceRef="Send_X_ReturnReject" targetRef="Recv_P_Return" />
    <bpmn:messageFlow id="MF_ReturnCorr" sourceRef="Send_X_Correction" targetRef="Recv_P_Return" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Portal" isExecutable="true" camunda:versionTag="1">
    <bpmn:startEvent id="Event_P_Start" name="Soumettre la demande" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Soumission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Le fonctionnaire soumet sa demande de liquidation de pension.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>SF_P_Start_Send</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sendTask id="Send_P_Start" name="Soumettre dossier XFlow" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_PENSION_START</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Event_P_Start.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Start_Send</bpmn:incoming>
      <bpmn:outgoing>SF_P_SendStart_RecvReturn</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Recv_P_Return" name="Attendre réponse XFlow" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" camunda:type="external" messageRef="MSG_PENSION_RETURN" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_SendStart_RecvReturn</bpmn:incoming>
      <bpmn:incoming>SF_P_SendResub_RecvReturn</bpmn:incoming>
      <bpmn:outgoing>SF_P_RecvReturn_GwAction</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="Gw_P_Action" name="Action XFlow ?">
      <bpmn:incoming>SF_P_RecvReturn_GwAction</bpmn:incoming>
      <bpmn:outgoing>SF_P_Action_Correction</bpmn:outgoing>
      <bpmn:outgoing>SF_P_Action_Accepte</bpmn:outgoing>
      <bpmn:outgoing>SF_P_Action_Rejete</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_P_Correction" name="Corriger le dossier" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:formKey="ULID_FORM_CORRECTION" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$(this.data.Task_P_Correction &amp;&amp; this.data.Task_P_Correction.result ? this.data.Task_P_Correction.result : this.data.Event_P_Start.parameters.submissionData.data)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Corriger mon dossier</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Action_Correction</bpmn:incoming>
      <bpmn:outgoing>SF_P_Correction_Send</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Send_P_Resub" name="Soumettre correction XFlow" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_PENSION_RESUB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Task_P_Correction.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_P_Correction_Send</bpmn:incoming>
      <bpmn:outgoing>SF_P_SendResub_RecvReturn</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_P_Accepte" name="Demande acceptée">
      <bpmn:incoming>SF_P_Action_Accepte</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_P_Rejete" name="Demande rejetée">
      <bpmn:incoming>SF_P_Action_Rejete</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_P_Start_Send" sourceRef="Event_P_Start" targetRef="Send_P_Start" />
    <bpmn:sequenceFlow id="SF_P_SendStart_RecvReturn" sourceRef="Send_P_Start" targetRef="Recv_P_Return" />
    <bpmn:sequenceFlow id="SF_P_RecvReturn_GwAction" sourceRef="Recv_P_Return" targetRef="Gw_P_Action" />
    <bpmn:sequenceFlow id="SF_P_Action_Correction" name="Correction" sourceRef="Gw_P_Action" targetRef="Task_P_Correction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Recv_P_Return.result.data.action == "correction"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Action_Accepte" name="Accepte" sourceRef="Gw_P_Action" targetRef="End_P_Accepte">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Recv_P_Return.result.data.action == "accepte"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Action_Rejete" name="Rejete" sourceRef="Gw_P_Action" targetRef="End_P_Rejete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Recv_P_Return.result.data.action == "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_P_Correction_Send" sourceRef="Task_P_Correction" targetRef="Send_P_Resub" />
    <bpmn:sequenceFlow id="SF_P_SendResub_RecvReturn" sourceRef="Send_P_Resub" targetRef="Recv_P_Return" />
    <bpmn:boundaryEvent id="Timer_P_15D" name="15 jours" attachedToRef="Task_P_Correction">
      <bpmn:outgoing>SF_P_Timer_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="SF_P_Timer_End" sourceRef="Timer_P_15D" targetRef="End_P_Rejete" />
  </bpmn:process>

  <bpmn:process id="Process_Xflow" isExecutable="true" camunda:versionTag="1">
    <bpmn:startEvent id="Event_X_Start" name="Réception dossier" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Réception du dossier de demande de pension.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="development">{"ODOO":{}, "PORTAL":{"BASE_URL":"https://portail.dev.gouv.tg"}}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{"ODOO":{}, "PORTAL":{"BASE_URL":"https://portail.sandbox.gouv.tg"}}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{"ODOO":{}, "PORTAL":{"BASE_URL":"https://portail.preprod.gouv.tg"}}</camunda:inputParameter>
          <camunda:inputParameter name="production">{"ODOO":{}, "PORTAL":{"BASE_URL":"https://portail.gouv.tg"}}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:messageEventDefinition messageRef="MSG_PENSION_START" />
      <bpmn:outgoing>SF_X_Start_InitCount</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Script_X_InitCount" name="Initialiser compteur" scriptFormat="javascript">
      <bpmn:incoming>SF_X_Start_InitCount</bpmn:incoming>
      <bpmn:outgoing>SF_X_Init_StepSubmitted</bpmn:outgoing>
      <bpmn:script>this.data.nbCorrections = 0</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Step_X_Submitted" name="Etape: Dossier Soumis" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Submited</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">1</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Init_StepSubmitted</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepSub_StepProc</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Step_X_Processing" name="Etape: Instruction" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">PendingBackOffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">2</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepSub_StepProc</bpmn:incoming>
      <bpmn:incoming>SF_X_Counter_Back</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepProc_Liquidateur</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_X_Instruction" name="Instruire le dossier (Liquidateur)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:formKey="ULID_FORM_LIQUIDATEUR" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">backoffice</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepProc_Liquidateur</bpmn:incoming>
      <bpmn:incoming>SF_X_Controle_Renvoi</bpmn:incoming>
      <bpmn:outgoing>SF_X_Instr_Gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_X_Contreverification" name="Contre-vérification (Contrôleur)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:formKey="ULID_FORM_CONTROLEUR" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">backoffice</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Instr_Conforme</bpmn:incoming>
      <bpmn:outgoing>SF_X_Controleur_Gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_X_SignatureDG" name="Signature du titre (DG CRT)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:formKey="ULID_FORM_SIGNATURE_DG" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">backoffice</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Doc_DG</bpmn:incoming>
      <bpmn:outgoing>SF_X_DG_Succ</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_X_Instruction" name="Décision Liquidateur ?">
      <bpmn:incoming>SF_X_Instr_Gw</bpmn:incoming>
      <bpmn:outgoing>SF_X_Instr_Conforme</bpmn:outgoing>
      <bpmn:outgoing>SF_X_Instr_Correction</bpmn:outgoing>
      <bpmn:outgoing>SF_X_Instr_Rejet</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gw_X_Controleur" name="Décision Contrôleur ?">
      <bpmn:incoming>SF_X_Controleur_Gw</bpmn:incoming>
      <bpmn:outgoing>SF_X_Controle_Valide</bpmn:outgoing>
      <bpmn:outgoing>SF_X_Controle_Renvoi</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Doc_X_Generate" name="Générer titre pension" camunda:modelerTemplate="tg.gouv.gnspd.generateTemplate" camunda:type="external" camunda:topic="flow-generate-template">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTemplate">ULID_TEMPLATE_TITRE_PENSION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdGeneratedName">${"titre-pension-" + this.data.recordUid + ".pdf"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTempData">${JSON.stringify({"numero": this.data.recordUid, "nom": this.data.Event_X_Start.parameters.submissionData.data.nom, "prenom": this.data.Event_X_Start.parameters.submissionData.data.prenom, "matricule": this.data.Event_X_Start.parameters.submissionData.data.matricule})}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPrintOptions">{'format':'A4'}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Controle_Valide</bpmn:incoming>
      <bpmn:outgoing>SF_X_Doc_DG</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Step_X_Success" name="Etape: Titre disponible" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Success</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">3</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_DG_Succ</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepSucc_Notif</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Notif_X_Accept" name="Notifier Citoyen (Succès)" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">01KHBXTEMPLATE_SUCCESS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">01KHBXTEMPLATE_SMS_SUCCESS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepSucc_Notif</bpmn:incoming>
      <bpmn:outgoing>SF_X_Notif_SendAccept</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Send_X_Return" name="Envoyer Acceptation XPortal" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_PENSION_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${JSON.stringify({"action": "accepte", "reference": this.data.recordUid})}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Notif_SendAccept</bpmn:incoming>
      <bpmn:outgoing>SF_X_Send_EndSuccess</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_X_Success" name="Terminé avec succès" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier traité</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Send_EndSuccess</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Notif_X_Correction" name="Notifier Citoyen (Correction)" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">01KHBXTEMPLATE_CORR</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${JSON.stringify({"record_id": this.data.recordUid, "reason": this.data.Activity_X_Instruction.result.submissionData.motifDecision ?? ""})}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">01KHBXTEMPLATE_SMS_CORRECTION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Instr_Correction</bpmn:incoming>
      <bpmn:outgoing>SF_X_Notif_SendCorr</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Send_X_Correction" name="Envoyer Ordre Correction XPortal" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_PENSION_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${JSON.stringify({"action": "correction", "motif": this.data.Activity_X_Instruction.result.submissionData.motifDecision ?? null, "reference": this.data.recordUid})}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Notif_SendCorr</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendCorr_RecvResub</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Recv_X_Resub" name="Attendre resoumission" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" camunda:type="external" messageRef="MSG_PENSION_RESUB" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendCorr_RecvResub</bpmn:incoming>
      <bpmn:outgoing>SF_X_RecvResub_Incr</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:scriptTask id="Script_X_IncrCount" name="Incrémenter compteur" scriptFormat="javascript">
      <bpmn:incoming>SF_X_RecvResub_Incr</bpmn:incoming>
      <bpmn:outgoing>SF_X_Incr_GwCounter</bpmn:outgoing>
      <bpmn:script>this.data.nbCorrections += 1</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gw_X_Counter" name="Limite corrections ?">
      <bpmn:incoming>SF_X_Incr_GwCounter</bpmn:incoming>
      <bpmn:outgoing>SF_X_Counter_Back</bpmn:outgoing>
      <bpmn:outgoing>SF_X_Counter_MaxReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Notif_X_Reject" name="Notifier Citoyen (Rejet)" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">01KHBXTEMPLATE_REJECT</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${JSON.stringify({"record_id": this.data.recordUid, "reason": this.data.Activity_X_Instruction.result.submissionData.motifDecision ?? ""})}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">01KHBXTEMPLATE_SMS_REJECT</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Instr_Rejet</bpmn:incoming>
      <bpmn:incoming>SF_X_Counter_MaxReject</bpmn:incoming>
      <bpmn:outgoing>SF_X_Notif_SendReject</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Send_X_ReturnReject" name="Envoyer Rejet XPortal" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_PENSION_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${JSON.stringify({"action": "rejete", "motif": this.data.Activity_X_Instruction.result.submissionData.motifDecision ?? null, "reference": this.data.recordUid})}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Notif_SendReject</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendReject_EndReject</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_X_Reject" name="Dossier rejeté" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier rejeté</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendReject_EndReject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_X_Start_InitCount" sourceRef="Event_X_Start" targetRef="Script_X_InitCount" />
    <bpmn:sequenceFlow id="SF_X_Init_StepSubmitted" sourceRef="Script_X_InitCount" targetRef="Step_X_Submitted" />
    <bpmn:sequenceFlow id="SF_X_StepSub_StepProc" sourceRef="Step_X_Submitted" targetRef="Step_X_Processing" />
    <bpmn:sequenceFlow id="SF_X_StepProc_Liquidateur" sourceRef="Step_X_Processing" targetRef="Activity_X_Instruction" />
    <bpmn:sequenceFlow id="SF_X_Instr_Gw" sourceRef="Activity_X_Instruction" targetRef="Gw_X_Instruction" />
    <bpmn:sequenceFlow id="SF_X_Instr_Conforme" name="Conforme" sourceRef="Gw_X_Instruction" targetRef="Activity_X_Contreverification">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Instruction.result.submissionData.decisionInstruction == 'conforme'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Instr_Correction" name="Correction" sourceRef="Gw_X_Instruction" targetRef="Notif_X_Correction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Instruction.result.submissionData.decisionInstruction == 'correction'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Instr_Rejet" name="Rejet" sourceRef="Gw_X_Instruction" targetRef="Notif_X_Reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Instruction.result.submissionData.decisionInstruction == 'rejet'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Controleur_Gw" sourceRef="Activity_X_Contreverification" targetRef="Gw_X_Controleur" />
    <bpmn:sequenceFlow id="SF_X_Controle_Valide" name="Validé" sourceRef="Gw_X_Controleur" targetRef="Doc_X_Generate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Contreverification.result.submissionData.decisionControle == 'valide'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Controle_Renvoi" name="Renvoi Interne" sourceRef="Gw_X_Controleur" targetRef="Activity_X_Instruction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Contreverification.result.submissionData.decisionControle == 'renvoi'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Doc_DG" sourceRef="Doc_X_Generate" targetRef="Activity_X_SignatureDG" />
    <bpmn:sequenceFlow id="SF_X_DG_Succ" sourceRef="Activity_X_SignatureDG" targetRef="Step_X_Success" />
    <bpmn:sequenceFlow id="SF_X_StepSucc_Notif" sourceRef="Step_X_Success" targetRef="Notif_X_Accept" />
    <bpmn:sequenceFlow id="SF_X_Notif_SendAccept" sourceRef="Notif_X_Accept" targetRef="Send_X_Return" />
    <bpmn:sequenceFlow id="SF_X_Send_EndSuccess" sourceRef="Send_X_Return" targetRef="End_X_Success" />
    <bpmn:sequenceFlow id="SF_X_Notif_SendCorr" sourceRef="Notif_X_Correction" targetRef="Send_X_Correction" />
    <bpmn:sequenceFlow id="SF_X_SendCorr_RecvResub" sourceRef="Send_X_Correction" targetRef="Recv_X_Resub" />
    <bpmn:sequenceFlow id="SF_X_RecvResub_Incr" sourceRef="Recv_X_Resub" targetRef="Script_X_IncrCount" />
    <bpmn:sequenceFlow id="SF_X_Incr_GwCounter" sourceRef="Script_X_IncrCount" targetRef="Gw_X_Counter" />
    <bpmn:sequenceFlow id="SF_X_Counter_Back" name="Continuer" sourceRef="Gw_X_Counter" targetRef="Step_X_Processing">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.nbCorrections &lt;= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Counter_MaxReject" name="Max atteint" sourceRef="Gw_X_Counter" targetRef="Notif_X_Reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.nbCorrections &gt; 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Notif_SendReject" sourceRef="Notif_X_Reject" targetRef="Send_X_ReturnReject" />
    <bpmn:sequenceFlow id="SF_X_SendReject_EndReject" sourceRef="Send_X_ReturnReject" targetRef="End_X_Reject" />
  </bpmn:process>

