          "persistent": false,
          "validateOn": "change",
          "calculateValue": "var typeLabels={'premiere_demande':'1ère demande (majeur)','premiere_demande_mineur':'1ère demande (mineur)','renouvellement':'Renouvellement','duplicata':'Duplicata','urgence':'Procédure d\\'urgence'};var centreLabel=data.centreDocumentation||'—';value='<div style=\"background:#f9fafb;border:1px solid #e5e7eb;border-radius:12px;padding:20px;font-size:15px;line-height:1.8;\"><table style=\"width:100%;border-collapse:collapse;\"><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;width:40%;\">Type de demande</td><td>'+(typeLabels[data.typedemande]||'—')+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Nom</td><td>'+(data.nom||'—')+' '+(data.prenom||'—')+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Date de naissance</td><td>'+(data.dateNaissance||'—')+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Téléphone</td><td>'+(data.telephone||'—')+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Email</td><td>'+(data.email||'—')+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Centre de Documentation</td><td>'+centreLabel+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Date RDV souhaitée</td><td>'+(data.dateRdvSouhaite||'—')+'</td></tr><tr><td style=\"padding:6px 0;font-weight:600;color:#6b7280;\">Montant à payer</td><td style=\"font-weight:700;color:#1BAE4A;\">'+(data.montantPaiement||'4 000')+' FCFA</td></tr></table></div>'"
