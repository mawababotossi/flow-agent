<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_CJ"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.42.0"
  modeler:executionPlatform="Camunda Platform"
  modeler:executionPlatformVersion="7.17.0">

  <!-- ══════════════════════════════════════════════ -->
  <!-- MESSAGES KAFKA                                 -->
  <!-- ══════════════════════════════════════════════ -->
  <bpmn:message id="MSG_CJ_START"        name="MSG_CJ_START" />
  <bpmn:message id="MSG_CJ_PAY_ORDER"    name="MSG_CJ_PAY_ORDER" />
  <bpmn:message id="MSG_CJ_PAY_CALLBACK" name="MSG_CJ_PAY_CALLBACK" />
  <bpmn:message id="MSG_CJ_PAY_CONFIRM"  name="MSG_CJ_PAY_CONFIRM" />
  <bpmn:message id="MSG_CJ_RETURN"       name="MSG_CJ_RETURN" />
  <bpmn:message id="MSG_CJ_RESUB"        name="MSG_CJ_RESUB" />

  <!-- ══════════════════════════════════════════════ -->
  <!-- COLLABORATION                                  -->
  <!-- ══════════════════════════════════════════════ -->
  <bpmn:collaboration id="Collaboration_CJ">
    <bpmn:participant id="Participant_Portal" name="xportal" processRef="Process_Portal"
      camunda:versionTag="1.0" isExecutable="true" camunda:historyTimeToLive="180" />
    <bpmn:participant id="Participant_Xflow" name="xflow" processRef="Process_Xflow"
      camunda:versionTag="1.0" isExecutable="true" camunda:historyTimeToLive="180" />
    <!-- Message Flows -->
    <bpmn:messageFlow id="MF_Start"      name="Dossier soumis"        sourceRef="Activity_P_SendBO"         targetRef="Event_X_Start" />
    <bpmn:messageFlow id="MF_PayOrder"   name="Demande paiement"      sourceRef="Activity_X_SendPayOrder"   targetRef="Activity_P_RcvPayOrder" />
    <bpmn:messageFlow id="MF_PayConfirm" name="Confirmation paiement" sourceRef="Activity_X_SendPayConfirm" targetRef="Activity_P_RcvPayConfirm" />
    <bpmn:messageFlow id="MF_Return"     name="Retour correction"     sourceRef="Activity_X_SendCorrection"  targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF_Accept"     name="Acceptation"           sourceRef="Activity_X_SendTermine"     targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF_Reject"     name="Rejet"                 sourceRef="Activity_X_SendRejet"       targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF_Resub"      name="Resoumission"          sourceRef="Activity_P_SendResub"       targetRef="Activity_X_WaitResub" />
  </bpmn:collaboration>

  <!-- ══════════════════════════════════════════════════════════════ -->
  <!-- POOL XPORTAL — Machine à états citoyen                       -->
  <!-- Pattern : StartEvent → Send → RcvPay → Pay → RcvConfirm     -->
  <!--           → RcvReturn(multi) → GW → Correction loop / End   -->
  <!-- ══════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Portal" isExecutable="true" camunda:versionTag="1">

    <!-- P0 — StartEvent -->
    <bpmn:startEvent id="Event_P_Start" name="Soumission de la demande de casier judiciaire"
      camunda:modelerTemplate="tg.gouv.gnspd.startEvent"
      camunda:formKey="01FORM_DEMANDE_CASIER_JUDICIAIRE"
      camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Soumission de la demande de casier judiciaire (bulletin n°3)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">2000</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCost" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_P_Start_Send</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- P1 — Envoi immédiat au back-office (AVANT paiement) -->
    <bpmn:sendTask id="Activity_P_SendBO" name="Envoi du dossier au back-office"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_START</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Event_P_Start.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_Start_Send</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Send_RcvPay</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- P2a — Attendre l'ordre de paiement de XFlow -->
    <bpmn:receiveTask id="Activity_P_RcvPayOrder" name="Attendre ordre de paiement"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      messageRef="MSG_CJ_PAY_ORDER"
      camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_Send_RcvPay</bpmn:incoming>
      <bpmn:outgoing>Flow_P_RcvPay_Pay</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- P2b — Paiement (redirection plateforme externe e-Gov) -->
    <bpmn:userTask id="Activity_P_Payment" name="Payer"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:formKey="01FORM_PAIEMENT_CASIER_JUDICIAIRE"
      camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Vous devez payer les frais de délivrance du casier judiciaire (2 000 FCFA)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">tarification</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Paiement des frais</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:outputParameter name="Output_Payment" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_RcvPay_Pay</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Pay_RcvConfirm</bpmn:outgoing>
    </bpmn:userTask>

    <!-- P2c — Attendre confirmation paiement de XFlow -->
    <bpmn:receiveTask id="Activity_P_RcvPayConfirm" name="Confirmation paiement?"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      messageRef="MSG_CJ_PAY_CONFIRM"
      camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_Pay_RcvConfirm</bpmn:incoming>
      <bpmn:outgoing>Flow_P_RcvConfirm_RcvReturn</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- P_WAIT — ReceiveTask central (multi-entrant : correction/accepte/rejete) -->
    <bpmn:receiveTask id="Activity_P_Receive" name="Attendre le retour XFlow"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      messageRef="MSG_CJ_RETURN"
      camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_RcvConfirm_RcvReturn</bpmn:incoming>
      <bpmn:incoming>Flow_P_Resub_Receive</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Receive_GW</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- Gateway action -->
    <bpmn:exclusiveGateway id="Gateway_P_Action" name="Quelle action ?">
      <bpmn:incoming>Flow_P_Receive_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Correction</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_AccepteEnd</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_RejeteEnd</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- P3a — Correction (userTask publish_submission) -->
    <bpmn:userTask id="Activity_P_Correction" name="Correction du dossier"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:formKey="01FORM_CORRECTION_CASIER_JUDICIAIRE"
      camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Veuillez corriger les éléments demandés par l'agent DACS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$(this.data.Activity_P_Correction &amp;&amp; this.data.Activity_P_Correction.result ? this.data.Activity_P_Correction.result : this.data.Event_P_Start.parameters.submissionData.data)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Correction du dossier</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_Correction</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Corr_SendResub</bpmn:outgoing>
    </bpmn:userTask>

    <!-- P3a — SendTask resoumission -->
    <bpmn:sendTask id="Activity_P_SendResub" name="Envoi de la resoumission"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_RESUB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">Envoi de la resoumission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_Corr_SendResub</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Resub_Receive</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- P_END -->
    <bpmn:endEvent id="Event_P_End" name="Fin">
      <bpmn:incoming>Flow_P_AccepteEnd</bpmn:incoming>
      <bpmn:incoming>Flow_P_RejeteEnd</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows XPortal -->
    <bpmn:sequenceFlow id="Flow_P_Start_Send"           sourceRef="Event_P_Start"           targetRef="Activity_P_SendBO" />
    <bpmn:sequenceFlow id="Flow_P_Send_RcvPay"          sourceRef="Activity_P_SendBO"        targetRef="Activity_P_RcvPayOrder" />
    <bpmn:sequenceFlow id="Flow_P_RcvPay_Pay"           sourceRef="Activity_P_RcvPayOrder"   targetRef="Activity_P_Payment" />
    <bpmn:sequenceFlow id="Flow_P_Pay_RcvConfirm"       sourceRef="Activity_P_Payment"       targetRef="Activity_P_RcvPayConfirm" />
    <bpmn:sequenceFlow id="Flow_P_RcvConfirm_RcvReturn" sourceRef="Activity_P_RcvPayConfirm" targetRef="Activity_P_Receive" />
    <bpmn:sequenceFlow id="Flow_P_Receive_GW"           sourceRef="Activity_P_Receive"       targetRef="Gateway_P_Action" />
    <bpmn:sequenceFlow id="Flow_P_Correction" name="Correction" sourceRef="Gateway_P_Action" targetRef="Activity_P_Correction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_P_Receive.result.data.action == "correction"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P_AccepteEnd" name="Accepté" sourceRef="Gateway_P_Action" targetRef="Event_P_End">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_P_Receive.result.data.action == "accepte"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P_RejeteEnd" name="Rejeté" sourceRef="Gateway_P_Action" targetRef="Event_P_End">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_P_Receive.result.data.action == "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P_Corr_SendResub" sourceRef="Activity_P_Correction" targetRef="Activity_P_SendResub" />
    <bpmn:sequenceFlow id="Flow_P_Resub_Receive"  sourceRef="Activity_P_SendResub"   targetRef="Activity_P_Receive" />

  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!-- POOL XFLOW — Orchestration back-office                          -->
  <!-- Pattern paiement : SendPayOrder → CatchEvent(callback) →        -->
  <!--                    SendPayConfirm → puis conformité classique   -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Xflow" isExecutable="true" camunda:versionTag="1">

    <!-- X0 — StartEvent -->
    <bpmn:startEvent id="Event_X_Start" name="Réception de la demande CJ"
      camunda:modelerTemplate="tg.gouv.gnspd.startEvent"
      camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Réception</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Réception de la demande de casier judiciaire</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">2000</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{ "ODOO": { "URL": "", "DB": "", "PORT": "", "SECRET_USERNAME": "", "SECRET_PASSWORD": "" } }</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{ "ODOO": { "URL": "", "DB": "", "PORT": "", "SECRET_USERNAME": "", "SECRET_PASSWORD": "" } }</camunda:inputParameter>
          <camunda:inputParameter name="production">{ "ODOO": { "URL": "", "DB": "", "PORT": "", "SECRET_USERNAME": "", "SECRET_PASSWORD": "" } }</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_X_Start_Step</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- B02 — Step Notification Soumis -->
    <bpmn:serviceTask id="Activity_X_StepSubmitted" name="Marquer dossier soumis"
      camunda:modelerTemplate="tg.gouv.gnspd.stepNotification"
      camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Submited</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassData" />
          <camunda:inputParameter name="gnspdPassCost" />
          <camunda:inputParameter name="gnspdIgnoreNotFound">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Soumission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Submitted</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Start_Step</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Step_NotifAR</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- B03 — Accusé de réception -->
    <bpmn:serviceTask id="Activity_X_NotifAR" name="Accusé de réception SMS/Email"
      camunda:modelerTemplate="tg.gouv.gnspd.sendNotification"
      camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">[ID template email AR]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">[ID template SMS AR]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">[ID template in-app AR]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Step_NotifAR</bpmn:incoming>
      <bpmn:outgoing>Flow_X_NotifAR_SendPayOrder</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ── BLOC PAIEMENT (pattern demande-passeport) ── -->

    <!-- X_PAY1 — Envoyer l'ordre de paiement au portail -->
    <bpmn:sendTask id="Activity_X_SendPayOrder" name="Envoyer la demande de paiement"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_PAY_ORDER</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_NotifAR_SendPayOrder</bpmn:incoming>
      <bpmn:outgoing>Flow_X_SendPayOrder_CatchPay</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- X_PAY2 — Recevoir le callback de la plateforme e-Gov -->
    <bpmn:intermediateCatchEvent id="Event_X_PayCallback" name="Recevoir les informations de paiement">
      <bpmn:extensionElements>
        <camunda:executionListener event="end">
          <camunda:script scriptFormat="javascript">this.data.payment_key = true</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_SendPayOrder_CatchPay</bpmn:incoming>
      <bpmn:outgoing>Flow_X_CatchPay_SendPayConfirm</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgEvtDef_PayCallback" messageRef="MSG_CJ_PAY_CALLBACK" />
    </bpmn:intermediateCatchEvent>

    <!-- X_PAY3 — Confirmer le paiement au portail -->
    <bpmn:sendTask id="Activity_X_SendPayConfirm" name="Confirmation de paiement"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_PAY_CONFIRM</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_CatchPay_SendPayConfirm</bpmn:incoming>
      <bpmn:outgoing>Flow_X_SendPayConfirm_Conformite</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- ── FIN BLOC PAIEMENT ── -->

    <!-- B04 — Vérification de conformité (Agent) -->
    <bpmn:userTask id="Activity_X_Conformite" name="Vérification de conformité (Agent DACS)"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Vérifier la conformité du dossier de demande de casier judiciaire</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments">${"pieceIdentite": this.data.Event_X_Start.parameters.submissionData.pieceIdentite ?? null, "acteDeNaissance": this.data.Event_X_Start.parameters.submissionData.acteDeNaissance ?? null}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Vérification de conformité</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">PendingBackOffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">backoffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_SendPayConfirm_Conformite</bpmn:incoming>
      <bpmn:incoming>Flow_X_Resub_Conformite</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Conformite_GW</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Gateway Conformité -->
    <bpmn:exclusiveGateway id="Gateway_X_Conformite" name="Décision conformité ?">
      <bpmn:incoming>Flow_X_Conformite_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Conforme</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_Correction</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_Rejet_Conf</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Boucle correction -->
    <bpmn:serviceTask id="Activity_X_StepCorrection" name="Mettre en correction"
      camunda:modelerTemplate="tg.gouv.gnspd.stepNotification"
      camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">PendingUser</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassData" />
          <camunda:inputParameter name="gnspdPassCost" />
          <camunda:inputParameter name="gnspdIgnoreNotFound">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Correction</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">PendingPortal</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Correction</bpmn:incoming>
      <bpmn:outgoing>Flow_X_StepCorr_NotifCorr</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_X_NotifCorrection" name="Notifier correction SMS/Email"
      camunda:modelerTemplate="tg.gouv.gnspd.sendNotification"
      camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">[ID template email correction]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": this.data.Activity_X_Conformite.result.submissionData.motifCorrection ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">[ID template SMS correction]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">[ID template in-app correction]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_StepCorr_NotifCorr</bpmn:incoming>
      <bpmn:outgoing>Flow_X_NotifCorr_SendCorr</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Activity_X_SendCorrection" name="Envoyer correction au portail"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "correction", "motif": this.data.Activity_X_Conformite.result.submissionData.motifCorrection ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_NotifCorr_SendCorr</bpmn:incoming>
      <bpmn:outgoing>Flow_X_SendCorr_WaitResub</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Activity_X_WaitResub" name="Attendre resoumission"
      camunda:modelerTemplate="tg.gouv.gnspd.receiveTask"
      messageRef="MSG_CJ_RESUB"
      camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">PendingPortal</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_SendCorr_WaitResub</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Resub_Conformite</bpmn:outgoing>
    </bpmn:receiveTask>

    <!-- Instruction + Chef + Archivage + Fin (inchangés) -->
    <bpmn:userTask id="Activity_X_Instruction" name="Instruction du bulletin (Agent DACS)"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Consulter le fichier des condamnations et saisir le résultat (néant ou mentions)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Instruction du bulletin</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">PendingBackOffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">backoffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Conforme</bpmn:incoming>
      <bpmn:incoming>Flow_X_Chef_Correction</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Instruction_Chef</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Activity_X_Chef" name="Validation finale (Chef DACS)"
      camunda:modelerTemplate="tg.gouv.gnspd.userTask"
      camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Contrôler et valider le bulletin de casier judiciaire</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Activity_X_Instruction.result.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Validation chef de service</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Review</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">3</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">backoffice</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Instruction_Chef</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Chef_GW</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_X_ChefDecision" name="Décision chef ?">
      <bpmn:incoming>Flow_X_Chef_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Chef_Valide</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_Chef_Correction</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_Chef_Rejet</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_X_OdooArchive" name="Archivage dans la GED Odoo"
      camunda:modelerTemplate="tg.gouv.gnspd.odoo"
      camunda:type="external" camunda:topic="flow-odoo">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdUrl">$this.data.Event_X_Start.parameters.configuration.ODOO.URL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDb">$this.data.Event_X_Start.parameters.configuration.ODOO.DB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPort">$this.data.Event_X_Start.parameters.configuration.ODOO.PORT</camunda:inputParameter>
          <camunda:inputParameter name="gnspdUsername">$this.data.Event_X_Start.parameters.configuration.ODOO.SECRET_USERNAME</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassword">$this.data.Event_X_Start.parameters.configuration.ODOO.SECRET_PASSWORD</camunda:inputParameter>
          <camunda:inputParameter name="gnspdModel">ged.document</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMethod">create</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDomain">${"from_portal": "true", "folder_number": this.data.xref, "nom": this.data.Event_X_Start.parameters.submissionData.nom, "prenom": this.data.Event_X_Start.parameters.submissionData.prenom, "resultat": this.data.Activity_X_Instruction.result.submissionData.resultat}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Chef_Valide</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Odoo_StepDispo</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_X_StepCompleted" name="Marquer bulletin disponible"
      camunda:modelerTemplate="tg.gouv.gnspd.stepNotification"
      camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Success</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassData" />
          <camunda:inputParameter name="gnspdPassCost" />
          <camunda:inputParameter name="gnspdIgnoreNotFound">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Bulletin disponible</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">PendingCompletion</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">3</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Odoo_StepDispo</bpmn:incoming>
      <bpmn:outgoing>Flow_X_StepDispo_NotifDispo</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_X_NotifDispo" name="Notifier disponibilité du bulletin"
      camunda:modelerTemplate="tg.gouv.gnspd.sendNotification"
      camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">[ID template email disponibilité]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">[ID template SMS disponibilité]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">[ID template in-app disponibilité]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_StepDispo_NotifDispo</bpmn:incoming>
      <bpmn:outgoing>Flow_X_NotifDispo_SendTermine</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Activity_X_SendTermine" name="Clôturer le portail"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "accepte"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_NotifDispo_SendTermine</bpmn:incoming>
      <bpmn:outgoing>Flow_X_SendTermine_End</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="Event_X_End" name="Fin — Succès"
      camunda:modelerTemplate="tg.gouv.gnspd.endEvent"
      camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Fin</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">4</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_SendTermine_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── BRANCHE REJET ── -->
    <bpmn:serviceTask id="Activity_X_StepRejet" name="Marquer dossier rejeté"
      camunda:modelerTemplate="tg.gouv.gnspd.stepNotification"
      camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Fail</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPassData" />
          <camunda:inputParameter name="gnspdPassCost" />
          <camunda:inputParameter name="gnspdIgnoreNotFound">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier rejeté</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Rejected</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Rejet_Conf</bpmn:incoming>
      <bpmn:incoming>Flow_X_Chef_Rejet</bpmn:incoming>
      <bpmn:outgoing>Flow_X_StepRejet_NotifRejet</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Activity_X_NotifRejet" name="Notifier rejet SMS/Email"
      camunda:modelerTemplate="tg.gouv.gnspd.sendNotification"
      camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">[ID template email rejet]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": this.data.Activity_X_Conformite.result.submissionData.motifRejet ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">[ID template SMS rejet]</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp" />
          <camunda:inputParameter name="gnspdNotifyContentInApp" />
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_StepRejet_NotifRejet</bpmn:incoming>
      <bpmn:outgoing>Flow_X_NotifRejet_SendRejet</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Activity_X_SendRejet" name="Signaler le rejet au portail"
      camunda:modelerTemplate="tg.gouv.gnspd.sendMessage"
      camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_CJ_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "rejete"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_NotifRejet_SendRejet</bpmn:incoming>
      <bpmn:outgoing>Flow_X_SendRejet_EndRejet</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="Event_X_EndRejet" name="Fin — Rejet"
      camunda:modelerTemplate="tg.gouv.gnspd.endEvent"
      camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Fin — Rejet</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Rejected</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">4</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">system</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_SendRejet_EndRejet</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows XFlow -->
    <bpmn:sequenceFlow id="Flow_X_Start_Step"                sourceRef="Event_X_Start"             targetRef="Activity_X_StepSubmitted" />
    <bpmn:sequenceFlow id="Flow_X_Step_NotifAR"              sourceRef="Activity_X_StepSubmitted"   targetRef="Activity_X_NotifAR" />
    <bpmn:sequenceFlow id="Flow_X_NotifAR_SendPayOrder"      sourceRef="Activity_X_NotifAR"         targetRef="Activity_X_SendPayOrder" />
    <bpmn:sequenceFlow id="Flow_X_SendPayOrder_CatchPay"     sourceRef="Activity_X_SendPayOrder"    targetRef="Event_X_PayCallback" />
    <bpmn:sequenceFlow id="Flow_X_CatchPay_SendPayConfirm"   sourceRef="Event_X_PayCallback"        targetRef="Activity_X_SendPayConfirm" />
    <bpmn:sequenceFlow id="Flow_X_SendPayConfirm_Conformite" sourceRef="Activity_X_SendPayConfirm"  targetRef="Activity_X_Conformite" />
    <bpmn:sequenceFlow id="Flow_X_Conformite_GW"             sourceRef="Activity_X_Conformite"      targetRef="Gateway_X_Conformite" />
    <bpmn:sequenceFlow id="Flow_X_Conforme" name="Conforme" sourceRef="Gateway_X_Conformite" targetRef="Activity_X_Instruction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Conformite.result.submissionData.decision == 'conforme'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_Correction" name="Correction" sourceRef="Gateway_X_Conformite" targetRef="Activity_X_StepCorrection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Conformite.result.submissionData.decision == 'correction'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_Rejet_Conf" name="Rejet" sourceRef="Gateway_X_Conformite" targetRef="Activity_X_StepRejet">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Conformite.result.submissionData.decision == 'rejet'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_StepCorr_NotifCorr"   sourceRef="Activity_X_StepCorrection"  targetRef="Activity_X_NotifCorrection" />
    <bpmn:sequenceFlow id="Flow_X_NotifCorr_SendCorr"   sourceRef="Activity_X_NotifCorrection"  targetRef="Activity_X_SendCorrection" />
    <bpmn:sequenceFlow id="Flow_X_SendCorr_WaitResub"   sourceRef="Activity_X_SendCorrection"   targetRef="Activity_X_WaitResub" />
    <bpmn:sequenceFlow id="Flow_X_Resub_Conformite"     sourceRef="Activity_X_WaitResub"        targetRef="Activity_X_Conformite" />
    <bpmn:sequenceFlow id="Flow_X_Instruction_Chef"     sourceRef="Activity_X_Instruction"      targetRef="Activity_X_Chef" />
    <bpmn:sequenceFlow id="Flow_X_Chef_GW"              sourceRef="Activity_X_Chef"             targetRef="Gateway_X_ChefDecision" />
    <bpmn:sequenceFlow id="Flow_X_Chef_Valide" name="Validé" sourceRef="Gateway_X_ChefDecision" targetRef="Activity_X_OdooArchive">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Chef.result.submissionData.decision == 'valide'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_Chef_Correction" name="Renvoi instruction" sourceRef="Gateway_X_ChefDecision" targetRef="Activity_X_Instruction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Chef.result.submissionData.decision == 'correction'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_Chef_Rejet" name="Rejeté" sourceRef="Gateway_X_ChefDecision" targetRef="Activity_X_StepRejet">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Chef.result.submissionData.decision == 'rejete'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_Odoo_StepDispo"       sourceRef="Activity_X_OdooArchive"     targetRef="Activity_X_StepCompleted" />
    <bpmn:sequenceFlow id="Flow_X_StepDispo_NotifDispo"  sourceRef="Activity_X_StepCompleted"   targetRef="Activity_X_NotifDispo" />
    <bpmn:sequenceFlow id="Flow_X_NotifDispo_SendTermine" sourceRef="Activity_X_NotifDispo"     targetRef="Activity_X_SendTermine" />
    <bpmn:sequenceFlow id="Flow_X_SendTermine_End"       sourceRef="Activity_X_SendTermine"     targetRef="Event_X_End" />
    <bpmn:sequenceFlow id="Flow_X_StepRejet_NotifRejet"  sourceRef="Activity_X_StepRejet"       targetRef="Activity_X_NotifRejet" />
    <bpmn:sequenceFlow id="Flow_X_NotifRejet_SendRejet"  sourceRef="Activity_X_NotifRejet"      targetRef="Activity_X_SendRejet" />
    <bpmn:sequenceFlow id="Flow_X_SendRejet_EndRejet"    sourceRef="Activity_X_SendRejet"       targetRef="Event_X_EndRejet" />

  </bpmn:process>

  <!-- ══════════════════════════════════════════════ -->
  <!-- BPMN DIAGRAM                                   -->
  <!-- ══════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_CJ">

      <!-- Pools -->
      <bpmndi:BPMNShape id="Participant_Portal_di" bpmnElement="Participant_Portal" isHorizontal="true">
        <dc:Bounds x="140" y="80" width="2400" height="400" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Xflow_di" bpmnElement="Participant_Xflow" isHorizontal="true">
        <dc:Bounds x="140" y="560" width="2400" height="700" />
      </bpmndi:BPMNShape>

      <!-- ── XPortal shapes ── -->
      <bpmndi:BPMNShape id="Event_P_Start_di" bpmnElement="Event_P_Start">
        <dc:Bounds x="222" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_SendBO_di" bpmnElement="Activity_P_SendBO">
        <dc:Bounds x="310" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_RcvPayOrder_di" bpmnElement="Activity_P_RcvPayOrder">
        <dc:Bounds x="460" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_Payment_di" bpmnElement="Activity_P_Payment">
        <dc:Bounds x="610" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_RcvPayConfirm_di" bpmnElement="Activity_P_RcvPayConfirm">
        <dc:Bounds x="760" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_Receive_di" bpmnElement="Activity_P_Receive">
        <dc:Bounds x="910" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_P_Action_di" bpmnElement="Gateway_P_Action" isMarkerVisible="true">
        <dc:Bounds x="1065" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_Correction_di" bpmnElement="Activity_P_Correction">
        <dc:Bounds x="1170" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_P_SendResub_di" bpmnElement="Activity_P_SendResub">
        <dc:Bounds x="1320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_P_End_di" bpmnElement="Event_P_End">
        <dc:Bounds x="1202" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ── XFlow shapes ── -->
      <bpmndi:BPMNShape id="Event_X_Start_di" bpmnElement="Event_X_Start">
        <dc:Bounds x="222" y="862" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_StepSubmitted_di" bpmnElement="Activity_X_StepSubmitted">
        <dc:Bounds x="310" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_NotifAR_di" bpmnElement="Activity_X_NotifAR">
        <dc:Bounds x="460" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_SendPayOrder_di" bpmnElement="Activity_X_SendPayOrder">
        <dc:Bounds x="610" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_X_PayCallback_di" bpmnElement="Event_X_PayCallback">
        <dc:Bounds x="762" y="862" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_SendPayConfirm_di" bpmnElement="Activity_X_SendPayConfirm">
        <dc:Bounds x="850" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_Conformite_di" bpmnElement="Activity_X_Conformite">
        <dc:Bounds x="1000" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_X_Conformite_di" bpmnElement="Gateway_X_Conformite" isMarkerVisible="true">
        <dc:Bounds x="1155" y="855" width="50" height="50" />
      </bpmndi:BPMNShape>
      <!-- Correction loop -->
      <bpmndi:BPMNShape id="Activity_X_StepCorrection_di" bpmnElement="Activity_X_StepCorrection">
        <dc:Bounds x="1130" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_NotifCorrection_di" bpmnElement="Activity_X_NotifCorrection">
        <dc:Bounds x="980" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_SendCorrection_di" bpmnElement="Activity_X_SendCorrection">
        <dc:Bounds x="830" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_WaitResub_di" bpmnElement="Activity_X_WaitResub">
        <dc:Bounds x="680" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <!-- Main path -->
      <bpmndi:BPMNShape id="Activity_X_Instruction_di" bpmnElement="Activity_X_Instruction">
        <dc:Bounds x="1280" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_Chef_di" bpmnElement="Activity_X_Chef">
        <dc:Bounds x="1430" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_X_ChefDecision_di" bpmnElement="Gateway_X_ChefDecision" isMarkerVisible="true">
        <dc:Bounds x="1585" y="855" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_OdooArchive_di" bpmnElement="Activity_X_OdooArchive">
        <dc:Bounds x="1700" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_StepCompleted_di" bpmnElement="Activity_X_StepCompleted">
        <dc:Bounds x="1850" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_NotifDispo_di" bpmnElement="Activity_X_NotifDispo">
        <dc:Bounds x="2000" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_SendTermine_di" bpmnElement="Activity_X_SendTermine">
        <dc:Bounds x="2150" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_X_End_di" bpmnElement="Event_X_End">
        <dc:Bounds x="2312" y="862" width="36" height="36" />
      </bpmndi:BPMNShape>
      <!-- Rejet branch -->
      <bpmndi:BPMNShape id="Activity_X_StepRejet_di" bpmnElement="Activity_X_StepRejet">
        <dc:Bounds x="1700" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_NotifRejet_di" bpmnElement="Activity_X_NotifRejet">
        <dc:Bounds x="1850" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_X_SendRejet_di" bpmnElement="Activity_X_SendRejet">
        <dc:Bounds x="2000" y="1040" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_X_EndRejet_di" bpmnElement="Event_X_EndRejet">
        <dc:Bounds x="2152" y="1062" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- ── XPortal edges ── -->
      <bpmndi:BPMNEdge id="Flow_P_Start_Send_di" bpmnElement="Flow_P_Start_Send">
        <di:waypoint x="258" y="280" />
        <di:waypoint x="310" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Send_RcvPay_di" bpmnElement="Flow_P_Send_RcvPay">
        <di:waypoint x="410" y="280" />
        <di:waypoint x="460" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_RcvPay_Pay_di" bpmnElement="Flow_P_RcvPay_Pay">
        <di:waypoint x="560" y="280" />
        <di:waypoint x="610" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Pay_RcvConfirm_di" bpmnElement="Flow_P_Pay_RcvConfirm">
        <di:waypoint x="710" y="280" />
        <di:waypoint x="760" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_RcvConfirm_RcvReturn_di" bpmnElement="Flow_P_RcvConfirm_RcvReturn">
        <di:waypoint x="860" y="280" />
        <di:waypoint x="910" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Receive_GW_di" bpmnElement="Flow_P_Receive_GW">
        <di:waypoint x="1010" y="280" />
        <di:waypoint x="1065" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Correction_di" bpmnElement="Flow_P_Correction">
        <di:waypoint x="1090" y="255" />
        <di:waypoint x="1090" y="170" />
        <di:waypoint x="1170" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_AccepteEnd_di" bpmnElement="Flow_P_AccepteEnd">
        <di:waypoint x="1090" y="305" />
        <di:waypoint x="1090" y="380" />
        <di:waypoint x="1202" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_RejeteEnd_di" bpmnElement="Flow_P_RejeteEnd">
        <di:waypoint x="1115" y="280" />
        <di:waypoint x="1220" y="280" />
        <di:waypoint x="1220" y="362" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Corr_SendResub_di" bpmnElement="Flow_P_Corr_SendResub">
        <di:waypoint x="1270" y="170" />
        <di:waypoint x="1320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Resub_Receive_di" bpmnElement="Flow_P_Resub_Receive">
        <di:waypoint x="1420" y="170" />
        <di:waypoint x="1470" y="170" />
        <di:waypoint x="1470" y="120" />
        <di:waypoint x="960" y="120" />
        <di:waypoint x="960" y="240" />
      </bpmndi:BPMNEdge>

      <!-- ── XFlow edges ── -->
      <bpmndi:BPMNEdge id="Flow_X_Start_Step_di" bpmnElement="Flow_X_Start_Step">
