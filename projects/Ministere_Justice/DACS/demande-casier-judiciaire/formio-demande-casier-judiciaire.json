    {
      "title": "Récapitulatif et soumission",
      "label": "Page 4",
      "type": "panel",
      "key": "stepRecap",
      "buttonSettings": {
        "previous": true,
        "cancel": true,
        "next": true
      },
      "components": [
        {
          "tag": "h3",
          "content": "Récapitulatif de votre demande",
          "key": "titreRecap",
          "type": "htmlelement",
          "input": false
        },
        {
          "tag": "p",
          "content": "Veuillez vérifier les informations ci-dessous avant de soumettre votre demande. En cas d'erreur, utilisez le bouton « Précédent » pour corriger.",
          "key": "infoRecap",
          "type": "htmlelement",
          "input": false
        },
        {
          "label": "HTML",
          "tag": "div",
          "attrs": [
            {
              "attr": "id",
              "value": "recapDisplay"
            }
          ],
          "refreshOnChange": true,
          "key": "htmlRecapitulatifFinal",
          "logic": [
            {
              "name": "logiqueConstruction",
              "trigger": {
                "type": "javascript",
                "javascript": "result = true;"
              },
              "actions": [
                {
                  "name": "actionJS",
                  "type": "customAction",
                  "customAction": "const recapDiv = document.getElementById(\"recapDisplay\");\nlet list_of_datagrid = [];\nlet data_stock = [];\nconst exclude = [\"button\", \"file\", \"container\", \"panel\", \"datagrid\"];\nconst excludeKeys = [\"luEtApprouve\"];\nconst includesLabelForSelect = [\"libelle\", \"label\"];\n\nutils.eachComponent(\n  form.components,\n  (component, path) => {\n    let splitted_path = path.split(\".\");\n    let skip = false;\n\n    if (\n      !exclude.includes(component.type) &&\n      !excludeKeys.includes(component.key) &&\n      !component.hidden &&\n      ![null, undefined, \"\", [], {}, \"[]\", \"{}\"].includes(data[component.key]) &&\n      !(typeof data[component.key] === \"string\" && [\"null\", \"undefined\", \"\", \"[]\", \"{}\"].includes(data[component.key]))\n    ) {\n      if (component.type === \"datagrid\") {\n        list_of_datagrid.push(component.key);\n      } else {\n        if (\n          splitted_path.length >= 2 &&\n          list_of_datagrid.includes(splitted_path[splitted_path.length - 2])\n        ) {\n          skip = true;\n        }\n      }\n      if (!skip) {\n        data_stock.push({\n          key: component.key,\n          label: component.label,\n          value: data[component.key] || (component.type === \"datagrid\" ? [] : \"\"),\n          type: component.type,\n          components: component.components || \"\",\n        });\n      }\n    }\n  },\n  false\n);\n\nlet ourTable = `\n<style>\n  .recap-container {\n    width: 100%;\n    margin: 0 auto;\n  }\n  .recap-table {\n    width: 100%;\n    border-collapse: collapse;\n  }\n  .recap-table thead th {\n    background-color: #eeeeee;\n    color: black;\n    font-weight: bold;\n    padding: 10px;\n    border: 3px solid #ccc;\n    text-align: center;\n    font-family: poppins;\n    font-size: 16px;\n  }\n  .recap-table th, .recap-table td {\n    border: 3px solid #ccc;\n    padding: 8px;\n    text-align: left;\n    font-size: 14px;\n    font-family: poppins;\n  }\n  .recap-table td:first-child {\n    width: 5%;\n    text-align: center;\n  }\n  .recap-table td:nth-child(2) {\n    width: 50%;\n  }\n  .recap-table td:last-child {\n    width: 45%;\n  }\n  .datagrid-title, .select-key, .datetime-key, .default-key {\n    font-weight: bold;\n  }\n</style>\n<div class=\"recap-container\">\n  <table class=\"recap-table\">\n    <thead>\n      <tr>\n        <th>#</th>\n        <th>Champs du formulaire</th>\n        <th>Données saisies</th>\n      </tr>\n    </thead>\n    <tbody>`;\n\nlet index = 1;\n\ndata_stock.forEach((elmt) => {\n  if (Array.isArray(elmt.value) && elmt.type === \"datagrid\") {\n    ourTable += `<tr><td colspan=\"3\" class=\"datagrid-title\"><b>${elmt.label}</b></td></tr>`;\n    elmt.value.forEach((rowData) => {\n      const keys = Object.keys(rowData);\n      keys.forEach((key) => {\n        let cmpnt = utils.getComponent(elmt.components, key);\n        let formattedValue = rowData[key];\n        if (typeof formattedValue === \"string\" && formattedValue.includes(\"T\")) {\n          const dateObj = new Date(formattedValue);\n          formattedValue = dateObj.toLocaleDateString();\n        }\n        ourTable += `<tr><td>${index++}</td><td>&nbsp;&nbsp;&nbsp;&nbsp;${cmpnt.label}</td><td>${formattedValue}</td></tr>`;\n      });\n    });\n  } else if (elmt.type === \"select\") {\n    if (elmt.value !== undefined) {\n      let valueToDisplay;\n      if (typeof elmt.value === \"object\" && !Array.isArray(elmt.value)) {\n        const includedPropertyName = includesLabelForSelect.find(\n          (propName) => elmt.value[propName] !== undefined\n        );\n        valueToDisplay = includedPropertyName ? elmt.value[includedPropertyName] : \"\";\n      } else if (Array.isArray(elmt.value)) {\n        valueToDisplay = elmt.value.join(\", \");\n      } else {\n        valueToDisplay = elmt.value;\n      }\n      ourTable += `<tr><td>${index++}</td><td><b>${elmt.label}</b></td><td>${valueToDisplay}</td></tr>`;\n    }\n  } else if (elmt.type === \"datetime\") {\n    ourTable += `<tr><td>${index++}</td><td><b>${elmt.label}</b></td><td>${moment(elmt.value).format('LL')}</td></tr>`;\n  } else if (elmt.type === \"number\") {\n    ourTable += `<tr><td>${index++}</td><td><b>${elmt.label}</b></td><td>${elmt.value}</td></tr>`;\n  } else {\n    ourTable += `<tr><td>${index++}</td><td><b>${elmt.label}</b></td><td>${elmt.value}</td></tr>`;\n  }\n});\n\nourTable += `\n    </tbody>\n  </table>\n  <hr>\n</div>`;\n\nrecapDiv.innerHTML = ourTable;\n"
                }
              ]
            }
          ],
          "type": "htmlelement",
          "input": false,
          "keyModified": true,
          "defaultValue": null,
          "persistent": false,
          "validateOn": "change",
          "content": ""
        },
        {
          "label": "Je déclare et certifie sur l'honneur que les informations fournies sont exactes et complètes",
          "defaultValue": false,
          "validate": {
            "required": true
          },
          "key": "luEtApprouve",
          "type": "checkbox",
          "input": true,
          "dataGridLabel": true,
          "labelPosition": "right",
          "validateOn": "change",
          "inputType": "checkbox",
          "value": "",
          "name": ""
        }
      ],
      "defaultValue": null,
      "persistent": false,
      "clearOnHide": false,
      "validateOn": "change"
    }
  ],
  "actions": [
