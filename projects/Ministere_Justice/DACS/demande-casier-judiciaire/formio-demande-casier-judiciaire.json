          "type": "columns",
          "input": false,
          "defaultValue": null,
          "persistent": false,
          "clearOnHide": false,
          "validateOn": "change"
        }
      ],
      "defaultValue": null,
      "persistent": false,
      "clearOnHide": false,
      "validateOn": "change"
