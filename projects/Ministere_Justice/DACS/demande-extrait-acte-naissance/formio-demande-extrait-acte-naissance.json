          "calculateValue": "var fields={\"Nom\":data.nom,\"Prénom(s)\":data.prenom,\"Email\":data.email,\"Téléphone\":data.telephone,\"Type de pièce\":data.typePiece,\"Numéro de pièce\":data.numeroPiece,\"Lien de parenté\":data.lienParente,\"Nom de l'intéressé\":data.nomInteresse,\"Date de naissance\":data.dateNaissanceInteresse,\"Commune de naissance\":data.communeNaissance,\"Préfecture\":data.prefectureNaissance,\"Pays de naissance\":data.paysNaissance,\"Numéro de l'acte\":data.numeroActe,\"Type d'extrait\":data.typeExtrait,\"Objet\":data.objetDemande};var html='';for(var k in fields){if(fields[k]){html+='<div style=\"display:flex;padding:8px 0;border-bottom:1px solid #e5e7eb\"><span style=\"font-weight:600;min-width:200px;color:#374151\">'+k+'</span><span style=\"color:#1f2937\">'+fields[k]+'</span></div>';}}document.getElementById&&document.getElementById('recap-content')&&(document.getElementById('recap-content').innerHTML=html);value='';"
