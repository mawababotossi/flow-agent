      <bpmn:incoming>SF_X_Decision_Correction</bpmn:incoming>
      <bpmn:outgoing>SF_X_NotifCorr_Send</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Send_X_Correction" name="Envoyer ordre correction XPortal" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_MARIAGE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "correction", "motif": this.data.Activity_X_Agent.result.submissionData.motif ?? null, "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_NotifCorr_Send</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendCorr_RecvResub</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Recv_X_Resub" name="Attendre resoumission" messageRef="MSG_MARIAGE_RESUB" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendCorr_RecvResub</bpmn:incoming>
      <bpmn:outgoing>SF_X_RecvResub_IncrCount</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:scriptTask id="ScriptTask_IncrCount" name="Incrémenter compteur" scriptFormat="javascript">
      <bpmn:incoming>SF_X_RecvResub_IncrCount</bpmn:incoming>
      <bpmn:outgoing>SF_X_IncrCount_GwCounter</bpmn:outgoing>
      <bpmn:script>this.data.nbCorrections += 1</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gw_X_Counter" name="Nb corrections &#60; 3 ?">
      <bpmn:incoming>SF_X_IncrCount_GwCounter</bpmn:incoming>
      <bpmn:outgoing>SF_X_Counter_OdooSearch</bpmn:outgoing>
      <bpmn:outgoing>SF_X_Counter_MaxReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Notif_X_Reject" name="Notifier rejet dossier" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TODO_TPL_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": this.data.Activity_X_Agent?.result?.submissionData?.motif ?? "Dossier refusé"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TODO_TPL_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref, "reason": this.data.Activity_X_Agent?.result?.submissionData?.motif ?? "Dossier refusé"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TODO_TPL_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref, "reason": this.data.Activity_X_Agent?.result?.submissionData?.motif ?? "Dossier refusé"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Decision_Reject</bpmn:incoming>
      <bpmn:incoming>SF_X_Counter_MaxReject</bpmn:incoming>
      <bpmn:outgoing>SF_X_Reject_Send</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Send_X_ReturnReject" name="Envoyer rejet XPortal" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_MARIAGE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "rejete", "motif": this.data.Activity_X_Agent?.result?.submissionData?.motif ?? null}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Reject_Send</bpmn:incoming>
      <bpmn:outgoing>SF_X_ReturnReject_End</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_X_Reject" name="Dossier rejeté" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier rejeté</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_ReturnReject_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="StepNotif_X_Success" name="Mettre à jour étape" camunda:modelerTemplate="tg.gouv.gnspd.stepNotification" camunda:type="external" camunda:topic="flow-step-notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStatus">Success</camunda:inputParameter>
          <camunda:inputParameter name="gnspdIsPortal">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdStepOrder">3</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_PrintSign_StepNotifSuccess</bpmn:incoming>
      <bpmn:outgoing>SF_X_StepNotifSuccess_Notif</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Notif_X_Accept" name="Notifier acceptation" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TODO_TPL_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": "Acte prêt à être retiré"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TODO_TPL_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref, "reason": "Acte prêt à être retiré"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TODO_TPL_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref, "reason": "Acte prêt à être retiré"}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_StepNotifSuccess_Notif</bpmn:incoming>
      <bpmn:outgoing>SF_X_Notif_SendAccept</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Send_X_Return" name="Envoyer acceptation XPortal" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_MARIAGE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "accepte", "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_Notif_SendAccept</bpmn:incoming>
      <bpmn:outgoing>SF_X_SendAccept_End</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_X_Success" name="Dossier traité avec succès" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Dossier validé</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Completed</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>SF_X_SendAccept_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_X_Start_StepNotif" sourceRef="Event_X_Start" targetRef="StepNotif_X_Submitted" />
    <bpmn:sequenceFlow id="SF_X_StepNotif_ScriptInit" sourceRef="StepNotif_X_Submitted" targetRef="ScriptTask_InitCount" />
    <bpmn:sequenceFlow id="SF_X_ScriptInit_OdooSearch" sourceRef="ScriptTask_InitCount" targetRef="Activity_X_OdooSearch" />
    <bpmn:sequenceFlow id="SF_X_OdooSearch_GwOdoo" sourceRef="Activity_X_OdooSearch" targetRef="Gw_X_OdooOK" />
    <bpmn:sequenceFlow id="SF_X_OdooKO_Agent" sourceRef="Gw_X_OdooOK" targetRef="Activity_X_Agent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_OdooSearch.result == null || this.data.Activity_X_OdooSearch.result.id == null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_OdooOK_Print" sourceRef="Gw_X_OdooOK" targetRef="Activity_X_PrintSign">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_OdooSearch.result != null &amp;&amp; this.data.Activity_X_OdooSearch.result.id != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Timer_NotifEscalade" sourceRef="BoundaryTimer_X_Agent" targetRef="Activity_X_NotifEscalade" />
    <bpmn:sequenceFlow id="SF_X_NotifEscalade_End" sourceRef="Activity_X_NotifEscalade" targetRef="End_X_Escalade" />
    <bpmn:sequenceFlow id="SF_X_Agent_GwDecision" sourceRef="Activity_X_Agent" targetRef="Gw_X_Decision" />
    <bpmn:sequenceFlow id="SF_X_Decision_Approve" sourceRef="Gw_X_Decision" targetRef="Activity_X_PrintSign">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Agent.result.submissionData.decision == 'oui'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Decision_Correction" sourceRef="Gw_X_Decision" targetRef="Notif_X_Correction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Agent.result.submissionData.decision == 'correction'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Decision_Reject" sourceRef="Gw_X_Decision" targetRef="Notif_X_Reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.Activity_X_Agent.result.submissionData.decision == 'non'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_PrintSign_StepNotifSuccess" sourceRef="Activity_X_PrintSign" targetRef="StepNotif_X_Success" />
    <bpmn:sequenceFlow id="SF_X_StepNotifSuccess_Notif" sourceRef="StepNotif_X_Success" targetRef="Notif_X_Accept" />
    <bpmn:sequenceFlow id="SF_X_Notif_SendAccept" sourceRef="Notif_X_Accept" targetRef="Send_X_Return" />
    <bpmn:sequenceFlow id="SF_X_SendAccept_End" sourceRef="Send_X_Return" targetRef="End_X_Success" />
    <bpmn:sequenceFlow id="SF_X_NotifCorr_Send" sourceRef="Notif_X_Correction" targetRef="Send_X_Correction" />
    <bpmn:sequenceFlow id="SF_X_SendCorr_RecvResub" sourceRef="Send_X_Correction" targetRef="Recv_X_Resub" />
    <bpmn:sequenceFlow id="SF_X_RecvResub_IncrCount" sourceRef="Recv_X_Resub" targetRef="ScriptTask_IncrCount" />
    <bpmn:sequenceFlow id="SF_X_IncrCount_GwCounter" sourceRef="ScriptTask_IncrCount" targetRef="Gw_X_Counter" />
    <bpmn:sequenceFlow id="SF_X_Counter_OdooSearch" sourceRef="Gw_X_Counter" targetRef="Activity_X_OdooSearch">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.nbCorrections &lt; 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Counter_MaxReject" sourceRef="Gw_X_Counter" targetRef="Notif_X_Reject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.nbCorrections &gt;= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SF_X_Reject_Send" sourceRef="Notif_X_Reject" targetRef="Send_X_ReturnReject" />
    <bpmn:sequenceFlow id="SF_X_ReturnReject_End" sourceRef="Send_X_ReturnReject" targetRef="End_X_Reject" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_MARIAGE">
  <bpmndi:BPMNPlane id="BPMNPlane_MARIAGE" bpmnElement="Collaboration_MARIAGE">
    <!-- POOLS -->
    <bpmndi:BPMNShape id="Participant_Portal_di" bpmnElement="Participant_Portal" isHorizontal="true">
      <dc:Bounds x="140" y="80" width="2900" height="500" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Participant_Xflow_di" bpmnElement="Participant_Xflow" isHorizontal="true">
      <dc:Bounds x="140" y="650" width="2900" height="800" />
    </bpmndi:BPMNShape>

    <!-- XPORTAL -->
    <bpmndi:BPMNShape id="Event_P_Start_di" bpmnElement="Event_P_Start">
      <dc:Bounds x="210" y="312" width="36" height="36" />
      <bpmndi:BPMNLabel><dc:Bounds x="190" y="355" width="76" height="14" /></bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Send_P_Start_di" bpmnElement="Send_P_Start">
      <dc:Bounds x="310" y="290" width="100" height="80" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Recv_P_Return_di" bpmnElement="Recv_P_Return">
      <dc:Bounds x="470" y="290" width="100" height="80" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Gw_P_Action_di" bpmnElement="Gw_P_Action" isMarkerVisible="true">
      <dc:Bounds x="635" y="305" width="50" height="50" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Task_P_Correction_di" bpmnElement="Task_P_Correction">
      <dc:Bounds x="750" y="180" width="100" height="80" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Send_P_Resub_di" bpmnElement="Send_P_Resub">
      <dc:Bounds x="910" y="180" width="100" height="80" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="End_P_Accepte_di" bpmnElement="End_P_Accepte">
      <dc:Bounds x="782" y="312" width="36" height="36" />
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="End_P_Rejete_di" bpmnElement="End_P_Rejete">
      <dc:Bounds x="782" y="432" width="36" height="36" />
    </bpmndi:BPMNShape>

    <bpmndi:BPMNEdge id="SF_P_Start_Send_di" bpmnElement="SF_P_Start_Send">
      <di:waypoint x="246" y="330" /><di:waypoint x="310" y="330" />
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="SF_P_SendStart_RecvReturn_di" bpmnElement="SF_P_SendStart_RecvReturn">
