<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_PermisConduire" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.17.0">
  <bpmn:message id="MSG_PC_START" name="MSG_PC_START" />
  <bpmn:message id="MSG_PC_RETURN" name="MSG_PC_RETURN" />
  <bpmn:message id="MSG_PC_RESUB" name="MSG_PC_RESUB" />
  <bpmn:collaboration id="Collaboration_PermisConduire">
    <bpmn:participant id="Participant_Portal" name="xportal" processRef="Process_Portal_PC" />
    <bpmn:participant id="Participant_Xflow" name="xflow" processRef="Process_Xflow_PC" />
    <bpmn:messageFlow id="MF01" sourceRef="Activity_P_SendBO" targetRef="Event_X_Start" />
    <bpmn:messageFlow id="MF02" sourceRef="Activity_X_SendCorrection" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF03" sourceRef="Activity_P_SendResub" targetRef="Activity_X_RecvResub" />
    <bpmn:messageFlow id="MF04" sourceRef="Activity_X_SendBiometrie" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF05" sourceRef="Activity_X_SendAccept" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF06" sourceRef="Activity_X_SendReject" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF07" sourceRef="Activity_X_SendConvocCode" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF08" sourceRef="Activity_X_SendResultCode" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF09" sourceRef="Activity_X_SendConvocPratique" targetRef="Activity_P_Receive" />
    <bpmn:messageFlow id="MF10" sourceRef="Activity_X_SendResultPratique" targetRef="Activity_P_Receive" />
  </bpmn:collaboration>
  <!-- ================================================================== -->
  <!-- XPORTAL POOL                                                       -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Portal_PC" name="Procedure_Demande_Permis_Conduire_Portal_v1" isExecutable="true">
    <bpmn:startEvent id="Event_P_Start" name="Soumission demande permis de conduire" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:formKey="" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Le candidat soumet le formulaire de demande de permis de conduire depuis Xportal</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority" />
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_P01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sendTask id="Activity_P_SendBO" name="Envoi au back-office DTRF" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">Event_X_Start</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Event_P_Start.submissionData.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P01</bpmn:incoming>
      <bpmn:outgoing>Flow_P02</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Activity_P_Receive" name="Attendre le retour DTRF" messageRef="MSG_PC_RETURN">
      <bpmn:incoming>Flow_P02</bpmn:incoming>
      <bpmn:incoming>Flow_P06</bpmn:incoming>
      <bpmn:incoming>Flow_P_InfoLoop</bpmn:incoming>
      <bpmn:outgoing>Flow_P03</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="Gateway_P_Action" name="Action requise ?">
      <bpmn:incoming>Flow_P03</bpmn:incoming>
      <bpmn:outgoing>Flow_P04</bpmn:outgoing>
      <bpmn:outgoing>Flow_P07</bpmn:outgoing>
      <bpmn:outgoing>Flow_P08</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_InfoLoop</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_P_Corrections" name="Faire les corrections" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Le candidat corrige les erreurs signalées par l'agent DTRF</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey">correction-permis-conduire</camunda:inputParameter>
          <camunda:inputParameter name="gnspdFormSetting" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Corrections demandées</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies" />
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Activity_P_Receive.result.data</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P04</bpmn:incoming>
      <bpmn:outgoing>Flow_P05</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Activity_P_SendResub" name="Envoyer la resoumission" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RESUB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Activity_P_Corrections.result</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P05</bpmn:incoming>
      <bpmn:outgoing>Flow_P06</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_P_EndSuccess" name="Permis prêt">
      <bpmn:incoming>Flow_P07</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_P_EndReject" name="Rejet">
      <bpmn:incoming>Flow_P08</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_P01" sourceRef="Event_P_Start" targetRef="Activity_P_SendBO" />
    <bpmn:sequenceFlow id="Flow_P02" sourceRef="Activity_P_SendBO" targetRef="Activity_P_Receive" />
    <bpmn:sequenceFlow id="Flow_P03" sourceRef="Activity_P_Receive" targetRef="Gateway_P_Action" />
    <bpmn:sequenceFlow id="Flow_P04" name="Correction" sourceRef="Gateway_P_Action" targetRef="Activity_P_Corrections">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_P_Receive.result.data.action == "correction"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P05" sourceRef="Activity_P_Corrections" targetRef="Activity_P_SendResub" />
    <bpmn:sequenceFlow id="Flow_P06" sourceRef="Activity_P_SendResub" targetRef="Activity_P_Receive" />
    <bpmn:sequenceFlow id="Flow_P07" name="Accepté" sourceRef="Gateway_P_Action" targetRef="Event_P_EndSuccess">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_P_Receive.result.data.action == "accepte"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P08" name="Rejeté" sourceRef="Gateway_P_Action" targetRef="Event_P_EndReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_P_Receive.result.data.action == "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P_InfoLoop" name="Info (biométrie, convocation, résultat...)" sourceRef="Gateway_P_Action" targetRef="Activity_P_Receive">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_P_Receive.result.data.action != "correction" &amp;&amp; $this.data.Activity_P_Receive.result.data.action != "accepte" &amp;&amp; $this.data.Activity_P_Receive.result.data.action != "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <!-- ================================================================== -->
  <!-- XFLOW POOL                                                         -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Xflow_PC" name="Procedure_Demande_Permis_Conduire_Xflow_v1" isExecutable="true" camunda:versionTag="1.0" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="Event_X_Start" name="Réception demande permis" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Réception du dossier de demande de permis de conduire depuis Xportal</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority" />
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{
"GED": {
      "BASE_URL": "https://ged.sandbox.gouv.tg",
      "SECRET_API_KEY": "{dbkms:DTRF_GED_API_KEY_SANDBOX}"
    },
    "NOTIFICATIONS": {
      "SMTP_HOST": "smtp.sandbox.gouv.tg",
      "SECRET_SMTP_PASSWORD": "{dbkms:DTRF_SMTP_PASSWORD_SANDBOX}"
    }
}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{
"GED": {
      "BASE_URL": "https://ged.preprod.gouv.tg",
      "SECRET_API_KEY": "{dbkms:DTRF_GED_API_KEY_PREPROD}"
    },
    "NOTIFICATIONS": {
      "SMTP_HOST": "smtp.preprod.gouv.tg",
      "SECRET_SMTP_PASSWORD": "{dbkms:DTRF_SMTP_PASSWORD_PREPROD}"
    }
}</camunda:inputParameter>
          <camunda:inputParameter name="production">{
"GED": {
      "BASE_URL": "https://ged.gouv.tg",
      "SECRET_API_KEY": "{dbkms:DTRF_GED_API_KEY_PROD}"
    },
    "NOTIFICATIONS": {
      "SMTP_HOST": "smtp.gouv.tg",
      "SECRET_SMTP_PASSWORD": "{dbkms:DTRF_SMTP_PASSWORD_PROD}"
    }
}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_X01</bpmn:outgoing>
    </bpmn:startEvent>
    <!-- N01 — Accusé de réception -->
    <bpmn:serviceTask id="Activity_X_NotifAR" name="Notifier accusé de réception (N01)" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp" />
          <camunda:inputParameter name="gnspdNotifyContentInApp" />
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.Event_X_Start.parameters.submissionData.data.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail" />
          <camunda:inputParameter name="gnspdNotifyContentEmail" />
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.Event_X_Start.parameters.submissionData.data.telephone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS" />
          <camunda:inputParameter name="gnspdNotifyContentSMS">Votre demande de permis de conduire a bien été reçue. Délai de traitement : 5 jours ouvrés.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X01</bpmn:incoming>
      <bpmn:outgoing>Flow_X02</bpmn:outgoing>
    </bpmn:serviceTask>
    <!-- B01 — Vérification conformité -->
    <bpmn:userTask id="Activity_X_Agent" name="Vérification conformité DTRF (B01)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">L'agent DTRF vérifie la conformité du dossier : pièces justificatives, conditions d'âge, catégorie demandée</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey" />
          <camunda:inputParameter name="gnspdFormSetting" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Vérification conformité DTRF</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies" />
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments">[
  {"label": "Pièce d'identité", "path": "$this.data.Event_X_Start.parameters.submissionData.data.pieceIdentite"},
  {"label": "Certificat médical", "path": "$this.data.Event_X_Start.parameters.submissionData.data.certificatMedical"},
  {"label": "Photo d'identité", "path": "$this.data.Event_X_Start.parameters.submissionData.data.photoIdentite"},
  {"label": "Certificat de résidence", "path": "$this.data.Event_X_Start.parameters.submissionData.data.certificatResidence"}
]</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X02</bpmn:incoming>
      <bpmn:incoming>Flow_X_ResubToAgent</bpmn:incoming>
      <bpmn:outgoing>Flow_X03</bpmn:outgoing>
    </bpmn:userTask>
    <!-- Gateway Décision agent -->
    <bpmn:exclusiveGateway id="Gateway_X_Decision" name="Décision agent ?">
      <bpmn:incoming>Flow_X03</bpmn:incoming>
      <bpmn:outgoing>Flow_X04</bpmn:outgoing>
      <bpmn:outgoing>Flow_X05</bpmn:outgoing>
      <bpmn:outgoing>Flow_X06</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <!-- Branche CORRECTION -->
    <bpmn:exclusiveGateway id="Gateway_X_MaxCorrections" name="Max corrections atteint ?">
      <bpmn:incoming>Flow_X05</bpmn:incoming>
      <bpmn:outgoing>Flow_X_CorrOK</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_CorrMax</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Activity_X_SendCorrection" name="Demander corrections au citoyen (B02)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "correction",
"motif": this.data.Activity_X_Agent.result.data.motif_correction ?? null,
"nbCorrections": (this.data.nbCorrections ?? 0) + 1
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_CorrOK</bpmn:incoming>
      <bpmn:outgoing>Flow_X07</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Activity_X_RecvResub" name="Attente resoumission (B03)" messageRef="MSG_PC_RESUB">
      <bpmn:incoming>Flow_X07</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ResubToAgent</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="Event_X_TimerResub" name="15 jours" attachedToRef="Activity_X_RecvResub">
      <bpmn:outgoing>Flow_X_TimerToReject</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Resub">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <!-- Branche CONFORME : Biométrie → Code → Pratique → Validation chef -->
    <bpmn:sendTask id="Activity_X_SendBiometrie" name="Convoquer pour biométrie (B04)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "biometrie",
"message": "Veuillez vous présenter à la DTRF pour le relevé biométrique."
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X04</bpmn:incoming>
      <bpmn:outgoing>Flow_X08</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_X_Biometrie" name="Relevé biométrique (B05)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">L'agent DTRF effectue le relevé biométrique du candidat (empreintes, photo)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey" />
          <camunda:inputParameter name="gnspdFormSetting" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Relevé biométrique</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies" />
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X08</bpmn:incoming>
      <bpmn:outgoing>Flow_X09</bpmn:outgoing>
    </bpmn:userTask>
    <!-- Convocation Code -->
    <bpmn:sendTask id="Activity_X_SendConvocCode" name="Convoquer examen code (B06)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "convoc_code",
"message": "Vous êtes convoqué pour l'épreuve théorique (code de la route)."
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X09</bpmn:incoming>
      <bpmn:incoming>Flow_X_CodeRetry</bpmn:incoming>
      <bpmn:outgoing>Flow_X10</bpmn:outgoing>
    </bpmn:sendTask>
    <!-- Saisie résultats code -->
    <bpmn:userTask id="Activity_X_ResultCode" name="Saisir résultats examen code (B07)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">L'inspecteur saisit les résultats de l'épreuve théorique (QCM 40 questions, seuil 35/40)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey" />
          <camunda:inputParameter name="gnspdFormSetting" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Résultats examen code</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">3</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies" />
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X10</bpmn:incoming>
      <bpmn:outgoing>Flow_X11</bpmn:outgoing>
    </bpmn:userTask>
    <!-- Notification résultat code au citoyen -->
    <bpmn:sendTask id="Activity_X_SendResultCode" name="Notifier résultat code (B08)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "result_code",
"note": this.data.Activity_X_ResultCode.result.data.noteCode ?? 0,
"reussi": (this.data.Activity_X_ResultCode.result.data.noteCode ?? 0) >= 35
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X11</bpmn:incoming>
      <bpmn:outgoing>Flow_X12</bpmn:outgoing>
    </bpmn:sendTask>
    <!-- Gateway Code OK ? -->
    <bpmn:exclusiveGateway id="Gateway_X_CodeOK" name="Code réussi (≥35/40) ?">
      <bpmn:incoming>Flow_X12</bpmn:incoming>
      <bpmn:outgoing>Flow_X_CodePass</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_CodeFail</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <!-- Gateway retry code ou rejet -->
    <bpmn:exclusiveGateway id="Gateway_X_CodeRetry" name="Tentatives code épuisées ?">
      <bpmn:incoming>Flow_X_CodeFail</bpmn:incoming>
      <bpmn:outgoing>Flow_X_CodeRetry</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_CodeReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <!-- Convocation pratique -->
    <bpmn:sendTask id="Activity_X_SendConvocPratique" name="Convoquer examen pratique (B09)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "convoc_pratique",
"message": "Vous êtes convoqué pour l'épreuve pratique de conduite."
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_CodePass</bpmn:incoming>
      <bpmn:incoming>Flow_X_PratiqueRetry</bpmn:incoming>
      <bpmn:outgoing>Flow_X13</bpmn:outgoing>
    </bpmn:sendTask>
    <!-- Saisie résultats pratique -->
    <bpmn:userTask id="Activity_X_ResultPratique" name="Saisir résultats examen pratique (B10)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">L'inspecteur saisit les résultats de l'épreuve pratique (circuit + route, note sur 20, seuil 10/20)</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey" />
          <camunda:inputParameter name="gnspdFormSetting" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Résultats examen pratique</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">4</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies" />
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X13</bpmn:incoming>
      <bpmn:outgoing>Flow_X14</bpmn:outgoing>
    </bpmn:userTask>
    <!-- Notification résultat pratique au citoyen -->
    <bpmn:sendTask id="Activity_X_SendResultPratique" name="Notifier résultat pratique (B11)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "result_pratique",
"note": this.data.Activity_X_ResultPratique.result.data.notePratique ?? 0,
"reussi": (this.data.Activity_X_ResultPratique.result.data.notePratique ?? 0) >= 10
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X14</bpmn:incoming>
      <bpmn:outgoing>Flow_X15</bpmn:outgoing>
    </bpmn:sendTask>
    <!-- Gateway Pratique OK ? -->
    <bpmn:exclusiveGateway id="Gateway_X_PratiqueOK" name="Pratique réussie (≥10/20) ?">
      <bpmn:incoming>Flow_X15</bpmn:incoming>
      <bpmn:outgoing>Flow_X_PratiquePass</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_PratiqueFail</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <!-- Gateway retry pratique ou rejet -->
    <bpmn:exclusiveGateway id="Gateway_X_PratiqueRetry" name="Tentatives pratique épuisées ?">
      <bpmn:incoming>Flow_X_PratiqueFail</bpmn:incoming>
      <bpmn:outgoing>Flow_X_PratiqueRetry</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_PratiqueReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <!-- Validation chef de service -->
    <bpmn:userTask id="Activity_X_ChefValidation" name="Validation chef de service DTRF (B12)" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Le chef de service DTRF valide la délivrance du permis de conduire et approuve la production du titre sécurisé</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey" />
          <camunda:inputParameter name="gnspdFormSetting" />
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Validation chef de service</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">5</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCandidateCompanies" />
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_PratiquePass</bpmn:incoming>
      <bpmn:outgoing>Flow_X16</bpmn:outgoing>
    </bpmn:userTask>
    <!-- SendAccept -->
    <bpmn:sendTask id="Activity_X_SendAccept" name="Notifier acceptation — Permis prêt (B13)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "accepte",
"message": "Votre permis de conduire est prêt. Veuillez vous présenter à la DTRF pour le retrait.",
"categorie": this.data.Event_X_Start.parameters.submissionData.data.categoriePermis ?? null
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X16</bpmn:incoming>
      <bpmn:outgoing>Flow_X17</bpmn:outgoing>
    </bpmn:sendTask>
    <!-- Notification finale acceptation -->
    <bpmn:serviceTask id="Activity_X_NotifAccept" name="Notifier permis disponible (N02)" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp" />
          <camunda:inputParameter name="gnspdNotifyContentInApp" />
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.Event_X_Start.parameters.submissionData.data.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail" />
          <camunda:inputParameter name="gnspdNotifyContentEmail" />
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.Event_X_Start.parameters.submissionData.data.telephone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS" />
          <camunda:inputParameter name="gnspdNotifyContentSMS">Félicitations ! Votre permis de conduire est disponible. Présentez-vous à la DTRF pour le retrait.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X17</bpmn:incoming>
      <bpmn:outgoing>Flow_X18</bpmn:outgoing>
    </bpmn:serviceTask>
    <!-- SendReject -->
    <bpmn:sendTask id="Activity_X_SendReject" name="Notifier le rejet définitif (B14)" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="gnspdMessageRef">MSG_PC_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${
"action": "rejete",
"motif": this.data.Activity_X_Agent.result.data.motif_rejet ?? "Dossier rejeté"
}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-gforce</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X06</bpmn:incoming>
      <bpmn:incoming>Flow_X_CorrMax</bpmn:incoming>
      <bpmn:incoming>Flow_X_TimerToReject</bpmn:incoming>
      <bpmn:incoming>Flow_X_CodeReject</bpmn:incoming>
      <bpmn:incoming>Flow_X_PratiqueReject</bpmn:incoming>
      <bpmn:outgoing>Flow_X19</bpmn:outgoing>
    </bpmn:sendTask>
    <!-- Notification finale rejet -->
    <bpmn:serviceTask id="Activity_X_NotifReject" name="Notifier rejet par SMS (N03)" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp" />
          <camunda:inputParameter name="gnspdNotifyContentInApp" />
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.Event_X_Start.parameters.submissionData.data.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail" />
          <camunda:inputParameter name="gnspdNotifyContentEmail" />
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.Event_X_Start.parameters.submissionData.data.telephone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS" />
          <camunda:inputParameter name="gnspdNotifyContentSMS">Votre demande de permis de conduire a été rejetée. Consultez votre espace Xportal pour plus de détails.</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X19</bpmn:incoming>
      <bpmn:outgoing>Flow_X20</bpmn:outgoing>
    </bpmn:serviceTask>
    <!-- End events -->
    <bpmn:endEvent id="Event_X_EndSuccess" name="Fin succès — Permis délivré">
      <bpmn:incoming>Flow_X18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_X_EndReject" name="Fin rejet">
      <bpmn:incoming>Flow_X20</bpmn:incoming>
    </bpmn:endEvent>
    <!-- ============ SEQUENCE FLOWS ============ -->
    <bpmn:sequenceFlow id="Flow_X01" sourceRef="Event_X_Start" targetRef="Activity_X_NotifAR" />
    <bpmn:sequenceFlow id="Flow_X02" sourceRef="Activity_X_NotifAR" targetRef="Activity_X_Agent" />
    <bpmn:sequenceFlow id="Flow_X03" sourceRef="Activity_X_Agent" targetRef="Gateway_X_Decision" />
    <bpmn:sequenceFlow id="Flow_X04" name="Conforme" sourceRef="Gateway_X_Decision" targetRef="Activity_X_SendBiometrie">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_X_Agent.result.data.decision == "conforme"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X05" name="Correction" sourceRef="Gateway_X_Decision" targetRef="Gateway_X_MaxCorrections">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_X_Agent.result.data.decision == "correction"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X06" name="Rejet" sourceRef="Gateway_X_Decision" targetRef="Activity_X_SendReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.Activity_X_Agent.result.data.decision == "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_CorrOK" name="Non (≤3)" sourceRef="Gateway_X_MaxCorrections" targetRef="Activity_X_SendCorrection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.nbCorrections ?? 0) &lt; 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_CorrMax" name="Oui (>3)" sourceRef="Gateway_X_MaxCorrections" targetRef="Activity_X_SendReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.nbCorrections ?? 0) >= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X07" sourceRef="Activity_X_SendCorrection" targetRef="Activity_X_RecvResub" />
    <bpmn:sequenceFlow id="Flow_X_ResubToAgent" sourceRef="Activity_X_RecvResub" targetRef="Activity_X_Agent" />
    <bpmn:sequenceFlow id="Flow_X_TimerToReject" name="Délai expiré" sourceRef="Event_X_TimerResub" targetRef="Activity_X_SendReject" />
    <bpmn:sequenceFlow id="Flow_X08" sourceRef="Activity_X_SendBiometrie" targetRef="Activity_X_Biometrie" />
    <bpmn:sequenceFlow id="Flow_X09" sourceRef="Activity_X_Biometrie" targetRef="Activity_X_SendConvocCode" />
    <bpmn:sequenceFlow id="Flow_X10" sourceRef="Activity_X_SendConvocCode" targetRef="Activity_X_ResultCode" />
    <bpmn:sequenceFlow id="Flow_X11" sourceRef="Activity_X_ResultCode" targetRef="Activity_X_SendResultCode" />
    <bpmn:sequenceFlow id="Flow_X12" sourceRef="Activity_X_SendResultCode" targetRef="Gateway_X_CodeOK" />
    <bpmn:sequenceFlow id="Flow_X_CodePass" name="Réussi (≥35/40)" sourceRef="Gateway_X_CodeOK" targetRef="Activity_X_SendConvocPratique">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.Activity_X_ResultCode.result.data.noteCode ?? 0) >= 35</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_CodeFail" name="Échoué (&lt;35/40)" sourceRef="Gateway_X_CodeOK" targetRef="Gateway_X_CodeRetry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.Activity_X_ResultCode.result.data.noteCode ?? 0) &lt; 35</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_CodeRetry" name="Peut réessayer" sourceRef="Gateway_X_CodeRetry" targetRef="Activity_X_SendConvocCode">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.nbTentativesCode ?? 0) &lt; 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_CodeReject" name="Épuisées" sourceRef="Gateway_X_CodeRetry" targetRef="Activity_X_SendReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.nbTentativesCode ?? 0) >= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X13" sourceRef="Activity_X_SendConvocPratique" targetRef="Activity_X_ResultPratique" />
    <bpmn:sequenceFlow id="Flow_X14" sourceRef="Activity_X_ResultPratique" targetRef="Activity_X_SendResultPratique" />
    <bpmn:sequenceFlow id="Flow_X15" sourceRef="Activity_X_SendResultPratique" targetRef="Gateway_X_PratiqueOK" />
    <bpmn:sequenceFlow id="Flow_X_PratiquePass" name="Réussi (≥10/20)" sourceRef="Gateway_X_PratiqueOK" targetRef="Activity_X_ChefValidation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.Activity_X_ResultPratique.result.data.notePratique ?? 0) >= 10</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_PratiqueFail" name="Échoué (&lt;10/20)" sourceRef="Gateway_X_PratiqueOK" targetRef="Gateway_X_PratiqueRetry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.Activity_X_ResultPratique.result.data.notePratique ?? 0) &lt; 10</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_PratiqueRetry" name="Peut réessayer" sourceRef="Gateway_X_PratiqueRetry" targetRef="Activity_X_SendConvocPratique">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.nbTentativesPratique ?? 0) &lt; 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_PratiqueReject" name="Épuisées" sourceRef="Gateway_X_PratiqueRetry" targetRef="Activity_X_SendReject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">($this.data.nbTentativesPratique ?? 0) >= 3</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X16" sourceRef="Activity_X_ChefValidation" targetRef="Activity_X_SendAccept" />
    <bpmn:sequenceFlow id="Flow_X17" sourceRef="Activity_X_SendAccept" targetRef="Activity_X_NotifAccept" />
    <bpmn:sequenceFlow id="Flow_X18" sourceRef="Activity_X_NotifAccept" targetRef="Event_X_EndSuccess" />
    <bpmn:sequenceFlow id="Flow_X19" sourceRef="Activity_X_SendReject" targetRef="Activity_X_NotifReject" />
    <bpmn:sequenceFlow id="Flow_X20" sourceRef="Activity_X_NotifReject" targetRef="Event_X_EndReject" />
  </bpmn:process>
