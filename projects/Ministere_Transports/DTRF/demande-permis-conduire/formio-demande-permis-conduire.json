    "components": [
        {
            "title": "Description du service",
            "label": "Page 1",
            "type": "panel",
            "key": "stepIntro",
            "components": [
                {
                    "label": "Styles CSS",
                    "tag": "style",
                    "content": ".sfc-card{position:sticky;top:20px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:24px;font-family:'Segoe UI',Roboto,sans-serif;box-shadow:0 4px 6px -1px rgba(0,0,0,0.05);}.sfc-card h3{font-size:18px;font-weight:700;color:#111827;margin:0 0 4px;}.sfc-card .sfc-subtitle{font-size:13.5px;color:#4b5563;margin:0 0 18px;line-height:1.5;}.sfc-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;font-size:13.5px;color:#374151;line-height:1.5;}.sfc-row .sfc-ico{flex-shrink:0;width:20px;text-align:center;font-size:15px;margin-top:1px;color:#4b5563;}.sfc-row a{color:#3b82f6;text-decoration:none;}.sfc-row a:hover{text-decoration:underline;}.sfc-row strong{color:#111827;font-weight:600;}.sfc-stitle{font-size:16px;font-weight:700;color:#111827;margin:20px 0 12px;padding-top:16px;border-top:1px solid #e5e7eb;}.sfc-boxes{display:flex;gap:10px;margin-bottom:14px;width:100%;}.sfc-box{flex:1;background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:12px;}.sfc-box .sfc-lbl{font-size:11.5px;color:#6b7280;font-weight:500;margin:0 0 6px;line-height:1.3;}.sfc-box .sfc-val{font-size:14px;font-weight:700;color:#111827;margin:0;}.sfc-box .sfc-sub{font-size:11px;color:#9ca3af;font-weight:400;}.sfc-link{display:inline-flex;align-items:center;gap:6px;color:#16a34a;font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;margin-top:5px;}.sfc-link:hover{text-decoration:underline;}.sfc-link-ico{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;background:#16a34a;color:#fff;border-radius:50%;font-size:11px;font-weight:700;}",
                    "key": "stylesCssSidebar",
                    "type": "htmlelement"
                },
                {
                    "tag": "div",
                    "key": "stickyInjector",
                    "type": "htmlelement",
                    "customClass": "d-none",
                    "calculateValue": "if(typeof window.__sfcStickyDone==='undefined'){window.__sfcStickyDone=false;}function sfcApply(){var el=document.getElementById('sidebar-fournisseur');if(!el)return false;var col=el.closest('[class*=\"col-\"]');if(col){col.style.position='sticky';col.style.top='20px';col.style.alignSelf='flex-start';}var row=el.closest('.row');if(row){row.style.alignItems='flex-start';row.style.display='flex';}return true;}if(!window.__sfcStickyDone){if(sfcApply()){window.__sfcStickyDone=true;}else{setTimeout(function(){sfcApply();window.__sfcStickyDone=true;},500);setTimeout(function(){sfcApply();},1500);}}"
                },
                {
                    "label": "Columns",
                    "columns": [
                        {
                            "components": [
                                {
                                    "tag": "h2",
                                    "content": "Demande de permis de conduire",
                                    "key": "titre",
                                    "type": "htmlelement"
                                },
                                {
                                    "tag": "div",
                                    "content": "<div style=\"display:flex;gap:20px;flex-wrap:wrap;margin-top:20px;\"><div style=\"flex:1;min-width:200px;background:#fff;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">&#9201;</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Délai de traitement</h3><p style=\"font-size:15px;color:#333;margin:0;\">5 jours ouvrés (vérification)</p></div><div style=\"flex:1;min-width:200px;background:#f9fafb;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">&#128176;</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Coût</h3><p style=\"font-size:15px;color:#333;margin:0;\">20 000 FCFA (inscription + délivrance)<br/>15 000 FCFA (duplicata)</p></div><div style=\"flex:1;min-width:200px;background:#f9fafb;border-radius:12px;padding:25px;box-shadow:0 2px 5px rgba(0,0,0,0.05);border:1px solid #f0f0f0;\"><div style=\"font-size:32px;margin-bottom:10px;\">&#128197;</div><h3 style=\"font-size:16px;font-weight:600;margin:0 0 5px;\">Validité</h3><p style=\"font-size:15px;color:#333;margin:0;\">10 ans (cat. A/B)<br/>5 ans (cat. C/D/E)</p></div></div>",
                                    "key": "infoPills",
                                    "type": "htmlelement"
                                },
                                {
                                    "tag": "div",
                                    "content": "<div style=\"font-size:22px;font-weight:700;margin:30px 0 10px;color:#000;\">Description</div><div style=\"font-size:16px;line-height:1.6;color:#333;margin-bottom:30px;\">Le permis de conduire est le titre officiel autorisant son titulaire à conduire un véhicule à moteur sur la voie publique au Togo. Il est délivré par la Direction des Transports Routiers et Ferroviaires (DTRF) après réussite aux épreuves théoriques et pratiques.</div><div style=\"font-size:22px;font-weight:700;margin-bottom:10px;color:#000;\">Personnes éligibles</div><div style=\"font-size:16px;line-height:1.6;color:#333;margin-bottom:30px;\">Tout citoyen togolais ou résident légal remplissant les conditions d'âge selon la catégorie demandée : 16 ans (cat. A), 18 ans (cat. B), 21 ans (cat. C/D/E avec permis B acquis).</div>",
                                    "key": "descriptionService",
                                    "type": "htmlelement"
                                },
                                {
                                    "tag": "div",
                                    "content": "<div style=\"background:#F8F8F8;border:1px solid #E5E5E5;border-radius:12px;padding:25px;margin-bottom:25px;\"><div style=\"font-size:20px;font-weight:700;margin-bottom:15px;color:#000;\">Conditions d'éligibilité</div><ul style=\"font-size:16px;color:#333;line-height:1.7;padding-left:20px;margin:0;\"><li>Avoir l'âge minimum requis selon la catégorie (16, 18 ou 21 ans)</li><li>Fournir un certificat médical d'aptitude à la conduite (< 3 mois)</li><li>Avoir suivi la formation dans une auto-école agréée par la DTRF</li><li>Pour les catégories C, D, E : posséder un permis de catégorie B</li></ul></div>",
                                    "key": "conditionsEligibilite",
                                    "type": "htmlelement"
                                },
                                {
                                    "tag": "div",
                                    "content": "<div style=\"background:#F8F8F8;border:1px solid #E5E5E5;border-radius:12px;padding:25px;margin-bottom:25px;\"><div style=\"font-size:20px;font-weight:700;margin-bottom:15px;color:#000;\">Pièces à fournir</div><ul style=\"font-size:16px;color:#333;line-height:1.7;padding-left:20px;margin:0;\"><li>Copie de la pièce d'identité nationale ou passeport (en cours de validité)</li><li>Copie de l'acte de naissance</li><li>Certificat médical d'aptitude à la conduite (daté de moins de 3 mois)</li><li>Attestation de formation de l'auto-école agréée</li><li>4 photos d'identité format 4x4 cm</li><li><em>Si duplicata :</em> Déclaration de perte/vol (police ou gendarmerie)</li></ul></div>",
                                    "key": "piecesAFournir",
                                    "type": "htmlelement"
                                },
                                {
                                    "tag": "div",
                                    "content": "<div style=\"font-size:22px;font-weight:700;margin-bottom:20px;color:#000;\">Étapes de la démarche</div><div style=\"display:flex;align-items:flex-start;margin-bottom:15px;\"><div style=\"width:28px;height:28px;min-width:28px;background:#1BAE4A;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px;font-size:16px;\">1</div><div style=\"font-size:16px;line-height:1.6;color:#333;\">Remplissez le formulaire en ligne et uploadez vos pièces justificatives</div></div><div style=\"display:flex;align-items:flex-start;margin-bottom:15px;\"><div style=\"width:28px;height:28px;min-width:28px;background:#1BAE4A;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px;font-size:16px;\">2</div><div style=\"font-size:16px;line-height:1.6;color:#333;\">Payez les frais en ligne (Flooz, TMoney, Visa, Mastercard)</div></div><div style=\"display:flex;align-items:flex-start;margin-bottom:15px;\"><div style=\"width:28px;height:28px;min-width:28px;background:#1BAE4A;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px;font-size:16px;\">3</div><div style=\"font-size:16px;line-height:1.6;color:#333;\">Présentez-vous à la DTRF pour le relevé biométrique (sur convocation)</div></div><div style=\"display:flex;align-items:flex-start;margin-bottom:15px;\"><div style=\"width:28px;height:28px;min-width:28px;background:#1BAE4A;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px;font-size:16px;\">4</div><div style=\"font-size:16px;line-height:1.6;color:#333;\">Passez les épreuves théoriques (code) et pratiques (conduite)</div></div><div style=\"display:flex;align-items:flex-start;margin-bottom:15px;\"><div style=\"width:28px;height:28px;min-width:28px;background:#1BAE4A;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:12px;font-size:16px;\">5</div><div style=\"font-size:16px;line-height:1.6;color:#333;\">Retirez votre permis au bureau DTRF de votre choix</div></div>",
                                    "key": "etapesProcessus",
                                    "type": "htmlelement"
                                }
                            ],
                            "width": 8,
                            "size": "md"
                        },
                        {
                            "components": [
                                {
                                    "tag": "div",
                                    "content": "<div class=\"sfc-card\" id=\"sidebar-fournisseur\"><h3>Fournisseur de service</h3><p class=\"sfc-subtitle\">Direction des Transports Routiers et Ferroviaires (DTRF)<br/>Ministère des Transports</p><div class=\"sfc-row\"><span class=\"sfc-ico\">&#128222;</span><span><strong>Téléphone :</strong> (+228) 22 21 XX XX</span></div><div class=\"sfc-row\"><span class=\"sfc-ico\">&#9993;</span><span><strong>Email :</strong> dtrf@transports.gouv.tg</span></div><div class=\"sfc-row\"><span class=\"sfc-ico\">&#128205;</span><span><strong>Adresse :</strong> Boulevard du Mono, Lomé, Togo</span></div><div class=\"sfc-row\"><span class=\"sfc-ico\">&#128336;</span><span><strong>Ouverture :</strong> Lun – Ven, 07h30 – 15h30</span></div><div class=\"sfc-row\"><span class=\"sfc-ico\">&#127760;</span><span><strong>Bureaux régionaux :</strong> Kara, Atakpamé, Sokodé, Dapaong</span></div><h3 class=\"sfc-stitle\">Statistiques</h3><div class=\"sfc-boxes\"><div class=\"sfc-box\"><p class=\"sfc-lbl\">Permis délivrés / an</p><p class=\"sfc-val\">~8 000</p><p class=\"sfc-sub\">Toutes catégories</p></div><div class=\"sfc-box\"><p class=\"sfc-lbl\">Délai moyen</p><p class=\"sfc-val\">5 <span style=\"font-size:12px;font-weight:normal;\">Jours</span></p><p class=\"sfc-sub\">Vérification dossier</p></div></div><a href=\"#\" class=\"sfc-link\"><span class=\"sfc-link-ico\">&#10148;</span> Voir les statistiques détaillées</a></div>",
                                    "key": "sidebarFournisseur",
                                    "type": "htmlelement"
                                }
                            ],
                            "width": 4,
                            "size": "md"
                        }
                    ],
                    "key": "columnsIntro",
                    "type": "columns"
                }
            ]
        },
        {
            "title": "Informations personnelles",
            "type": "panel",
            "key": "stepIdentite",
            "components": [
                {
                    "type": "radio",
                    "label": "Type de demande",
                    "key": "typeDemande",
                    "input": true,
                    "values": [
                        { "label": "Première inscription à l'examen", "value": "premiereInscription" },
                        { "label": "Duplicata (perte ou vol)", "value": "duplicata" }
                    ],
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "Ce champ est obligatoire" }
                },
                {
                    "type": "select",
                    "label": "Catégorie de permis demandée",
                    "key": "categoriePermis",
                    "input": true,
                    "data": {
                        "values": [
                            { "label": "A — Motocyclettes (16 ans min.)", "value": "A" },
                            { "label": "B — Véhicules légers (18 ans min.)", "value": "B" },
                            { "label": "C — Poids lourds (21 ans min., permis B requis)", "value": "C" },
                            { "label": "D — Transport en commun (21 ans min., permis B requis)", "value": "D" },
                            { "label": "E — Remorques (21 ans min., permis B requis)", "value": "E" }
                        ]
                    },
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "Ce champ est obligatoire" }
                },
                {
                    "type": "textfield",
                    "label": "Nom de famille",
                    "key": "nom",
                    "input": true,
                    "defaultValue": "{{ config.users.lastName }}",
                    "validate": { "required": true, "minLength": 2 },
                    "validateOn": "blur",
                    "errors": { "required": "Le nom de famille est obligatoire", "minLength": "Le nom doit comporter au moins 2 caractères" },
                    "logic": [
                        {
                            "name": "Verrouillage e-ID si non vide",
                            "trigger": { "type": "javascript", "javascript": "result = !!(data.nom && String(data.nom).trim().length > 0);" },
                            "actions": [
                                { "name": "Désactiver champ", "type": "property", "property": { "label": "Disabled", "value": "disabled", "type": "boolean" }, "state": true }
                            ]
                        }
                    ]
                },
                {
                    "type": "textfield",
                    "label": "Prénom(s)",
                    "key": "prenom",
                    "input": true,
                    "defaultValue": "{{ config.users.firstName }}",
                    "validate": { "required": true, "minLength": 2 },
                    "validateOn": "blur",
                    "errors": { "required": "Le prénom est obligatoire", "minLength": "Le prénom doit comporter au moins 2 caractères" },
                    "logic": [
                        {
                            "name": "Verrouillage e-ID si non vide",
                            "trigger": { "type": "javascript", "javascript": "result = !!(data.prenom && String(data.prenom).trim().length > 0);" },
                            "actions": [
                                { "name": "Désactiver champ", "type": "property", "property": { "label": "Disabled", "value": "disabled", "type": "boolean" }, "state": true }
                            ]
                        }
                    ]
                },
                {
                    "type": "datetime",
                    "label": "Date de naissance",
                    "key": "dateNaissance",
                    "input": true,
                    "format": "dd/MM/yyyy",
                    "enableDate": true,
                    "enableTime": false,
                    "validate": {
                        "required": true,
                        "custom": "var birthDate = new Date(input); var today = new Date(); var age = today.getFullYear() - birthDate.getFullYear(); var m = today.getMonth() - birthDate.getMonth(); if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) { age--; } var minAge = 18; if (data.categoriePermis === 'A') minAge = 16; else if (['C','D','E'].includes(data.categoriePermis)) minAge = 21; valid = (age >= minAge) ? true : 'Vous devez avoir au moins ' + minAge + ' ans pour la catégorie ' + (data.categoriePermis || '') + '.';"
                    },
                    "validateOn": "blur",
                    "errors": { "required": "La date de naissance est obligatoire" }
                },
                {
                    "type": "textfield",
                    "label": "Lieu de naissance",
                    "key": "lieuNaissance",
                    "input": true,
                    "validate": { "required": true, "minLength": 2 },
                    "validateOn": "blur",
                    "errors": { "required": "Le lieu de naissance est obligatoire" }
                },
                {
                    "type": "select",
                    "label": "Nationalité",
                    "key": "nationalite",
                    "input": true,
                    "dataSrc": "url",
                    "data": { "url": "{{ config.apiBaseUrl }}/references/nationalities" },
                    "valueProperty": "code",
                    "template": "<span>{{ item.libelle }}</span>",
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "La nationalité est obligatoire" }
                },
                {
                    "type": "radio",
                    "label": "Sexe",
                    "key": "sexe",
                    "input": true,
                    "values": [
                        { "label": "Masculin", "value": "masculin" },
                        { "label": "Féminin", "value": "feminin" }
                    ],
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "Ce champ est obligatoire" }
                },
                {
                    "type": "phoneNumber",
                    "label": "Numéro de téléphone",
                    "key": "telephone",
                    "input": true,
                    "defaultValue": "{{ config.users.phone }}",
                    "validate": { "required": true, "pattern": "^(\\+228)?[0-9]{8}$" },
                    "validateOn": "blur",
                    "errors": { "required": "Le numéro de téléphone est obligatoire", "pattern": "Format attendu : +228XXXXXXXX ou 8 chiffres" },
                    "logic": [
                        {
                            "name": "Verrouillage e-ID si non vide",
                            "trigger": { "type": "javascript", "javascript": "result = !!(data.telephone && String(data.telephone).trim().length > 0);" },
                            "actions": [
                                { "name": "Désactiver champ", "type": "property", "property": { "label": "Disabled", "value": "disabled", "type": "boolean" }, "state": true }
                            ]
                        }
                    ]
                },
                {
                    "type": "email",
                    "label": "Adresse email",
                    "key": "email",
                    "input": true,
                    "defaultValue": "{{ config.users.email }}",
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "L'adresse email est obligatoire" },
                    "logic": [
                        {
                            "name": "Verrouillage e-ID si non vide",
                            "trigger": { "type": "javascript", "javascript": "result = !!(data.email && String(data.email).trim().length > 0);" },
                            "actions": [
                                { "name": "Désactiver champ", "type": "property", "property": { "label": "Disabled", "value": "disabled", "type": "boolean" }, "state": true }
                            ]
                        }
                    ]
                },
                {
                    "type": "textfield",
                    "label": "Adresse de résidence",
                    "key": "adresseResidence",
                    "input": true,
                    "validate": { "required": true, "minLength": 5 },
                    "validateOn": "blur",
                    "errors": { "required": "L'adresse de résidence est obligatoire" }
                },
                {
                    "type": "select",
                    "label": "Ville / Commune",
                    "key": "ville",
                    "input": true,
                    "dataSrc": "url",
                    "data": { "url": "{{ config.apiBaseUrl }}/references/cities" },
                    "valueProperty": "code",
                    "template": "<span>{{ item.libelle }}</span>",
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "La ville est obligatoire" }
                },
                {
                    "type": "select",
                    "label": "Région",
                    "key": "region",
                    "input": true,
                    "dataSrc": "url",
                    "data": { "url": "{{ config.apiBaseUrl }}/references/regions" },
                    "valueProperty": "code",
                    "template": "<span>{{ item.libelle }}</span>",
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "La région est obligatoire" }
                }
            ]
        },
        {
            "title": "Informations sur la formation",
            "type": "panel",
            "key": "stepFormation",
            "components": [
                {
                    "type": "textfield",
                    "label": "Nom de l'auto-école",
                    "key": "nomAutoEcole",
                    "input": true,
                    "validate": { "required": true, "minLength": 3 },
                    "validateOn": "blur",
                    "errors": { "required": "Le nom de l'auto-école est obligatoire", "minLength": "3 caractères minimum" },
                    "conditional": { "show": true, "when": "typeDemande", "eq": "premiereInscription" }
                },
                {
                    "type": "select",
                    "label": "Ville de l'auto-école",
                    "key": "villeAutoEcole",
                    "input": true,
                    "dataSrc": "url",
                    "data": { "url": "{{ config.apiBaseUrl }}/references/cities" },
                    "valueProperty": "code",
                    "template": "<span>{{ item.libelle }}</span>",
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "La ville de l'auto-école est obligatoire" },
                    "conditional": { "show": true, "when": "typeDemande", "eq": "premiereInscription" }
                },
                {
                    "type": "textfield",
                    "label": "Numéro d'attestation de formation",
                    "key": "numeroAttestation",
                    "input": true,
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "Le numéro d'attestation est obligatoire" },
                    "conditional": { "show": true, "when": "typeDemande", "eq": "premiereInscription" }
                },
                {
                    "type": "select",
                    "label": "Bureau de retrait souhaité",
                    "key": "lieuRetraitSouhaite",
                    "input": true,
                    "data": {
                        "values": [
                            { "label": "Lomé (DTRF siège)", "value": "lome" },
                            { "label": "Kara", "value": "kara" },
                            { "label": "Atakpamé", "value": "atakpame" },
                            { "label": "Sokodé", "value": "sokode" },
                            { "label": "Dapaong", "value": "dapaong" }
                        ]
                    },
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "Veuillez choisir un bureau de retrait" }
                },
                {
                    "type": "radio",
                    "label": "Possédez-vous déjà un permis de catégorie B ?",
                    "key": "permisExistant",
                    "input": true,
                    "values": [
                        { "label": "Oui", "value": "oui" },
                        { "label": "Non", "value": "non" }
                    ],
                    "validate": {
                        "required": true,
                        "custom": "if (['C','D','E'].includes(data.categoriePermis) && input === 'non') { valid = 'Un permis de catégorie B est requis pour demander les catégories C, D ou E.'; } else { valid = true; }"
                    },
                    "validateOn": "blur",
                    "errors": { "required": "Ce champ est obligatoire" },
                    "customConditional": "show = ['C','D','E'].includes(data.categoriePermis);"
                },
                {
                    "type": "textfield",
                    "label": "Numéro du permis existant",
                    "key": "numeroPermisExistant",
                    "input": true,
                    "validate": { "required": true },
                    "validateOn": "blur",
                    "errors": { "required": "Le numéro du permis existant est obligatoire" },
                    "customConditional": "show = data.permisExistant === 'oui' && ['C','D','E'].includes(data.categoriePermis);"
                }
            ]
        },
        {
            "title": "Pièces justificatives",
            "type": "panel",
            "key": "stepPieces",
            "components": [
                {
                    "type": "file",
                    "label": "Copie de la pièce d'identité",
                    "key": "pieceIdentite",
                    "input": true,
                    "storage": "base64",
                    "filePattern": ".pdf,.jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "validate": { "required": true },
                    "errors": { "required": "La pièce d'identité est obligatoire" }
                },
                {
                    "type": "file",
                    "label": "Copie de l'acte de naissance",
                    "key": "acteNaissance",
                    "input": true,
                    "storage": "base64",
                    "filePattern": ".pdf,.jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "validate": { "required": true },
                    "errors": { "required": "L'acte de naissance est obligatoire" }
                },
                {
                    "type": "file",
                    "label": "Certificat médical d'aptitude à la conduite",
                    "key": "certificatMedical",
                    "input": true,
                    "storage": "base64",
                    "filePattern": ".pdf,.jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "validate": { "required": true },
                    "errors": { "required": "Le certificat médical est obligatoire (daté de moins de 3 mois)" },
                    "conditional": { "show": true, "when": "typeDemande", "eq": "premiereInscription" }
                },
                {
                    "type": "file",
                    "label": "Attestation de formation auto-école",
                    "key": "attestationFormation",
                    "input": true,
                    "storage": "base64",
                    "filePattern": ".pdf,.jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "validate": { "required": true },
                    "errors": { "required": "L'attestation de formation est obligatoire" },
                    "conditional": { "show": true, "when": "typeDemande", "eq": "premiereInscription" }
                },
                {
                    "type": "file",
                    "label": "Photos d'identité (4x4 cm)",
                    "key": "photosIdentite",
                    "input": true,
                    "storage": "base64",
                    "multiple": true,
                    "filePattern": ".jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "validate": { "required": true },
                    "errors": { "required": "Les photos d'identité sont obligatoires (4 photos)" }
                },
                {
                    "type": "file",
                    "label": "Déclaration de perte ou de vol",
                    "key": "declarationPerte",
                    "input": true,
                    "storage": "base64",
                    "filePattern": ".pdf,.jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "validate": { "required": true },
                    "errors": { "required": "La déclaration de perte/vol est obligatoire pour un duplicata" },
                    "conditional": { "show": true, "when": "typeDemande", "eq": "duplicata" }
                },
                {
                    "type": "file",
                    "label": "Copie du permis perdu (si disponible)",
                    "key": "copiePermisPerdu",
                    "input": true,
                    "storage": "base64",
                    "filePattern": ".pdf,.jpg,.jpeg,.png",
                    "fileMaxSize": "2MB",
                    "conditional": { "show": true, "when": "typeDemande", "eq": "duplicata" }
                }
            ]
        },
        {
            "title": "Paiement",
            "type": "panel",
            "key": "stepPaiement",
            "components": [
                {
                    "type": "htmlelement",
                    "tag": "div",
                    "key": "recapMontant",
                    "content": "<div style=\"background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:25px;margin-bottom:20px;\"><h3 style=\"font-size:20px;font-weight:700;color:#166534;margin:0 0 15px;\">Récapitulatif des frais</h3><div id=\"montantDisplay\" style=\"font-size:16px;line-height:1.8;color:#333;\"></div></div>",
                    "refreshOnChange": true,
                    "calculateValue": "var el = document.getElementById('montantDisplay'); if(el){ if(data.typeDemande === 'premiereInscription'){ el.innerHTML = '<p><strong>Inscription à l\\'examen :</strong> 5 000 FCFA</p><p><strong>Droits de délivrance :</strong> 15 000 FCFA</p><hr style=\"border-color:#bbf7d0;\"/><p style=\"font-size:20px;font-weight:700;color:#166534;\">Total : 20 000 FCFA</p>'; } else if(data.typeDemande === 'duplicata'){ el.innerHTML = '<p><strong>Frais de duplicata :</strong> 15 000 FCFA</p><hr style=\"border-color:#bbf7d0;\"/><p style=\"font-size:20px;font-weight:700;color:#166534;\">Total : 15 000 FCFA</p>'; } else { el.innerHTML = '<p style=\"color:#6b7280;\">Veuillez sélectionner un type de demande pour afficher le montant.</p>'; }}"
                },
                {
                    "type": "hidden",
                    "key": "montantPaiement",
                    "input": true,
                    "calculateValue": "value = (data.typeDemande === 'premiereInscription') ? 20000 : (data.typeDemande === 'duplicata') ? 15000 : 0;"
                }
            ]
        },
        {
            "title": "Récapitulatif et soumission",
            "type": "panel",
            "key": "stepRecapitulatif",
            "components": [
                {
                    "label": "HTML",
                    "tag": "div",
                    "attrs": [{ "attr": "id", "value": "recapDisplay" }],
                    "refreshOnChange": false,
                    "key": "htmlRecapitulatifFinal",
                    "logic": [
                        {
                            "name": "logiqueConstruction",
                            "trigger": { "type": "javascript", "javascript": "result = true;" },
                            "actions": [
                                {
                                    "name": "actionJS",
                                    "type": "customAction",
                                    "customAction": "const recapDiv = document.getElementById(\"recapDisplay\");\nlet list_of_datagrid = [];\nlet data_stock = [];\nconst exclude = [\"button\", \"file\", \"container\", \"panel\", \"datagrid\"];\nconst excludeKeys = [\"luEtApprouve\"];\nconst includesLabelForSelect = [\"libelle\", \"label\"];\n\nutils.eachComponent(form.components, (component, path) => {\n  let splitted_path = path.split(\".\");\n  let skip = false;\n  if (\n    !exclude.includes(component.type) &&\n    !excludeKeys.includes(component.key) &&\n    !component.hidden &&\n    ![null, undefined, \"\", [], {}].includes(data[component.key]) &&\n    !(typeof data[component.key] === \"string\" && [\"\", \"null\", \"undefined\"].includes(data[component.key]))\n  ) {\n    if (component.type === \"datagrid\") {\n      list_of_datagrid.push(component.key);\n    } else {\n      if (splitted_path.length >= 2 && list_of_datagrid.includes(splitted_path[splitted_path.length - 2])) {\n        skip = true;\n      }\n    }\n    if (!skip) {\n      data_stock.push({ key: component.key, label: component.label, value: data[component.key] || (component.type === \"datagrid\" ? [] : \"\"), type: component.type, components: component.components || \"\" });\n    }\n  }\n}, false);\n\nlet ourTable = `<style>.recap-container{width:100%;margin:0 auto;}.recap-table{width:100%;border-collapse:collapse;}.recap-table thead th{background-color:#F8F9FA;color:#212529;font-weight:700;padding:12px;border:1px solid #DEE2E6;text-align:left;font-family:-apple-system,system-ui,sans-serif;font-size:15px;}.recap-table th,.recap-table td{border:1px solid #DEE2E6;padding:12px;text-align:left;font-size:14px;font-family:-apple-system,system-ui,sans-serif;}.recap-table td:first-child{width:6%;text-align:center;color:#6C757D;}.recap-table td:nth-child(2){width:44%;font-weight:600;color:#212529;}.recap-table td:last-child{width:50%;color:#495057;}.datagrid-title{background-color:#E9ECEF;}</style><div class=\"recap-container\"><table class=\"recap-table\"><thead><tr><th>N°</th><th>Donnée demandée</th><th>Votre saisie</th></tr></thead><tbody>`;\n\nlet index = 1;\ndata_stock.forEach((elmt) => {\n  if (Array.isArray(elmt.value) && elmt.type === \"datagrid\") {\n    ourTable += `<tr><td colspan=\"3\" class=\"datagrid-title\"><b>${elmt.label}</b></td></tr>`;\n  } else if (elmt.type === \"select\") {\n    let valueToDisplay;\n    if (typeof elmt.value === \"object\" && !Array.isArray(elmt.value)) {\n      const prop = includesLabelForSelect.find((p) => elmt.value[p] !== undefined);\n      valueToDisplay = prop ? elmt.value[prop] : JSON.stringify(elmt.value);\n    } else {\n      valueToDisplay = Array.isArray(elmt.value) ? elmt.value.join(\", \") : elmt.value;\n    }\n    ourTable += `<tr><td>${index++}</td><td>${elmt.label}</td><td><b>${valueToDisplay}</b></td></tr>`;\n  } else if (elmt.type === \"radio\") {\n    const radioComp = utils.getComponent(form.components, elmt.key);\n    let radioLabel = elmt.value;\n    if (radioComp && radioComp.values) {\n      const found = radioComp.values.find(v => v.value === elmt.value);\n      if (found) radioLabel = found.label;\n    }\n    ourTable += `<tr><td>${index++}</td><td>${elmt.label}</td><td><b>${radioLabel}</b></td></tr>`;\n  } else {\n    let finalVal = elmt.value;\n    if (elmt.type === \"datetime\") finalVal = new Date(elmt.value).toLocaleDateString('fr-TG');\n    ourTable += `<tr><td>${index++}</td><td>${elmt.label}</td><td><b>${finalVal}</b></td></tr>`;\n  }\n});\n\nourTable += `</tbody></table></div>`;\nrecapDiv.innerHTML = ourTable;"
                                }
                            ]
                        }
                    ],
                    "type": "htmlelement",
                    "input": false,
                    "tableView": false
                },
                {
                    "type": "checkbox",
                    "label": "Je certifie sur l'honneur que les informations fournies sont exactes et complètes.",
                    "key": "luEtApprouve",
                    "input": true,
                    "tableView": false,
                    "validate": { "required": true },
                    "errors": { "required": "Vous devez certifier l'exactitude des informations avant de soumettre." }
                }
            ]
        }
    ],
    "actions": [
        {
            "name": "calculateCosts",
            "type": "calculateCosts",
            "condition": "true",
            "algorithm": "data.typeDemande === 'premiereInscription' ? 20000 : 15000"
        },
        {
            "name": "publishToRabbitMQ",
            "type": "rabbitmq",
            "topic": "submissions.topic",
            "payload": "{{ submission.data }}"
        }
    ]
}
