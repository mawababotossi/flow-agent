<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_FormActLivre" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.17.0">

  <bpmn:message id="MSG_FORM_ACT_LIVRE_START" name="MSG_FORM_ACT_LIVRE_START" />
  <bpmn:message id="MSG_FORM_ACT_LIVRE_RETURN" name="MSG_FORM_ACT_LIVRE_RETURN" />
  <bpmn:message id="MSG_FORM_ACT_LIVRE_RESUB" name="MSG_FORM_ACT_LIVRE_RESUB" />

  <bpmn:collaboration id="Collaboration_FormActLivre">
    <bpmn:participant id="Participant_Portal" name="XPORTAL" processRef="Process_Portal" />
    <bpmn:participant id="Participant_Xflow" name="XFLOW" processRef="Process_Xflow" camunda:versionTag="1.0" camunda:historyTimeToLive="180" />
    <bpmn:messageFlow id="MF_Submit" name="Soumission" sourceRef="SendTask_P_Submit" targetRef="Event_X_Start" />
    <bpmn:messageFlow id="MF_Return" name="Retour XFlow" sourceRef="SendTask_X_ReturnCorrection" targetRef="ReceiveTask_P_Wait" />
    <bpmn:messageFlow id="MF_Return2" name="Retour Rejet" sourceRef="SendTask_X_ReturnRejet" targetRef="ReceiveTask_P_Wait" />
    <bpmn:messageFlow id="MF_Return3" name="Retour Accepte" sourceRef="SendTask_X_ReturnAccepte" targetRef="ReceiveTask_P_Wait" />
    <bpmn:messageFlow id="MF_Resub" name="Resoumission" sourceRef="SendTask_P_Resub" targetRef="ReceiveTask_X_Resub" />
  </bpmn:collaboration>

  <!-- ===== POOL XPORTAL ===== -->
  <bpmn:process id="Process_Portal" isExecutable="true" camunda:versionTag="1">

    <bpmn:startEvent id="Event_P_Start" name="Candidature initiée" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Le candidat soumet sa candidature via le formulaire en ligne</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">PORTAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_P_ToSubmit</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="SendTask_P_Submit" name="Envoyer candidature à XFlow" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:StartEvent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_FORM_ACT_LIVRE_START</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.Event_P_Start.parameters</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_ToSubmit</bpmn:incoming>
      <bpmn:outgoing>Flow_P_ToWait</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_P_Wait" name="Attendre décision XFlow" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_FORM_ACT_LIVRE_RETURN" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Suivi de votre candidature</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">1</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_ToWait</bpmn:incoming>
      <bpmn:incoming>Flow_P_ResubToWait</bpmn:incoming>
      <bpmn:outgoing>Flow_P_ToGateway</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_P_Action" name="Action retour ?">
      <bpmn:incoming>Flow_P_ToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_P_Correction</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_Accepte</bpmn:outgoing>
      <bpmn:outgoing>Flow_P_Rejete</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_P_Correction" name="Correction" sourceRef="Gateway_P_Action" targetRef="UserTask_P_Correction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.ReceiveTask_P_Wait.result.data.action == "correction"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P_Accepte" name="Accepté" sourceRef="Gateway_P_Action" targetRef="EndEvent_P_Accepte">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.ReceiveTask_P_Wait.result.data.action == "accepte"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_P_Rejete" name="Rejeté" sourceRef="Gateway_P_Action" targetRef="EndEvent_P_Rejete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">$this.data.ReceiveTask_P_Wait.result.data.action == "rejete"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:userTask id="UserTask_P_Correction" name="Corriger le dossier" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:formKey="formation-acteurs-livre" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Le candidat corrige les erreurs signalées</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey">formation-acteurs-livre</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_P_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments">${}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Corriger votre candidature</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder">2</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_Correction</bpmn:incoming>
      <bpmn:outgoing>Flow_P_ToResub</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sendTask id="SendTask_P_Resub" name="Renvoyer dossier corrigé" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">peer-xflow-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_FORM_ACT_LIVRE_RESUB</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">$this.data.UserTask_P_Correction.result</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_P_ToResub</bpmn:incoming>
      <bpmn:outgoing>Flow_P_ResubToWait</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_P_Accepte" name="Candidature acceptée">
      <bpmn:incoming>Flow_P_Accepte</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_P_Rejete" name="Candidature rejetée">
      <bpmn:incoming>Flow_P_Rejete</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_P_ToSubmit" sourceRef="Event_P_Start" targetRef="SendTask_P_Submit" />
    <bpmn:sequenceFlow id="Flow_P_ToWait" sourceRef="SendTask_P_Submit" targetRef="ReceiveTask_P_Wait" />
    <bpmn:sequenceFlow id="Flow_P_ToGateway" sourceRef="ReceiveTask_P_Wait" targetRef="Gateway_P_Action" />
    <bpmn:sequenceFlow id="Flow_P_ToResub" sourceRef="UserTask_P_Correction" targetRef="SendTask_P_Resub" />
    <bpmn:sequenceFlow id="Flow_P_ResubToWait" sourceRef="SendTask_P_Resub" targetRef="ReceiveTask_P_Wait" />
  </bpmn:process>

  <!-- ===== POOL XFLOW ===== -->
  <bpmn:process id="Process_Xflow" isExecutable="true" camunda:versionTag="1">

    <bpmn:startEvent id="Event_X_Start" name="Réception candidature" camunda:modelerTemplate="tg.gouv.gnspd.startEvent" camunda:type="external" camunda:topic="flow-start">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdStepName">Début</camunda:inputParameter>
          <camunda:inputParameter name="gnspdDescription">Réception de la candidature depuis XPortal</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPriority">10</camunda:inputParameter>
          <camunda:inputParameter name="gnspdExecution">XFLOW</camunda:inputParameter>
          <camunda:inputParameter name="gnspdPaymentAmount">0</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationOperator">ADDITION</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCalculationVar1" />
          <camunda:inputParameter name="gnspdCalculationVar2" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
          <camunda:inputParameter name="development">{}</camunda:inputParameter>
          <camunda:inputParameter name="sandbox">{}</camunda:inputParameter>
          <camunda:inputParameter name="preproduction">{}</camunda:inputParameter>
          <camunda:inputParameter name="production">{}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:messageEventDefinition messageRef="MSG_FORM_ACT_LIVRE_START" />
      <bpmn:outgoing>Flow_X_ToNotifReception</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- B02: Notification accusé réception -->
    <bpmn:serviceTask id="ServiceTask_X_NotifReception" name="Notification accusé de réception" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TPL_FORM_ACT_LIVRE_RECEPTION_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TPL_FORM_ACT_LIVRE_RECEPTION_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TPL_FORM_ACT_LIVRE_RECEPTION_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToNotifReception</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToAgent</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- B03: Vérification conformité agent -->
    <bpmn:userTask id="UserTask_X_Verification" name="Vérification de conformité" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Vérifier la conformité du dossier : identité, pièces justificatives, cohérence catégorie/œuvre</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey">formation-acteurs-livre</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments">${"fileIdentite": this.data.Event_X_Start.parameters.submissionData.fileIdentite ?? null, "fileEbaucheTexte": this.data.Event_X_Start.parameters.submissionData.fileEbaucheTexte ?? null, "fileCatalogueEditeur": this.data.Event_X_Start.parameters.submissionData.fileCatalogueEditeur ?? null, "fileJustificatifExperience": this.data.Event_X_Start.parameters.submissionData.fileJustificatifExperience ?? null}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">agent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToAgent</bpmn:incoming>
      <bpmn:incoming>Flow_X_ResubToAgent</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToDecision</bpmn:outgoing>
    </bpmn:userTask>

    <!-- B03 gateway: Décision conformité -->
    <bpmn:exclusiveGateway id="Gateway_X_Decision" name="Décision conformité ?">
      <bpmn:incoming>Flow_X_ToDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Conforme</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_CorrectionNeeded</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_RejetConformite</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_X_Conforme" name="Conforme" sourceRef="Gateway_X_Decision" targetRef="UserTask_X_Jury">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.UserTask_X_Verification.result.submissionData.decision == 'oui' &amp;&amp; this.data.UserTask_X_Verification.result.submissionData.hasCorrections == 'non'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_CorrectionNeeded" name="Correction" sourceRef="Gateway_X_Decision" targetRef="ServiceTask_X_NotifCorrection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.UserTask_X_Verification.result.submissionData.decision == 'oui' &amp;&amp; this.data.UserTask_X_Verification.result.submissionData.hasCorrections == 'oui'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_RejetConformite" name="Rejeté" sourceRef="Gateway_X_Decision" targetRef="ServiceTask_X_NotifRejet">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.UserTask_X_Verification.result.submissionData.decision == 'non'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- B04: Notification correction -->
    <bpmn:serviceTask id="ServiceTask_X_NotifCorrection" name="Notification correction" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TPL_FORM_ACT_LIVRE_CORRECTION_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": this.data.UserTask_X_Verification.result.submissionData.motif ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TPL_FORM_ACT_LIVRE_CORRECTION_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref, "reason": this.data.UserTask_X_Verification.result.submissionData.motif ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TPL_FORM_ACT_LIVRE_CORRECTION_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref, "reason": this.data.UserTask_X_Verification.result.submissionData.motif ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_CorrectionNeeded</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToSendCorrection</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- B04b: Send correction order to Portal -->
    <bpmn:sendTask id="SendTask_X_ReturnCorrection" name="Envoyer ordre correction au portail" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_FORM_ACT_LIVRE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "correction", "motif": this.data.UserTask_X_Verification.result.submissionData.motif ?? null, "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToSendCorrection</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToWaitResub</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- B04c: Wait for resubmission with 72h timer -->
    <bpmn:receiveTask id="ReceiveTask_X_Resub" name="Attendre resoumission" camunda:modelerTemplate="tg.gouv.gnspd.receiveTask" messageRef="MSG_FORM_ACT_LIVRE_RESUB" camunda:type="external" camunda:topic="flow-receive-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToWaitResub</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ResubToAgent</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:boundaryEvent id="BoundaryTimer_Resub" name="72h timeout" attachedToRef="ReceiveTask_X_Resub" cancelActivity="true">
      <bpmn:outgoing>Flow_X_TimeoutToRejet</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT72H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:sequenceFlow id="Flow_X_TimeoutToRejet" name="Timeout 72h" sourceRef="BoundaryTimer_Resub" targetRef="ServiceTask_X_NotifRejet" />

    <!-- B06: Évaluation jury -->
    <bpmn:userTask id="UserTask_X_Jury" name="Évaluation par le jury" camunda:modelerTemplate="tg.gouv.gnspd.userTask" camunda:type="external" camunda:topic="flow-user-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskDescription">Le jury évalue la qualité de l'œuvre et la pertinence du profil du candidat</camunda:inputParameter>
          <camunda:inputParameter name="gnspdHandlerType">publish_submission</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionFormkey">formation-acteurs-livre</camunda:inputParameter>
          <camunda:inputParameter name="gnspdSubmissionData">$this.data.Event_X_Start.parameters.submissionData</camunda:inputParameter>
          <camunda:inputParameter name="gnspdAttachments">${"fileIdentite": this.data.Event_X_Start.parameters.submissionData.fileIdentite ?? null, "fileEbaucheTexte": this.data.Event_X_Start.parameters.submissionData.fileEbaucheTexte ?? null}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">agent</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Conforme</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToJuryDecision</bpmn:outgoing>
    </bpmn:userTask>

    <!-- B06 gateway: Décision jury -->
    <bpmn:exclusiveGateway id="Gateway_X_Jury" name="Sélectionné ?">
      <bpmn:incoming>Flow_X_ToJuryDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_X_Selectionne</bpmn:outgoing>
      <bpmn:outgoing>Flow_X_NonSelectionne</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_X_Selectionne" name="Sélectionné" sourceRef="Gateway_X_Jury" targetRef="ServiceTask_X_NotifSelection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.UserTask_X_Jury.result.submissionData.decision == 'oui'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_X_NonSelectionne" name="Non sélectionné" sourceRef="Gateway_X_Jury" targetRef="ServiceTask_X_NotifNonSelection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="javascript">this.data.UserTask_X_Jury.result.submissionData.decision == 'non'</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- B07: Notification sélection -->
    <bpmn:serviceTask id="ServiceTask_X_NotifSelection" name="Notification sélection" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TPL_FORM_ACT_LIVRE_SELECTION_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TPL_FORM_ACT_LIVRE_SELECTION_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TPL_FORM_ACT_LIVRE_SELECTION_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_Selectionne</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToSendAccepte</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- B09: Send acceptation to Portal -->
    <bpmn:sendTask id="SendTask_X_ReturnAccepte" name="Envoyer acceptation au portail" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_FORM_ACT_LIVRE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "accepte", "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToSendAccepte</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToEndAccepte</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- Non-selection notification -->
    <bpmn:serviceTask id="ServiceTask_X_NotifNonSelection" name="Notification non-sélection" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TPL_FORM_ACT_LIVRE_NONSELECTION_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref, "reason": this.data.UserTask_X_Jury.result.submissionData.motif ?? ""}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TPL_FORM_ACT_LIVRE_NONSELECTION_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TPL_FORM_ACT_LIVRE_NONSELECTION_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_NonSelectionne</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToSendRejetJury</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Send rejet jury to Portal -->
    <bpmn:sendTask id="SendTask_X_ReturnRejetJury" name="Envoyer non-sélection au portail" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_FORM_ACT_LIVRE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "rejete", "motif": this.data.UserTask_X_Jury.result.submissionData.motif ?? "Non sélectionné", "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToSendRejetJury</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToEndRejetJury</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- Notification rejet (conformité ou timeout) -->
    <bpmn:serviceTask id="ServiceTask_X_NotifRejet" name="Notification rejet définitif" camunda:modelerTemplate="tg.gouv.gnspd.sendNotification" camunda:type="external" camunda:topic="flow-notify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdNotifySendEmail">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyEmail">$this.data.applicant.email</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateEmail">TPL_FORM_ACT_LIVRE_REJET_EMAIL</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentEmail">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifySendSMS">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyPhone">$this.data.applicant.phone</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateSMS">TPL_FORM_ACT_LIVRE_REJET_SMS</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentSMS">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyInApp">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyTemplateInApp">TPL_FORM_ACT_LIVRE_REJET_INAPP</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyContentInApp">${"record_id": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdNotifyAttachment" />
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_RejetConformite</bpmn:incoming>
      <bpmn:incoming>Flow_X_TimeoutToRejet</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToSendRejet</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Send rejet to Portal -->
    <bpmn:sendTask id="SendTask_X_ReturnRejet" name="Envoyer rejet au portail" camunda:modelerTemplate="tg.gouv.gnspd.sendMessage" camunda:type="external" camunda:topic="flow-send-message">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdKafkaTopic">bpmn.commands</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTargetElementType">bpmn:ReceiveTask</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageDestination">ch-portail-local-sp</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessageRef">MSG_FORM_ACT_LIVRE_RETURN</camunda:inputParameter>
          <camunda:inputParameter name="gnspdMessage">${"action": "rejete", "motif": this.data.UserTask_X_Verification.result.submissionData.motif ?? "Non conforme", "reference": this.data.xref}</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskIsVisible">false</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel" />
          <camunda:inputParameter name="gnspdTaskStatus">Pending</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToSendRejet</bpmn:incoming>
      <bpmn:outgoing>Flow_X_ToEndRejet</bpmn:outgoing>
    </bpmn:sendTask>

    <!-- End Events XFlow -->
    <bpmn:endEvent id="EndEvent_X_Accepte" name="Candidature acceptée" camunda:modelerTemplate="tg.gouv.gnspd.endEvent" camunda:type="external" camunda:topic="flow-end-event">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="gnspdTaskIsVisible">true</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskLabel">Candidature acceptée</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskStatus">Done</camunda:inputParameter>
          <camunda:inputParameter name="gnspdTaskOrder" />
          <camunda:inputParameter name="gnspdTaskKind">citizen</camunda:inputParameter>
          <camunda:inputParameter name="gnspdCostVariable" />
          <camunda:inputParameter name="gnspdCostTotal" />
          <camunda:inputParameter name="gnspdCostUnitaire" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_X_ToEndAccepte</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_X_Rejet" name="Candidature rejetée">
      <bpmn:incoming>Flow_X_ToEndRejet</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_X_RejetJury" name="Non sélectionné">
      <bpmn:incoming>Flow_X_ToEndRejetJury</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows XFlow -->
    <bpmn:sequenceFlow id="Flow_X_ToNotifReception" sourceRef="Event_X_Start" targetRef="ServiceTask_X_NotifReception" />
    <bpmn:sequenceFlow id="Flow_X_ToAgent" sourceRef="ServiceTask_X_NotifReception" targetRef="UserTask_X_Verification" />
    <bpmn:sequenceFlow id="Flow_X_ToDecision" sourceRef="UserTask_X_Verification" targetRef="Gateway_X_Decision" />
    <bpmn:sequenceFlow id="Flow_X_ToSendCorrection" sourceRef="ServiceTask_X_NotifCorrection" targetRef="SendTask_X_ReturnCorrection" />
    <bpmn:sequenceFlow id="Flow_X_ToWaitResub" sourceRef="SendTask_X_ReturnCorrection" targetRef="ReceiveTask_X_Resub" />
    <bpmn:sequenceFlow id="Flow_X_ResubToAgent" sourceRef="ReceiveTask_X_Resub" targetRef="UserTask_X_Verification" />
    <bpmn:sequenceFlow id="Flow_X_ToJuryDecision" sourceRef="UserTask_X_Jury" targetRef="Gateway_X_Jury" />
    <bpmn:sequenceFlow id="Flow_X_ToSendAccepte" sourceRef="ServiceTask_X_NotifSelection" targetRef="SendTask_X_ReturnAccepte" />
    <bpmn:sequenceFlow id="Flow_X_ToEndAccepte" sourceRef="SendTask_X_ReturnAccepte" targetRef="EndEvent_X_Accepte" />
    <bpmn:sequenceFlow id="Flow_X_ToSendRejet" sourceRef="ServiceTask_X_NotifRejet" targetRef="SendTask_X_ReturnRejet" />
    <bpmn:sequenceFlow id="Flow_X_ToEndRejet" sourceRef="SendTask_X_ReturnRejet" targetRef="EndEvent_X_Rejet" />
    <bpmn:sequenceFlow id="Flow_X_ToSendRejetJury" sourceRef="ServiceTask_X_NotifNonSelection" targetRef="SendTask_X_ReturnRejetJury" />
    <bpmn:sequenceFlow id="Flow_X_ToEndRejetJury" sourceRef="SendTask_X_ReturnRejetJury" targetRef="EndEvent_X_RejetJury" />
  </bpmn:process>

  <!-- ===== BPMN DIAGRAM ===== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_FormActLivre">
      <!-- Pools -->
      <bpmndi:BPMNShape id="Participant_Portal_di" bpmnElement="Participant_Portal" isHorizontal="true">
        <dc:Bounds x="140" y="80" width="1800" height="350" />
        <bpmndi:BPMNLabel><dc:Bounds x="155" y="222" width="20" height="66" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Xflow_di" bpmnElement="Participant_Xflow" isHorizontal="true">
        <dc:Bounds x="140" y="500" width="1800" height="600" />
        <bpmndi:BPMNLabel><dc:Bounds x="155" y="755" width="20" height="90" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Portal shapes -->
      <bpmndi:BPMNShape id="Event_P_Start_di" bpmnElement="Event_P_Start">
        <dc:Bounds x="212" y="232" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_P_Submit_di" bpmnElement="SendTask_P_Submit">
        <dc:Bounds x="300" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_P_Wait_di" bpmnElement="ReceiveTask_P_Wait">
        <dc:Bounds x="460" y="210" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_P_Action_di" bpmnElement="Gateway_P_Action" isMarkerVisible="true">
        <dc:Bounds x="625" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_P_Correction_di" bpmnElement="UserTask_P_Correction">
        <dc:Bounds x="740" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_P_Resub_di" bpmnElement="SendTask_P_Resub">
        <dc:Bounds x="900" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_P_Accepte_di" bpmnElement="EndEvent_P_Accepte">
        <dc:Bounds x="742" y="312" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_P_Rejete_di" bpmnElement="EndEvent_P_Rejete">
        <dc:Bounds x="742" y="372" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Portal edges -->
      <bpmndi:BPMNEdge id="Flow_P_ToSubmit_di" bpmnElement="Flow_P_ToSubmit">
        <di:waypoint x="248" y="250" /><di:waypoint x="300" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_ToWait_di" bpmnElement="Flow_P_ToWait">
        <di:waypoint x="400" y="250" /><di:waypoint x="460" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_ToGateway_di" bpmnElement="Flow_P_ToGateway">
        <di:waypoint x="560" y="250" /><di:waypoint x="625" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Correction_di" bpmnElement="Flow_P_Correction">
        <di:waypoint x="650" y="225" /><di:waypoint x="650" y="160" /><di:waypoint x="740" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Accepte_di" bpmnElement="Flow_P_Accepte">
        <di:waypoint x="675" y="250" /><di:waypoint x="700" y="250" /><di:waypoint x="700" y="330" /><di:waypoint x="742" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P_Rejete_di" bpmnElement="Flow_P_Rejete">
