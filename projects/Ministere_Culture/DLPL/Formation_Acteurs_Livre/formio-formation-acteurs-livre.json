                    "tag": "div",
                    "key": "htmlRecapitulatifFinal",
                    "content": "<div id=\"recapitulatif-container\" class=\"mt-4 mb-4\"></div>\n<script>\n  setTimeout(() => {\n    const container = document.getElementById('recapitulatif-container');\n    if (!container || !window.formioInstance) return;\n    const data = window.formioInstance._data;\n    let html = '<div class=\"card shadow-sm border-success\">';\n    html += '<div class=\"card-header bg-success text-white\"><h4 class=\"mb-0\"><i class=\"fa fa-list-alt me-2\"></i>Récapitulatif de votre démarche</h4></div>';\n    html += '<div class=\"card-body bg-light\"><div class=\"row\">';\n    html += '<div class=\"col-sm-6 mb-3\"><strong>Nom : </strong>' + (data.nom || '-') + '</div>';\n    html += '<div class=\"col-sm-6 mb-3\"><strong>Prénoms : </strong>' + (data.prenom || '-') + '</div>';\n    html += '<div class=\"col-sm-6 mb-3\"><strong>Email : </strong>' + (data.email || '-') + '</div>';\n    html += '<div class=\"col-sm-6 mb-3\"><strong>Téléphone : </strong>' + (data.telephone || '-') + '</div>';\n    html += '<div class=\"col-sm-12 mb-3\"><strong>Catégorie d\\'acteur : </strong><span class=\"badge bg-primary fs-6\">' + (data.categorieActeur || '-') + '</span></div>';\n    html += '</div></div></div>';\n    container.innerHTML = html;\n  }, 500);\n</script>"
                },
